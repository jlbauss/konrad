{
  // The name shown in your editor when the devcontainer is running.
  "name": "konrad",
  // Tells your editor how to build the container.
  // It looks for "Dockerfile" in this same .devcontainer folder.
  "build": {
    "dockerfile": "Dockerfile"
  },
  // The Linux user the editor connects as.
  // "node" is the default non-root user in the node:24 base image.
  "remoteUser": "node",
  "containerUser": "node",
  "updateRemoteUserUID": false,
  // Podman-specific: map host UID/GID 1000 to the container's `node` user so
  // bind-mounted /workspace files have correct ownership without chowning.
  // Docker does not accept this flag — see BACKLOG.md (Docker support).
  "runArgs": [
    "--userns=keep-id:uid=1000,gid=1000"
  ],
  // Live two-way bind mount of the project folder.
  // ${localWorkspaceFolder} = the folder you opened on your host.
  // /workspace = where it appears inside the container.
  // consistency=delegated = slightly faster on macOS (container writes preferred).
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  // The folder the editor opens when the container starts.
  "workspaceFolder": "/workspace",
  // Named volumes so opencode state survives container rebuilds.
  // Without these every rebuild wipes /connect auth, session history,
  // and the autoupdated opencode binary in ~/.npm-global.
  // (See README → "Why a named volume for opencode state".)
  "mounts": [
    "source=konrad-opencode-data,target=/home/node/.local/share/opencode,type=volume",
    "source=konrad-opencode-cache,target=/home/node/.cache/opencode,type=volume",
    "source=konrad-npm-global,target=/home/node/.npm-global,type=volume"
  ],
  // On every start, verify the host's LM Studio server is reachable.
  // konrad is useless without it, so fail loudly rather than later.
  "postStartCommand": "curl --max-time 2 -sf http://host.containers.internal:1234/v1/models > /dev/null && echo '[konrad] LM Studio reachable.' || echo '[konrad] WARNING: LM Studio not reachable at host.containers.internal:1234. Start LM Studio on the host and load qwen/qwen3.6-35b-a3b before using opencode.'"
}
