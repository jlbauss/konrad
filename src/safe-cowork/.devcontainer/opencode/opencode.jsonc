{
  // Points to the official OpenCode JSON schema.
  // This enables autocomplete and validation in editors like VS Code.
  "$schema": "https://opencode.ai/config.json",
  // Configure which LLM providers OpenCode can use.
  "provider": {
    // Local LM Studio server on the Mac host.
    // host.containers.internal resolves to the host from inside Podman.
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://host.containers.internal:1234/v1"
      },
      "models": {
        "qwen3.6-35b-a3b": {
          "name": "qwen3.6-35b-a3b"
        }
      }
    }
  },
  // Default model on startup. Remove this line to pick interactively via /models.
  "model": "lmstudio/qwen3.6-35b-a3b",
  // Automatically update OpenCode when a new version is available.
  "autoupdate": true
}