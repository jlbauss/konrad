# Operational state of any local konrad session in this repo
# (sessions, sqlite, cache). Planning files live in .agent/ too,
# but those are committable so this ignore is scoped tightly.
.agent/opencode/

# Skill-eval workspaces: bulky test artifacts (inputs, outputs,
# transcripts, grading) from iterating on Konrad's opencode skills.
# Kept out of git because they regenerate on every eval pass.
.skill-eval/

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Freedesktop trash dirs (created by trash-cli inside the dev container
# when files under /workspace are deleted — they live next to the
# originals on the host filesystem so deletes survive container rebuilds).
.Trash-*

# Logs
*.log
/.claude/
