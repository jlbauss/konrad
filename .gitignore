# Operational state of any local konrad session in this repo
# (sessions, sqlite, cache). Planning files live in .agent/ too,
# but those are committable so this ignore is scoped tightly.
.agent/opencode/

# Skill-eval workspaces: bulky test artifacts (inputs, outputs,
# transcripts, grading) from iterating on Konrad's opencode skills.
# Kept out of git because they regenerate on every eval pass.
.skill-eval/

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Python bytecode, venvs, and tool caches. The skills under image/
# ship Python scripts; running them locally (or via verify scripts
# under .skill-eval/) drops __pycache__ dirs and may create a uv venv.
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# Freedesktop trash dirs (created by trash-cli inside the dev container
# when files under /workspace are deleted — they live next to the
# originals on the host filesystem so deletes survive container rebuilds).
.Trash-*

# Logs
*.log

# Claude local settings
/.claude/settings.local.json

# Agent git-worktree scratch (transient checkouts created by Claude Code's
# worktree isolation — full working trees, never committable). Re-added after
# the .claude/-wide ignore was narrowed to track .claude/settings.json.
/.claude/worktrees/
