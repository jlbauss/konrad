{
  "permissions": {
    "allow": [
      "Bash(shellcheck:*)",
      "Bash(reuse:*)",
      "Bash(yamllint:*)",
      "Bash(hadolint:*)",
      "Bash(actionlint:*)",
      "Bash(npx --yes markdownlint-cli2:*)",
      "Bash(bash -n:*)",
      "Bash(sh -n:*)",
      "Bash(git:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:opencode.ai)",
      "WebFetch(domain:gitlab.git.nrw)",
      "WebFetch(domain:huggingface.co)",
      "Read"
    ],
    "deny": [
      "Bash(git push:*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.opencode-secrets/**)",
      "Read(**/.opencode-secrets/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/.git-credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.docker/config.json)",
      "Bash(gh:*)"
    ],
    "ask": [
      "Bash(podman push:*)",
      "Bash(podman run:*)",
      "Bash(podman system prune:*)"
    ]
  },
  "enabledPlugins": {
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  }
}