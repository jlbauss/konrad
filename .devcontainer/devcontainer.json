{
  // Claude dev container — for working ON konrad. VS Code auto-detects
  // this because of the leading dot.
  //
  // Distinct from the planned consumer path: a `konrad init-devcontainer`
  // subcommand will scaffold a Dev Container into a *user's* own project
  // (ROADMAP.md). That config lives in the user's tree, never here — this
  // .devcontainer/ only ever configures Konrad's own repo.
  "name": "konrad-claude-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "node",
  "containerUser": "node",
  // --userns=keep-id (in runArgs below) handles UID/GID mapping at the
  // namespace level, so VS Code's updateRemoteUserUID is redundant.
  "updateRemoteUserUID": false,
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // Podman: map container UID/GID 1000 (the `node` user) to the host
  // user, so files in bind-mounted /workspace stay owned by the host
  // user and are editable. Without this, rootless Podman maps node@1000
  // to a sub-UID and edits fail. Podman-specific — Docker support is on
  // the roadmap.
  "runArgs": [
    "--userns=keep-id:uid=1000,gid=1000"
  ],
  // Persist state across container rebuilds via named volumes:
  //   .claude         → Claude Code credentials, sessions, projects
  //   .vscode-server  → installed VS Code extensions + their state
  // The names are project-scoped so they don't collide with other
  // dev containers on the same machine.
  //
  // Plus a bind-mount overlaying just .claude/skills/ from the host's
  // own Claude Code skills dir. Skills are inert content (no container
  // state) so they're safe to share across host and container — drop a
  // skill into ~/.claude/skills/ on the host and the in-container
  // Claude instance sees it instantly. Sessions/credentials stay on
  // the named volume above. Host dir must exist before the container
  // starts; create with `mkdir -p ~/.claude/skills` on the host.
  //
  // Self-testing socket mount: bind the HOST's rootless podman socket in,
  // so `podman` here (and therefore `konrad-dev --rebuild` / smoke-test /
  // shelling into the runtime image) drives the host daemon. This is what
  // lets the agent working ON konrad actually exercise the konrad runtime
  // image without round-tripping through the user. containerEnv below
  // points the podman client at it via CONTAINER_HOST.
  //
  // The mount source is NOT the host socket directly — it's a stable symlink
  // that initializeCommand (below) drops at .devcontainer/.cache/, resolving
  // to the real per-OS socket when one exists and to /dev/null when it
  // doesn't. A long-form type=bind source MUST exist or container creation
  // hard-fails, and the real socket path is OS-specific and may be absent
  // (macOS has no $XDG_RUNTIME_DIR; a Linux host may not have enabled the
  // socket; a non-podman host has none at all). Going through the symlink
  // means the container ALWAYS starts, degrading to "no self-testing"
  // (podman calls against /dev/null fail cleanly) rather than refusing to
  // come up. See .devcontainer/ensure-podman-sock.sh.
  //
  // HOST PREREQUISITE (one-time) for self-testing to actually work:
  //   Linux:  systemctl --user enable --now podman.socket
  //   macOS:  point VS Code at the rootful-connection shim — user setting
  //           "dev.containers.dockerPath": <abs path>/.devcontainer/podman-vscode.sh
  // Without either, the container still starts; only the podman calls fail.
  //
  // macOS: the container runs INSIDE the podman-machine VM. The rootless VM
  // socket is unreachable from a nested container (unmapped-uid wall), so the
  // shim creates THIS dev container via the machine's rootful connection and
  // rewrites the keep-id runArg below into explicit --uidmap/--gidmap flags
  // (rootful keep-id is an identity map; virtiofs presents raw Mac ids); the
  // symlink then targets the VM-internal rootful socket. The machine's
  // default connection stays rootless — day-to-day podman on the Mac is
  // untouched. Details: .devcontainer/podman-vscode.sh, CONTRIBUTING.md.
  "initializeCommand": "sh .devcontainer/ensure-podman-sock.sh",
  "mounts": [
    "source=konrad-claude-dev-claude,target=/home/node/.claude,type=volume",
    "source=konrad-claude-dev-vscode-server,target=/home/node/.vscode-server,type=volume",
    "source=${localEnv:HOME}/.claude/skills,target=/home/node/.claude/skills,type=bind,consistency=delegated",
    "source=${localWorkspaceFolder}/.devcontainer/.cache/podman-host.sock,target=/run/podman-host.sock,type=bind",
    // Your real konrad config layer, bound in at its normal path. Two jobs:
    // konrad-dev in here behaves like your real konrad (same model/agents/
    // skills), and bin/konrad can stat which layers exist before mounting them
    // into the self-test runtime container from KONRAD_REMOTE_HOST_CONFIG below.
    // ensure-podman-sock.sh mkdir's the source so this never fails to resolve.
    "source=${localEnv:HOME}/.config/konrad,target=/home/node/.config/konrad,type=bind,consistency=delegated"
  ],
  // CONTAINER_HOST → podman client talks to the host socket mounted above.
  // KONRAD_REMOTE_* → tell bin/konrad it's driving a REMOTE daemon, so it
  // rewrites bind-mount SOURCES to their real host paths (the daemon resolves
  // them on its own filesystem). KONRAD_REMOTE_HOST_ROOT maps the /workspace
  // mount (see remote_host_path()); KONRAD_REMOTE_HOST_CONFIG is the host path
  // of the config layer bound in above, so the self-test runtime container gets
  // your real org/user layers mounted and composes baked<org<user exactly like
  // a normal run (see bin/konrad podman_run). The log dir stays host-only and
  // is the one thing self-testing skips.
  "containerEnv": {
    "CONTAINER_HOST": "unix:///run/podman-host.sock",
    "KONRAD_REMOTE_HOST_ROOT": "${localWorkspaceFolder}",
    "KONRAD_REMOTE_GUEST_ROOT": "/workspace",
    "KONRAD_REMOTE_HOST_CONFIG": "${localEnv:HOME}/.config/konrad"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "timonwong.shellcheck"
      ]
    }
  }
}