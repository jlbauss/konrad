{
  // Points to the official opencode JSON schema.
  // Enables autocomplete and validation in editors.
  "$schema": "https://opencode.ai/config.json",
  // Configure which LLM providers opencode can use.
  "provider": {
    // Local LM Studio server running on the host.
    // host.containers.internal resolves to the host from inside Podman.
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://host.containers.internal:1234/v1"
      },
      "models": {
        // Canonical LM Studio id for Qwen3.6-35B-A3B.
        // If LM Studio exposes the model under a different name on your host,
        // change this key and the "model" default below to match.
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B"
        }
      }
    }
  },
  // Default model on startup. Remove this line to pick interactively via /models.
  "model": "lmstudio/qwen/qwen3.6-35b-a3b",
  // Auto-update opencode when a new version is available.
  // See ROADMAP.md — we plan to pin a version and turn this off.
  "autoupdate": true
}
