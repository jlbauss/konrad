//
// konrad's baked-in opencode defaults.
//
// This file is COPIED into the image at /etc/konrad/opencode-defaults.jsonc.
// It is NOT loaded by opencode directly. At container start, the entrypoint
// left-folds up to three layers and writes the result to
// /home/node/.config/opencode/opencode.jsonc, which opencode then reads as its
// global config:
//   1. this file                              (baked into the image)
//   2. ~/.config/konrad/org/opencode.jsonc    (org layer, optional)
//   3. ~/.config/konrad/user/opencode.jsonc   (user layer, optional)
//
// Later layers win on conflicting keys (precedence: baked < org < user); new
// keys from any layer come through; arrays replace. See README → Configuration.
{
  // Points to the official opencode JSON schema.
  "$schema": "https://opencode.ai/config.json",

  // System `instructions`, layered baked < org < user. Each entry is a glob
  // over one FIXED instructions/ dir; opencode expands them itself — skipping
  // absent dirs/files, de-duplicating, preserving this order (see opencode's
  // Instruction.systemPaths). So a layer adds instructions by DROPPING a *.md
  // into its instructions/ dir — no JSON to author, no array-replace footgun
  // (only this baked layer declares the array; nobody else needs to touch it).
  //
  //   - environment.md is konrad's runtime-environment manifest (tool
  //     inventory, Python libs, filesystem layout, constraints — NOT behavior,
  //     which lives in agents/). It's the baked layer's instructions/ entry.
  //     The entrypoint also writes the egress allow-list there at run time, so
  //     the same baked glob picks it up.
  //   - ORG layers (~/.config/konrad/org/<name>/) get NO entry of their own:
  //     opencode globs only the basename component of an entry (the dirname is
  //     a literal), so `org/*/instructions/*.md` could never match. The
  //     entrypoint copies each layer's instructions/*.md (and back-compat
  //     AGENTS.md) into the baked instructions/ dir as org-<name>-<file>,
  //     where the FIRST glob below finds them — same mechanism as the
  //     generated allow-list file.
  //
  // opencode additionally auto-discovers any AGENTS.md — the user-level
  // (~/.config/opencode/AGENTS.md) and project-level (workspace root) — which
  // stays the user's own slot. See README → "Adding your own model
  // instructions" and ARCHITECTURE → Configuration & instructions.
  //
  // environment.md lives under opencode/instructions/ (not /etc/konrad/) so
  // that edits to it don't invalidate the expensive model-download layer in
  // the multi-stage Dockerfile build.
  "instructions": [
    "/home/node/.config/opencode/instructions/*.md",
    "/home/node/.config/konrad/user/instructions/*.md"
  ],

  // Hide opencode Zen from the picker. Zen is opencode's hosted/paid
  // model gateway; konrad is local-first, so it's opt-in (a user who
  // wants it removes "opencode" from this list in their override).
  "disabled_providers": ["opencode"],

  // No dynamic model discovery. konrad previously shipped the
  // opencode-models-discovery plugin to auto-populate the picker from each
  // provider's /v1/models endpoint, but the plugin added ~3-4 s of Bun
  // startup time and tripped on LM Studio's embedding modality. Until we
  // ship an inline replacement (see ROADMAP → Future features), users
  // declare their own models in ~/.config/konrad/opencode.jsonc — see
  // README → Configuration → "Recipes".

  // Local-engine providers, pre-wired to their default ports on the host.
  // host.containers.internal resolves to the host machine from inside Podman.
  // Add more providers (Anthropic, OpenRouter, etc.) in your user override.
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://host.containers.internal:1234/v1"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://host.containers.internal:11434/v1"
      }
    },
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://host.containers.internal:8080/v1"
      }
    }
  },

  // No top-level `"model"` set on purpose. opencode persists the
  // user's last selection to ~/.local/state/opencode/model.json (kept
  // across konrad runs by the konrad-state named volume), so the next
  // launch starts on whatever they used last. On first run, opencode
  // prompts for a model interactively. Setting "model" here would
  // override that persistence on every launch — see commit history.
  //
  // konrad is optimized for Qwen3.6-class local models (e.g.
  // qwen3.6-35b-a3b on LM Studio) — see README → Configuration.

  // Baseline tool permissions, shared by every agent (objects deep-merge, so a
  // per-agent `permission` block in agents/*.md overrides only the keys it
  // names — see agents/manual-transformer.md for the subagent pattern). The
  // model is the *sandbox boundary*: the container is disposable and runs as a
  // non-root user, so the agent acts freely inside it; the only things gated are
  // the ones that reach *past* the box.
  //   - allow  — anything inside the container, and edits to the bind-mounted
  //              /workspace (the deny list below protects secrets/integrity).
  //   - ask    — `rm -rf`: /workspace is the user's REAL project files, so an
  //              irreversible delete there is the one action worth a confirm.
  //   - deny   — root (`sudo`) and host container/cluster control
  //              (`podman`/`docker`/`kubectl`): escape vectors, and `deny` is
  //              prompt-free, so it costs the user nothing.
  // Network tools (`webfetch`/`websearch`, and `curl` et al. under bash) stay
  // `allow`: the egress firewall is the real network boundary — it forwards only
  // an allow-list regardless of which binary makes the call — so gating them
  // here would only add friction (or a false sense of safety) without adding
  // containment. `external_directory` opens up too, minus the secrets volume:
  // auth.json (provider keys) lives there, and the firewall blocks exfil but not
  // a prompt-injected agent writing a key into the workspace, so keep it out of
  // reach. See ARCHITECTURE → Configuration & instructions.
  "permission": {
    "edit": {
      "**/.env*": "deny",
      "**/.git/**": "deny",
      "**/*.key": "deny",
      "**/*.pem": "deny",
      "**/*.secret": "deny",
      "node_modules/**": "deny",
      "**": "allow"
    },
    "external_directory": {
      "/home/node/.opencode-secrets/**": "deny",
      "**": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "sudo *": "deny",
      "podman *": "deny",
      "docker *": "deny",
      "kubectl *": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",
    // `question` is opencode's human-in-the-loop tool (multiple-choice picker
    // with a free-text fallback). It is OPT-IN: opencode only registers it when
    // a `permission.question` key is present — without this line it never
    // appears in the agent's toolset, so konrad.md's "ask via the question
    // tool" instructions fail at runtime ("tool not available"). Subagents have
    // no user in their loop, so manual-transformer.md sets `question: deny`.
    "question": "allow",
    // `todowrite` is on by default (unlike `question`), but pin it explicitly so
    // the in-session planning channel konrad.md leans on can never be turned off
    // out from under the agent by a future opencode default change.
    "todowrite": "allow"
  },

  // Primary agent on startup. Defined in agents/konrad.md.
  "default_agent": "konrad",

  // Disable opencode's built-in `build` and `plan` agents so konrad is
  // the only primary the user sees. konrad's body absorbs both roles —
  // full-tool execution by default, plan-only behaviour via prompting
  // when the user asks for it.
  "agent": {
    "build": { "disable": true },
    "plan":  { "disable": true }
  },

  // Don't have opencode check npm for new versions on every startup.
  // The check adds ~1-3s of cold-network latency to every launch, and
  // makes the immutable-image story fuzzy. To update opencode, rebuild
  // the konrad image (which `npm install -g opencode-ai` at build time).
  "autoupdate": false
}
