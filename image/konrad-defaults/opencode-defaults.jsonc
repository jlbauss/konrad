// konrad's baked-in opencode defaults.
//
// This file is COPIED into the image at /etc/konrad/opencode-defaults.jsonc.
// It is NOT loaded by opencode directly. At container start, the entrypoint
// deep-merges this file with the user's optional override
// (~/.config/konrad/opencode.jsonc on the host, bind-mounted in) and writes
// the result to /home/node/.config/opencode/opencode.jsonc, which opencode
// then reads as its global config.
//
// User overrides win on conflicting keys; new keys from either side come
// through; arrays replace. See README → Configuration.
{
  // Points to the official opencode JSON schema.
  "$schema": "https://opencode.ai/config.json",

  // konrad's base instructions for the model, loaded via the instructions
  // key. opencode also additively loads any AGENTS.md it discovers — both
  // the user-level one (~/.config/opencode/AGENTS.md) and the project-level
  // one (workspace root). Keeping konrad's base on the instructions key
  // (rather than parking it as an AGENTS.md) gives us a clear "konrad's
  // domain vs user's domain" split: AGENTS.md is for user content.
  // See README → Configuration → "Adding your own model instructions".
  "instructions": ["/etc/konrad/instructions.md"],

  // Hide opencode Zen from the picker. Zen is opencode's hosted/paid
  // model gateway; konrad is local-first, so it's opt-in (a user who
  // wants it removes "opencode" from this list in their override).
  "disabled_providers": ["opencode"],

  // Dynamic model discovery for Ollama / llama.cpp. The plugin queries
  // each provider's /v1/models endpoint at startup. Each call has a
  // 3s timeout — so an unreachable provider costs 3s of startup delay.
  //
  // Two things keep this fast:
  //   1. lmstudio is excluded statically here (upstream bug — it emits
  //      "embedding" as a modality which opencode's schema rejects).
  //   2. konrad's CLI (bin/konrad) probes ollama and llama.cpp on the
  //      host BEFORE launching the container and dynamically adds them
  //      to providers.exclude if they're not reachable. That layer
  //      arrives via merge-config.js as a runtime override. See
  //      image/entrypoint.sh.
  //
  // Pinned to @0.8.0 (not @latest) so opencode doesn't make a network
  // call to npm on every startup to check for a newer version.
  // MIT-licensed; see NOTICE.
  "plugin": [
    ["opencode-models-discovery@0.8.0", {
      "providers": { "exclude": ["lmstudio"] }
    }]
  ],

  // Local-engine providers, pre-wired to their default ports on the host.
  // host.containers.internal resolves to the host machine from inside Podman.
  // Add more providers (Anthropic, OpenRouter, etc.) in your user override.
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://host.containers.internal:1234/v1"
      },
      "models": {
        // Konrad's documented default. Re-declared because the discovery
        // plugin is currently excluded for lmstudio (see plugin comment
        // above). If you've loaded a different model in LM Studio, add it
        // to this map in your ~/.config/konrad/opencode.jsonc override.
        "qwen/qwen3.6-35b-a3b": { "name": "Qwen3.6 35B A3B" }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://host.containers.internal:11434/v1"
      }
    },
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://host.containers.internal:8080/v1"
      }
    }
  },

  // No top-level `"model"` set on purpose. opencode persists the
  // user's last selection to ~/.local/state/opencode/model.json (kept
  // across konrad runs by the konrad-state named volume), so the next
  // launch starts on whatever they used last. On first run, opencode
  // prompts for a model interactively. Setting "model" here would
  // override that persistence on every launch — see commit history.
  //
  // konrad is optimized for Qwen3.6-class local models (e.g.
  // qwen3.6-35b-a3b on LM Studio) — see README → Configuration.

  // Primary agent on startup. Defined in agents/konrad.md.
  "default_agent": "konrad",

  // Disable opencode's built-in `build` and `plan` agents so konrad is
  // the only primary the user sees. konrad's body absorbs both roles —
  // full-tool execution by default, plan-only behaviour via prompting
  // when the user asks for it.
  "agent": {
    "build": { "disable": true },
    "plan":  { "disable": true }
  },

  // Don't have opencode check npm for new versions on every startup.
  // The check adds ~1-3s of cold-network latency to every launch, and
  // makes the immutable-image story fuzzy. To update opencode, rebuild
  // the konrad image (which `npm install -g opencode-ai` at build time).
  "autoupdate": false
}
