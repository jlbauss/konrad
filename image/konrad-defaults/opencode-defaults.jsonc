// konrad's baked-in opencode defaults.
//
// This file is COPIED into the image at /etc/konrad/opencode-defaults.jsonc.
// It is NOT loaded by opencode directly. At container start, the entrypoint
// deep-merges this file with the user's optional override
// (~/.config/konrad/opencode.jsonc on the host, bind-mounted in) and writes
// the result to /home/node/.config/opencode/opencode.jsonc, which opencode
// then reads as its global config.
//
// User overrides win on conflicting keys; new keys from either side come
// through; arrays replace. See README → Configuration.
{
  // Points to the official opencode JSON schema.
  "$schema": "https://opencode.ai/config.json",

  // konrad's base instructions for the model, loaded via the instructions
  // key. opencode also additively loads any AGENTS.md it discovers — both
  // the user-level one (~/.config/opencode/AGENTS.md) and the project-level
  // one (workspace root). Keeping konrad's base on the instructions key
  // (rather than parking it as an AGENTS.md) gives us a clear "konrad's
  // domain vs user's domain" split: AGENTS.md is for user content.
  // See README → Configuration → "Adding your own model instructions".
  "instructions": ["/etc/konrad/instructions.md"],

  // Hide opencode Zen from the picker. Zen is opencode's hosted/paid
  // model gateway; konrad is local-first, so it's opt-in (a user who
  // wants it removes "opencode" from this list in their override).
  "disabled_providers": ["opencode"],

  // Dynamic model discovery. On startup, this plugin queries each
  // OpenAI-compatible provider's /v1/models endpoint and adds whatever
  // is actually loaded to the model picker. Means we don't have to
  // hardcode model lists for LM Studio / Ollama / llama.cpp — users
  // see exactly what they have running. MIT-licensed; see NOTICE.
  "plugin": ["opencode-models-discovery@latest"],

  // Local-engine providers, pre-wired to their default ports on the host.
  // host.containers.internal resolves to the host machine from inside Podman.
  // No models declared here — the discovery plugin fills them in at start
  // from whatever the provider actually has loaded.
  // Add more providers (Anthropic, OpenRouter, etc.) in your user override.
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://host.containers.internal:1234/v1"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://host.containers.internal:11434/v1"
      }
    },
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://host.containers.internal:8080/v1"
      }
    }
  },

  // No default `model` set on purpose. On first run, opencode prompts the
  // user to pick a provider+model. konrad is optimized for Qwen3.6-class
  // local models (e.g. qwen3.6-35b-a3b on LM Studio) but any opencode-
  // supported provider works — see README → Configuration for recipes.

  // Primary agent on startup. Defined in agents/konrad.md.
  "default_agent": "konrad",

  // Disable opencode's built-in `build` and `plan` agents so konrad is
  // the only primary the user sees. konrad's body absorbs both roles —
  // full-tool execution by default, plan-only behaviour via prompting
  // when the user asks for it.
  "agent": {
    "build": { "disable": true },
    "plan":  { "disable": true }
  },

  // Auto-update opencode when a new version is available.
  // See ROADMAP.md — we plan to pin a version and turn this off.
  "autoupdate": true
}
