#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 Jan-Luca Bauß
# SPDX-License-Identifier: AGPL-3.0-or-later
# konrad — sandboxed opencode in a Podman container. See `konrad --help`.
set -euo pipefail

LM_STUDIO_HOST_URL="http://localhost:1234/v1/models"

# Image tags. Two distinct surfaces:
#   konrad:latest  — what `konrad --update` writes (= the published image
#                    from ghcr.io). The default when this script is
#                    invoked as `konrad`.
#   konrad:local   — what `konrad-dev --rebuild` writes (= your local
#                    build, for working ON konrad itself). The default
#                    when this script is invoked as `konrad-dev` (the
#                    contributor symlink — see CONTRIBUTING.md).
#
# Same script, two binaries on PATH. The invocation name decides which
# image tag is the default — `konrad` runs the published image,
# `konrad-dev` runs your dev build. Neither touches the other, so a
# contributor can keep both side by side. KONRAD_IMAGE still overrides
# either path for ad-hoc tags (`KONRAD_IMAGE=konrad:pr-42 konrad`).
#
# KONRAD_IMAGE does NOT redirect what --update/--rebuild produce; those
# always write to their fixed tags.
IMAGE_LOCAL_TAG="konrad:local"
case "$(basename -- "$0")" in
  konrad-dev) IMAGE_DEFAULT="$IMAGE_LOCAL_TAG" ;;
  *)          IMAGE_DEFAULT="konrad:latest"   ;;
esac
IMAGE_NAME="${KONRAD_IMAGE:-$IMAGE_DEFAULT}"

# Registry coordinates — where CI publishes the prebuilt image and where
# `konrad --update` pulls from. `:latest` always points at the newest
# build that passed the smoke gate (see .github/workflows/build-image.yml).
# CI runs on a GitHub mirror of this repo even though the primary repo
# lives on gitlab.git.nrw — see the README's "Pinning strategy" section.
REGISTRY_IMAGE="ghcr.io/jlbauss/konrad:latest"

# URL of the curl|sh installer. `konrad --update` re-runs it after the
# image pull so the CLI itself stays fresh; standalone installs don't
# otherwise auto-update.
INSTALL_REMOTE_URL="https://gitlab.git.nrw/jbauss2/konrad/-/raw/main/scripts/install-remote.sh"

# Shared (cross-project) named volumes.
SECRETS_VOLUME="konrad-secrets"
CACHE_VOLUME="konrad-cache"
STATE_VOLUME="konrad-state"

# Volume profile (--profile <name>). When set, the state + cache volumes are
# suffixed (konrad-state → konrad-state-<name>, konrad-cache → konrad-cache-<name>)
# so a named profile gets throwaway opencode state — its own session DB, model
# selection, and caches — without touching the user's real ones. The canonical
# use is `--profile selftest` for end-to-end self-test runs: a live run against
# the real konrad-state otherwise triggers opencode's one-time DB migration on
# it and persists a model/session the user didn't pick (hit 2026-06-03 during
# dev-container self-testing). SECRETS is deliberately NOT suffixed — it stays
# shared so a profile reuses the user's real provider credentials (auth.json);
# an isolated secrets volume would start empty and have no API key to resolve a
# model. Empty (no --profile) → the unsuffixed volumes above, unchanged.
KONRAD_PROFILE=""

# Where konrad keeps host-side config. Two symmetric sublayers live under it:
#   org/   — an organization's shipped defaults (dropped in by a provisioning
#            package; see docs/examples/org-package/). Merged ABOVE the baked
#            image defaults but BELOW the user's own layer.
#   user/  — the individual user's overrides.
# Merge precedence is baked < org < user (last writer wins). Pre-org-layer
# konrad kept the user layer flat at $KONRAD_CFG_DIR/*; migrate_flat_config()
# relocates it into user/ on first run of this version.
KONRAD_CFG_DIR="${HOME}/.config/konrad"
ORG_CFG_DIR="$KONRAD_CFG_DIR/org"
USER_CFG_DIR="$KONRAD_CFG_DIR/user"

# Central log directory on the host (XDG state). Holds opencode's
# structured log files plus a per-session sidecar that records the host
# workspace path. Shared across all projects so logs live in one
# discoverable place; pruned (>7d) before every launch.
KONRAD_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/konrad/log"

# --- Resolve the script's source directory, even when symlinked ---
# Lets `konrad-dev --rebuild` find image/Dockerfile no matter where
# bin/konrad is symlinked from.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SRC_DIR_TMP="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SRC_DIR_TMP/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
IMAGE_CONTEXT="$REPO_ROOT/image"

# CLI version. Three sources, in priority order:
#   1. $REPO_ROOT/VERSION       — present when installed from a clone
#                                  (the konrad-dev symlink path documented
#                                  in CONTRIBUTING.md).
#   2. $KONRAD_VERSION_BAKED    — rewritten by scripts/install-remote.sh
#                                  at install time (curl|sh path), so
#                                  standalone installs still report the
#                                  real version instead of "dev".
#   3. "dev"                     — last-ditch fallback.
KONRAD_VERSION_BAKED=""  # rewritten by scripts/install-remote.sh
if [[ -f "$REPO_ROOT/VERSION" ]]; then
  KONRAD_VERSION="$(cat "$REPO_ROOT/VERSION")"
elif [[ -n "$KONRAD_VERSION_BAKED" ]]; then
  KONRAD_VERSION="$KONRAD_VERSION_BAKED"
else
  KONRAD_VERSION="dev"
fi

# --- Output helpers (all go to stderr; stdout is reserved for tool output) ---

die()  { printf 'konrad: %s\n' "$*" >&2; exit 1; }
warn() { printf 'konrad: warning: %s\n' "$*" >&2; }
info() { printf 'konrad: %s\n' "$*" >&2; }

# Debug mode: KONRAD_DEBUG=1 turns on per-phase timestamps (host + container)
# and points at opencode's structured file log. Off by default — flip with
# -v/--verbose or by exporting KONRAD_DEBUG=1 in the environment.
KONRAD_DEBUG="${KONRAD_DEBUG:-0}"
# Raw HTTP trace: a separate, noisier opt-in than -v. KONRAD_TRACE_FETCH=1
# makes the container dump every Bun fetch (full headers) to stderr — for
# hunting network stalls the file log can't surface. Deliberately NOT bundled
# into -v (it buries everything else; see image/entrypoint.sh). Passed through
# to the container via -e; off by default.
KONRAD_TRACE_FETCH="${KONRAD_TRACE_FETCH:-0}"

# Egress firewall (ON by default). The agent container runs on an isolated
# Podman network with NO route to the internet; a sidecar — the same konrad
# image launched as `konrad-proxy` — is the only member with egress and forwards
# only the allow-listed hosts (derived providers + a baked infra floor + the
# user's allowed_hosts). Shrinks the blast radius of a prompt-injected agent
# exfiltrating secrets/workspace data. See image/konrad-proxy-entrypoint.sh and
# fw_setup() below. Disable per-run with --no-firewall (or KONRAD_FIREWALL=0).
# Add one-off allowed hosts with --allow-host h1,h2 (or KONRAD_ALLOW_HOST=…).
KONRAD_FIREWALL="${KONRAD_FIREWALL:-1}"
KONRAD_PROXY_PORT="${KONRAD_PROXY_PORT:-8888}"
KONRAD_ALLOW_HOST="${KONRAD_ALLOW_HOST:-}"

# Default user-namespace mapping: container node(1000) ⇄ the invoking host user,
# so bind-mounted files keep sane ownership. Single source of the keep-id flag,
# reused by the agent run (podman_run) and the persistent dev-container firewall
# verb (do_fw). The rootful remote-daemon variant is built inline in podman_run.
KONRAD_KEEPID_USERNS="--userns=keep-id:uid=1000,gid=1000"

# $SECONDS is bash's built-in script-elapsed counter (portable to bash 3.2
# on macOS). The container side uses GNU `date +%N` for sub-second precision
# since Linux has that. Both are good enough to spot what's slow.
dbg() {
  [[ "$KONRAD_DEBUG" != "1" ]] && return 0
  printf 'konrad [debug +%ss]: %s\n' "$SECONDS" "$*" >&2
}

# --- Image-pull progress + registry probes (manifest preflight + awk counter) ---
#
# Why this shape: podman doesn't expose byte-level pull progress anywhere
# (libpod & docker-compat endpoints, events, debug log — all silent on bytes;
# containers/podman issue #24887 is open). The ceiling is a layer counter.
# We fetch the platform-specific manifest via curl+jq to learn the total
# layer count M, then pipe `podman pull` through awk to render `[N/M]` per
# `Copying blob sha256:…` line. jq is a soft-dep — missing jq → warn once
# and fall back to bare `podman pull`. Whole flow is registry-agnostic in
# shape but the token endpoint is ghcr.io-specific today (the only registry
# konrad pulls from).
#
# The same primitives also power `--check-updates`: token + platform
# manifest + config blob → `org.opencontainers.image.version` label, which
# we compare against the locally-installed image to tell the user whether
# a pull would change anything.

# Split `<registry>/<repo>:<tag>` into three space-separated tokens on stdout.
# Defaults `tag` to `latest`. Repo may contain slashes; tokens won't.
_parse_image_ref() {
  local image_ref="$1" tag repo_part
  case "$image_ref" in
    *:*) tag="${image_ref##*:}"; repo_part="${image_ref%:*}" ;;
    *)   tag="latest";            repo_part="$image_ref"      ;;
  esac
  printf '%s %s %s' "${repo_part%%/*}" "${repo_part#*/}" "$tag"
}

# Detect the target arch for podman pull. Podman's VM matches host arch on
# both macOS and Linux, so `uname -m` on the host is the right answer.
_pull_arch() {
  case "$(uname -m)" in
    x86_64|amd64)  printf 'amd64' ;;
    aarch64|arm64) printf 'arm64' ;;
    *)             printf 'amd64' ;;
  esac
}

# Fetch an anonymous pull-scoped bearer token for the given registry/repo.
# Echoes the token or returns silently empty. ghcr.io only today.
_registry_anon_token() {
  local registry="$1" repo="$2" url
  case "$registry" in
    ghcr.io) url="https://ghcr.io/token?service=ghcr.io&scope=repository:${repo}:pull" ;;
    *)       return 0 ;;
  esac
  curl -fsS --max-time 5 "$url" 2>/dev/null \
    | jq -r '.token // .access_token // empty' 2>/dev/null
}

# Fetch the platform-specific image manifest JSON for ${registry}/${repo}:${tag}.
# Echoes the JSON on stdout, or nothing on failure. Handles both single-
# manifest and multi-arch manifest-list / OCI-index shapes.
_registry_platform_manifest() {
  local registry="$1" repo="$2" tag="$3" token="$4"
  local arch accept manifest media_type platform_digest
  arch="$(_pull_arch)"
  accept='application/vnd.docker.distribution.manifest.list.v2+json,application/vnd.oci.image.index.v1+json,application/vnd.docker.distribution.manifest.v2+json,application/vnd.oci.image.manifest.v1+json'
  manifest="$(curl -fsS --max-time 5 \
                -H "Authorization: Bearer $token" \
                -H "Accept: $accept" \
                "https://${registry}/v2/${repo}/manifests/${tag}" 2>/dev/null)"
  [[ -z "$manifest" ]] && return 0
  media_type="$(printf '%s' "$manifest" | jq -r '.mediaType // empty' 2>/dev/null)"
  case "$media_type" in
    *manifest.list*|*image.index*)
      platform_digest="$(printf '%s' "$manifest" \
        | jq -r --arg a "$arch" '
            .manifests[]
            | select(.platform.architecture == $a
                     and (.platform.os == "linux" or .platform.os == null))
            | .digest' 2>/dev/null | head -1)"
      [[ -z "$platform_digest" ]] && return 0
      curl -fsS --max-time 5 \
        -H "Authorization: Bearer $token" \
        -H "Accept: $accept" \
        "https://${registry}/v2/${repo}/manifests/${platform_digest}" 2>/dev/null
      ;;
    *)
      printf '%s' "$manifest"
      ;;
  esac
}

# Fetch the layer count for the platform-specific manifest of $1.
# Prints the count on stdout, or nothing on any failure / unknown registry.
# Always returns 0 so callers can `total="$(manifest_total_layers ... )"`.
manifest_total_layers() {
  command -v jq   >/dev/null 2>&1 || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local registry repo tag token
  read -r registry repo tag <<<"$(_parse_image_ref "$1")"
  token="$(_registry_anon_token "$registry" "$repo")"
  [[ -z "$token" ]] && return 0
  _registry_platform_manifest "$registry" "$repo" "$tag" "$token" \
    | jq -r '.layers | length' 2>/dev/null
  return 0
}

# Fetch the `org.opencontainers.image.version` label from the registry's
# platform-specific image config blob. Three HTTP calls (token, manifest,
# config blob). Prints the label on stdout, or nothing on failure.
# Always returns 0.
registry_image_version() {
  command -v jq   >/dev/null 2>&1 || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local registry repo tag token pm config_digest
  read -r registry repo tag <<<"$(_parse_image_ref "$1")"
  token="$(_registry_anon_token "$registry" "$repo")"
  [[ -z "$token" ]] && return 0
  pm="$(_registry_platform_manifest "$registry" "$repo" "$tag" "$token")"
  [[ -z "$pm" ]] && return 0
  config_digest="$(printf '%s' "$pm" | jq -r '.config.digest // empty' 2>/dev/null)"
  [[ -z "$config_digest" || "$config_digest" == "null" ]] && return 0
  # -L follows redirects: GHCR (and most OCI registries) serve blobs by
  # returning a 307 redirect to a CDN-signed URL. Manifest endpoints don't
  # redirect, but `-L` is harmless there.
  curl -fsSL --max-time 5 \
    -H "Authorization: Bearer $token" \
    "https://${registry}/v2/${repo}/blobs/${config_digest}" 2>/dev/null \
    | jq -r '.config.Labels["org.opencontainers.image.version"] // empty' 2>/dev/null
  return 0
}

# Run `podman pull <image>` with an aggregated [N/M] layer counter on stderr.
# Single-line `\r`-overwrite shape: each blob redraws one line in place,
# sealed with a `\n` at the end. Falls back to a bare pull (no counter)
# when the manifest preflight returns nothing — keeping the happy path
# moving when offline-resolution failed, jq is missing, or a non-ghcr
# registry was passed.
pull_with_progress() {
  local image_ref="$1"
  local total
  total="$(manifest_total_layers "$image_ref" 2>/dev/null || true)"
  if [[ -z "$total" ]] || ! [[ "$total" =~ ^[0-9]+$ ]] || (( total <= 0 )); then
    if ! command -v jq >/dev/null 2>&1; then
      warn "jq not installed; pull-progress counter disabled (install jq for the [N/M] aggregation)."
    fi
    podman pull "$image_ref"
    return $?
  fi

  # Why a bash `while read` loop instead of awk: the previous awk wrapper
  # used `\r` + `\033[K` for in-place overwrite, but on at least one real
  # macOS Terminal + fish setup the counter rendered as 23 stacked lines
  # instead of one updating line. Most likely cause is awk-side stdio
  # buffering — BSD awk on macOS line-buffers stdout when it sees a TTY,
  # and a `printf` without `\n` doesn't trigger that flush, while
  # `fflush()` on a `>&2`-redirected fd isn't reliably reaching the
  # underlying terminal synchronously. bash's `printf` is a builtin —
  # writes go straight to fd2, which libc treats as unbuffered by default
  # — so the bytes hit the terminal in the order and timing the terminal
  # needs to interpret `\r` correctly.
  #
  # `2>&1` merges podman's stderr (progress lives there) and stdout (final
  # image digest) into the pipe. The brace block reads line-by-line. After
  # the pipe closes, `|| rc=${PIPESTATUS[0]}` captures podman's exit code
  # (PIPESTATUS[0], evaluated before any later command clobbers it; the
  # `||` keeps `set -e` from aborting on a non-zero pull). Note that the
  # brace block runs in a subshell (right side of a pipe), so `$n` doesn't
  # escape — that's why the seal `\n` is inside the brace, not after.
  #
  # Filtering (default quiet — pass everything in KONRAD_DEBUG=1):
  #   - `Copying blob sha256:` → counter (the show)
  #   - `Copying config sha256:`, `Trying to pull`, `Getting image source
  #     signatures`, `Writing manifest …`, `Storing signatures`, the bare
  #     64-hex final image-ID → swallowed
  #   - everything else → pass through (errors land here)
  local rc=0 verbose=0
  [[ "$KONRAD_DEBUG" == "1" ]] && verbose=1
  podman pull "$image_ref" 2>&1 | {
    n=0
    while IFS= read -r line; do
      case "$line" in
        "Copying blob sha256:"*)
          ((n+=1))
          if (( n > total )); then n=$total; fi
          if (( verbose )); then
            printf '  [%d/%d] %s\n' "$n" "$total" "$line" >&2
          else
            printf '\r  [%d/%d] %s\033[K' "$n" "$total" "$line" >&2
          fi
          ;;
        "Copying config sha256:"*|\
        "Trying to pull"*|\
        "Getting image source signatures"|\
        "Writing manifest to image destination"|\
        "Storing signatures")
          if (( verbose )); then printf '%s\n' "$line" >&2; fi
          ;;
        *)
          if [[ "$line" =~ ^[0-9a-f]{64}$ ]]; then
            if (( verbose )); then printf '%s\n' "$line" >&2; fi
          else
            printf '%s\n' "$line" >&2
          fi
          ;;
      esac
    done
    if (( n > 0 )) && (( verbose == 0 )); then printf '\n' >&2; fi
  } || rc=${PIPESTATUS[0]}
  return "$rc"
}

# --- Preflight checks ---

require_podman() {
  command -v podman >/dev/null 2>&1 \
    || die "podman is not installed."
  if ! podman info >/dev/null 2>&1; then
    cat >&2 <<'EOF'
konrad: cannot reach Podman.

On macOS this usually means the Podman VM isn't running. Start it with:

  podman machine init     # first time only
  podman machine start

Then re-run your command.
EOF
    exit 1
  fi
}

require_image() {
  if podman image exists "$IMAGE_NAME"; then
    return 0
  fi
  # Non-default tags don't auto-resolve — user must build/pull explicitly.
  # The only tag we know how to fetch is the registry's :latest.
  if [[ "$IMAGE_NAME" != "$IMAGE_DEFAULT" ]]; then
    if [[ "$(basename -- "$0")" == "konrad-dev" ]]; then
      die "image '$IMAGE_NAME' not found locally. Build the local dev image with 'konrad-dev --rebuild' or pull the published one with 'konrad --update'."
    else
      die "image '$IMAGE_NAME' not found locally. Pull the published image with 'konrad --update', or build/pull '$IMAGE_NAME' manually first."
    fi
  fi
  # konrad-dev shouldn't auto-pull the published image when its own
  # default (konrad:local) is missing — that would silently undo what
  # the dev was about to do with --rebuild.
  if [[ "$(basename -- "$0")" == "konrad-dev" ]]; then
    die "image '$IMAGE_NAME' not built yet. Run: konrad-dev --rebuild"
  fi
  # Default tag missing — try registry, fall back to local build.
  # Pull fetches a known-good image; local build recompiles every layer
  # and re-downloads model weights, so it's substantially slower. The
  # registry path is the default user experience.
  info "image '$IMAGE_NAME' not found locally — pulling ${REGISTRY_IMAGE}…"
  if pull_with_progress "$REGISTRY_IMAGE"; then
    podman tag "$REGISTRY_IMAGE" "$IMAGE_NAME"
    info "pulled and tagged as $IMAGE_NAME"
    return 0
  fi
  die "registry pull failed (offline? registry unreachable?). Once connectivity is back: konrad --update"
}

check_lm_studio() {
  if ! curl --max-time 2 -sf "$LM_STUDIO_HOST_URL" >/dev/null 2>&1; then
    info "LM Studio not detected at $LM_STUDIO_HOST_URL (ignore if you're using a different provider)"
  fi
}

# If the cwd is inside a git repo, make sure the auto-pruned subdirs of
# .agent/ are gitignored. .agent/task.md and .agent/artifacts/ stay
# tracked because the user may want to commit them. Idempotent —
# appends only the entries that aren't already there.
ensure_gitignore() {
  git -C "$(pwd -P)" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
  local gi
  gi="$(pwd -P)/.gitignore"

  # Decide what we still need to add by reading $gi up-front (before any
  # write), so we never read and write in the same pipeline.
  local have_quality_assurance=0 have_scratch=0
  if [[ -f "$gi" ]]; then
    grep -qE '^\.agent/quality-assurance/?$' "$gi" && have_quality_assurance=1
    grep -qE '^\.agent/scratch/?$' "$gi"           && have_scratch=1
  fi
  [[ "$have_quality_assurance" = 1 && "$have_scratch" = 1 ]] && return 0

  local needs_newline=""
  if [[ -s "$gi" ]]; then
    local last_byte
    last_byte=$(tail -c1 "$gi" 2>/dev/null || printf '')
    [[ -n "$last_byte" ]] && needs_newline=1
  fi
  {
    [[ -n "$needs_newline" ]] && printf '\n'
    printf '# konrad agent working state (auto-pruned >7d on every launch)\n'
    [[ "$have_quality_assurance" = 0 ]] && printf '.agent/quality-assurance/\n'
    [[ "$have_scratch"           = 0 ]] && printf '.agent/scratch/\n'
  } >> "$gi"
  info "added .agent/quality-assurance/ and .agent/scratch/ to $gi"
}

# Prune the central log dir of files older than 7 days. Runs host-side
# before every launch so disk doesn't grow without bound. Quiet on the
# common case; only mentions itself when it actually deletes something.
prune_log_dir() {
  [[ -d "$KONRAD_LOG_DIR" ]] || return 0
  # -delete prints nothing; count what's gone for the info message.
  local pruned
  pruned=$(find "$KONRAD_LOG_DIR" -maxdepth 1 -type f \
             \( -name '*.log' -o -name '*-session.txt' \) \
             -mtime +7 -print -delete 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$pruned" -gt 0 ]]; then
    info "pruned $pruned old log file(s) from $KONRAD_LOG_DIR"
  fi
}

# One-time migration: pre-org-layer konrad (≤0.3.x) kept the user's config
# flat at ~/.config/konrad/{opencode.jsonc,agents,skills,AGENTS.md,fonts}.
# The org config layer splits that dir into org/ and user/ sublayers, so the
# flat per-user files have to move into user/. Idempotent — runs only when
# user/ doesn't yet exist AND at least one flat item is present, so a fresh
# install (no flat files) and an already-migrated install both no-op. Host-
# side and live (bin/konrad isn't baked), so existing installs pick it up on
# their next launch without a rebuild.
migrate_flat_config() {
  [[ -d "$USER_CFG_DIR" ]] && return 0      # already on the new layout
  [[ -d "$KONRAD_CFG_DIR" ]] || return 0    # nothing here yet (fresh install)
  local -a flat_items=(opencode.jsonc agents skills AGENTS.md fonts)
  local item found=0
  for item in "${flat_items[@]}"; do
    [[ -e "$KONRAD_CFG_DIR/$item" ]] && { found=1; break; }
  done
  (( found )) || return 0                   # an empty/org-only dir — leave it
  mkdir -p "$USER_CFG_DIR"
  for item in "${flat_items[@]}"; do
    [[ -e "$KONRAD_CFG_DIR/$item" ]] && mv "$KONRAD_CFG_DIR/$item" "$USER_CFG_DIR/$item"
  done
  info "moved your config into $USER_CFG_DIR/ (org config layer — see README → Configuration)"
}

# --- Remote-daemon path translation (dev-container self-testing) ---
# Normally konrad's podman talks to a LOCAL daemon, so bind-mount SOURCE
# paths are read off the same filesystem as this script. The .devcontainer
# self-testing path (see CLAUDE.md) instead points podman at the HOST's
# rootless socket via CONTAINER_HOST, so the agent working ON konrad can
# exercise the runtime image. With a remote daemon, every `-v src:…` source
# is resolved against the HOST fs, not this container's — so the workspace
# the agent sees under /workspace has to be rewritten to its real host path.
# The dev container supplies the mapping in two env vars:
#   KONRAD_REMOTE_HOST_ROOT   host-fs path the guest workspace root maps to
#                             (its presence is what flips on remote mode)
#   KONRAD_REMOTE_GUEST_ROOT  the in-container prefix that maps to it (/workspace)
# Unset on every normal host install → no rewrite, paths used verbatim.
remote_host_path() {
  local p="$1"
  local host="${KONRAD_REMOTE_HOST_ROOT:-}" guest="${KONRAD_REMOTE_GUEST_ROOT:-/workspace}"
  if [[ -n "$host" && "$p" == "$guest"* ]]; then
    printf '%s%s' "$host" "${p#"$guest"}"
  else
    printf '%s' "$p"
  fi
}

# --- Egress firewall (sidecar filtering proxy) -------------------------------
# Topology (validated): two Podman networks per run —
#   <net-internal>  --internal (no route out): the agent's ONLY network.
#   <net-egress>    normal bridge: carries the proxy's outbound traffic.
# The proxy container joins BOTH; the agent joins only <net-internal> and is
# pointed at the proxy via HTTP(S)_PROXY. So the agent has no direct path to the
# internet — every request is filtered against the allow-list or refused. The
# boundary lives in Podman-managed networking the agent (uid 1000) can't alter.
#
# Why a forward proxy (HTTP_PROXY) and not something fancier: opencode runs on
# Bun, which honours HTTP_PROXY/HTTPS_PROXY for fetch — verified end-to-end that
# its model-catalog (HTTPS CONNECT) and local-model (HTTP) calls both route
# through tinyproxy. Keeps the agent capability-less and needs no nftables.

firewall_on() { [[ "$KONRAD_FIREWALL" == "1" ]]; }

# Names are per-run ($$) so concurrent konrad invocations don't collide; the
# konrad-fw- prefix makes orphans (after a kill -9) greppable for cleanup.
FW_ACTIVE=0
FW_NET_INTERNAL=""
FW_NET_EGRESS=""
FW_PROXY_NAME=""

# Remove this run's proxy + networks. Idempotent (EXIT trap may double-fire);
# every step is best-effort so teardown never masks the agent's exit code.
fw_teardown() {
  [[ "$FW_ACTIVE" == "1" ]] || return 0
  FW_ACTIVE=0
  dbg "firewall: tearing down proxy + networks"
  if [[ -n "$FW_PROXY_NAME" ]]; then
    podman rm -f "$FW_PROXY_NAME" >/dev/null 2>&1 || true
  fi
  if [[ -n "$FW_NET_INTERNAL" ]]; then
    podman network rm "$FW_NET_INTERNAL" >/dev/null 2>&1 || true
  fi
  if [[ -n "$FW_NET_EGRESS" ]]; then
    podman network rm "$FW_NET_EGRESS" >/dev/null 2>&1 || true
  fi
}

# Block until tinyproxy in container $1 is accepting connections (it logs the
# line on start); bail fast with the proxy's own logs if it died (bad config,
# image mismatch). Shared by the per-run CLI path and the persistent do_fw verb.
fw_wait_ready() {
  local proxy="$1" i
  for i in $(seq 1 100); do
    if podman logs "$proxy" 2>&1 | grep -q "Accepting connections"; then
      dbg "firewall: proxy ready"
      return 0
    fi
    if ! podman container exists "$proxy" 2>/dev/null; then
      podman logs "$proxy" 2>&1 | tail -20 >&2 || true
      die "egress firewall: proxy exited during startup (see logs above; --no-firewall to bypass)"
    fi
    sleep 0.1
  done
  podman logs "$proxy" 2>&1 | tail -20 >&2 || true
  die "egress firewall: proxy did not become ready (--no-firewall to bypass)"
}

# ── Shared firewall primitives (used by both fw_setup and do_fw) ─────────────
# Naming scheme for the persistent dev-container firewall (one set per project).
# Single source of the scheme so do_fw and init-devcontainer can't drift on it.
# Echoes "<internal-net> <egress-net> <proxy>" for a given id.
_fw_dc_names() {
  printf 'konrad-fw-net-dc-%s konrad-fw-out-dc-%s konrad-fw-proxy-dc-%s' "$1" "$1" "$1"
}

# Create the two firewall networks ($1 internal, $2 egress). Idempotent via an
# exists-guard (never rm's a possibly in-use network — important for the
# persistent dev-container path, where a reopen re-runs this against live nets).
_fw_create_networks() {
  local net_internal="$1" net_egress="$2"
  podman network exists "$net_internal" 2>/dev/null \
    || podman network create --internal "$net_internal" >/dev/null \
    || die "egress firewall: could not create internal network (--no-firewall to bypass)"
  podman network exists "$net_egress" 2>/dev/null \
    || podman network create "$net_egress" >/dev/null \
    || die "egress firewall: could not create egress network (--no-firewall to bypass)"
}

# Start the filtering proxy sidecar named $1 on networks $2,$3 with allow-list $4.
# Reuses the agent's userns map + config mounts from the KR_USERNS_FLAGS and
# KR_CFG_MOUNTS globals (bash 3.2 has no array passing) so the proxy composes the
# same baked<org<user config to derive the provider allow-list. Clears any
# same-named leftover first (crash/PID-reuse, or a dev-container reopen).
_fw_start_proxy() {
  local proxy="$1" net_internal="$2" net_egress="$3" allowed="$4"
  podman rm -f "$proxy" >/dev/null 2>&1 || true
  podman run -d --rm --name "$proxy" --init \
    --network "${net_internal},${net_egress}" \
    "${KR_USERNS_FLAGS[@]}" \
    ${KR_CFG_MOUNTS[@]+"${KR_CFG_MOUNTS[@]}"} \
    -e "KONRAD_DEBUG=${KONRAD_DEBUG}" \
    -e "KONRAD_PROXY_PORT=${KONRAD_PROXY_PORT}" \
    -e "KONRAD_ALLOWED_HOSTS=${allowed}" \
    "$IMAGE_NAME" konrad-proxy >/dev/null \
    || die "egress firewall: could not start proxy container (--no-firewall to bypass)"
}

# Remove every stray konrad-fw-* proxy + network. Belt-and-suspenders cleanup for
# orphans a hard-killed run or a stopped dev container left behind (the per-run
# EXIT trap and idempotent do_fw normally prevent these). Best-effort; quiet.
_fw_sweep() {
  command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1 || return 0
  local n
  while IFS= read -r n; do
    [[ -n "$n" ]] && { podman rm -f "$n" >/dev/null 2>&1 || true; }
  done < <(podman ps -a --filter 'name=konrad-fw-proxy' --format '{{.Names}}' 2>/dev/null)
  while IFS= read -r n; do
    [[ -n "$n" ]] && { podman network rm "$n" >/dev/null 2>&1 || true; }
  done < <(podman network ls --filter 'name=konrad-fw-' --format '{{.Name}}' 2>/dev/null)
}

# Populate the KR_CFG_MOUNTS global with the org/user config-layer `-v` flags the
# agent AND the proxy both need (each composes baked<org<user — the agent for
# opencode, the proxy to derive the provider allow-list). Single source of this
# logic, shared by podman_run and do_fw. Daemon-mode-aware: against a REMOTE
# daemon (dev-container self-testing) the `-v` SOURCE must be DAEMON-visible, so
# org/user resolve under KONRAD_REMOTE_HOST_CONFIG; against a LOCAL daemon (the
# normal host CLI and every consumer dev container) they bind straight off this
# filesystem. The -d guards stat the copy THIS process sees ($ORG_CFG_DIR/
# $USER_CFG_DIR), which the dev container also binds in, so "which layers exist"
# is decided the same way in both modes.
_build_cfg_mounts() {
  KR_CFG_MOUNTS=()
  if [[ -z "${KONRAD_REMOTE_HOST_ROOT:-}" ]]; then
    [[ -d "$ORG_CFG_DIR" ]]  && KR_CFG_MOUNTS+=(-v "$ORG_CFG_DIR:/home/node/.config/konrad/org:ro")
    [[ -d "$USER_CFG_DIR" ]] && KR_CFG_MOUNTS+=(-v "$USER_CFG_DIR:/home/node/.config/konrad/user:ro")
  else
    local host_cfg="${KONRAD_REMOTE_HOST_CONFIG:-}"
    if [[ -n "$host_cfg" ]]; then
      [[ -d "$ORG_CFG_DIR" ]]  && KR_CFG_MOUNTS+=(-v "$host_cfg/org:/home/node/.config/konrad/org:ro")
      [[ -d "$USER_CFG_DIR" ]] && KR_CFG_MOUNTS+=(-v "$host_cfg/user:/home/node/.config/konrad/user:ro")
    fi
  fi
}

# Create the networks and start the proxy sidecar. Reads two arrays the caller
# (podman_run) exports as globals — KR_USERNS_FLAGS and KR_CFG_MOUNTS — because
# the proxy needs the same userns mapping and the same org/user config mounts as
# the agent (it derives the provider allow-list from the merged config). Sets
# the FW_* globals and the EXIT trap so a partial setup is always cleaned up.
fw_setup() {
  FW_NET_INTERNAL="konrad-fw-net-$$"
  FW_NET_EGRESS="konrad-fw-out-$$"
  FW_PROXY_NAME="konrad-fw-proxy-$$"
  trap fw_teardown EXIT
  trap 'exit 143' TERM   # TERM → exit → EXIT trap → teardown (don't leak nets);
                          # SIGINT is left untrapped so the interactive TUI's
                          # Ctrl-C reaches podman, which exits cleanly and lets
                          # this function's caller fall through to teardown.

  dbg "firewall: creating networks $FW_NET_INTERNAL (internal) + $FW_NET_EGRESS"
  _fw_create_networks "$FW_NET_INTERNAL" "$FW_NET_EGRESS"
  FW_ACTIVE=1

  info "egress firewall: starting filtering proxy…"
  _fw_start_proxy "$FW_PROXY_NAME" "$FW_NET_INTERNAL" "$FW_NET_EGRESS" "$KONRAD_ALLOW_HOST"
  fw_wait_ready "$FW_PROXY_NAME"
}

# Run a command inside the konrad container with the standard mount set.
# All variables are quoted, so paths containing spaces are safe.
podman_run() {
  local cwd ws_src
  cwd="$(pwd -P)"
  ws_src="$(remote_host_path "$cwd")"   # rewritten only in remote mode

  # Profile-suffixed state + cache volumes (secrets stays shared — see
  # KONRAD_PROFILE above). No profile → the base names, unchanged.
  local state_vol="$STATE_VOLUME" cache_vol="$CACHE_VOLUME"
  if [[ -n "$KONRAD_PROFILE" ]]; then
    state_vol="${STATE_VOLUME}-${KONRAD_PROFILE}"
    cache_vol="${CACHE_VOLUME}-${KONRAD_PROFILE}"
  fi

  # TTY / stdin allocation. The interactive TUI and the --shell path want a
  # real terminal (-it). The non-interactive `konrad run` path never wants a
  # pseudo-tty (its answer should stream to stdout clean and capturable), and
  # it must be careful with stdin: `opencode run` treats a non-tty stdin as
  # PIPED input and reads it, so forwarding a live interactive terminal as a
  # non-tty fd (-i without -t) makes opencode block forever on a read that
  # never sees EOF. So in run mode we attach stdin ONLY when it's genuinely
  # piped/redirected (echo … | konrad run); from a terminal we pass neither
  # flag, podman leaves the container stdin closed, and opencode uses the
  # prompt arg. KONRAD_NONINTERACTIVE is set by do_run_oneshot before it
  # calls here.
  local -a tty_flags=(-it)
  if [[ "${KONRAD_NONINTERACTIVE:-0}" == "1" ]]; then
    if [[ -t 0 ]]; then tty_flags=(); else tty_flags=(-i); fi
  fi

  # Host-home bind mounts. The central log dir and the org/user config layers
  # live under $HOME. Against a LOCAL daemon they bind straight off this
  # filesystem. Against a REMOTE daemon (dev-container self-testing) the daemon
  # resolves every -v SOURCE on its OWN filesystem, so:
  #   - the log dir is skipped — no daemon-visible path for it; giving up
  #     host-side log capture is the one concession self-testing makes;
  #   - the config layers ARE mounted, from the host path the dev container
  #     exposes as KONRAD_REMOTE_HOST_CONFIG (the user's real ~/.config/konrad,
  #     which .devcontainer also binds into THIS container at $KONRAD_CFG_DIR so
  #     the -d guards below can see which layers exist). Net effect: self-testing
  #     composes baked < org < user exactly like an ordinary run — same model,
  #     AGENTS.md, skills, and providers — instead of running bare baked config.
  # The named volumes further down are daemon-side and work either way (so the
  # dev-container konrad still shares the host konrad's secrets/state).
  # The org/user config-layer mounts are built by _build_cfg_mounts into the
  # KR_CFG_MOUNTS global (daemon-mode-aware) — the SAME set the firewall proxy
  # needs (it composes the same baked<org<user config to derive the allow-list),
  # so sharing one builder keeps the two in lockstep. home_mounts is the agent's
  # superset: those config layers PLUS the central log dir (LOCAL daemon only —
  # no daemon-visible path for it under a remote daemon; giving up host-side log
  # capture is the one concession self-testing makes).
  local -a home_mounts=()
  if [[ -z "${KONRAD_REMOTE_HOST_ROOT:-}" ]]; then
    # Central log dir on the host (XDG state). Created lazily so the bind works
    # on the very first launch; the entrypoint writes a per-session sidecar here
    # and opencode writes its structured log alongside.
    mkdir -p "$KONRAD_LOG_DIR"
    home_mounts+=(-v "${KONRAD_LOG_DIR}:/home/node/.local/share/opencode/log:z")
  elif [[ "$cwd" != "${KONRAD_REMOTE_GUEST_ROOT:-/workspace}"* ]]; then
    warn "remote-socket mode: cwd ($cwd) is outside ${KONRAD_REMOTE_GUEST_ROOT:-/workspace}; the workspace mount resolves against the host fs and will likely be empty. Run konrad from under ${KONRAD_REMOTE_GUEST_ROOT:-/workspace}."
  fi
  _build_cfg_mounts
  home_mounts+=(${KR_CFG_MOUNTS[@]+"${KR_CFG_MOUNTS[@]}"})

  # User-namespace mapping. The normal case (local rootless daemon, and the
  # Linux remote-socket path) is keep-id: container node(1000) shares the
  # invoking user's uid, so workspace files have sane ownership. A ROOTFUL
  # remote daemon — the macOS dev-container self-testing path, flagged by
  # KONRAD_DAEMON_ROOTFUL from .devcontainer/podman-vscode.sh — needs the
  # explicit equivalent instead: rootful keep-id degrades to an identity map
  # while virtiofs presents the workspace with raw Mac ids, so node must be
  # mapped to the Mac user's uid/gid (KONRAD_REMOTE_UID/GID, injected by the
  # same shim). SELinux labeling is disabled there (Enforcing in the machine
  # VM) and the workspace `:z` relabel skipped (chcon fails on virtiofs).
  local ws_relabel=":z"
  local -a userns_flags=("$KONRAD_KEEPID_USERNS")
  if [[ "${KONRAD_DAEMON_ROOTFUL:-0}" == "1" ]]; then
    local ruid="${KONRAD_REMOTE_UID:?KONRAD_DAEMON_ROOTFUL=1 requires KONRAD_REMOTE_UID}"
    local rgid="${KONRAD_REMOTE_GID:?KONRAD_DAEMON_ROOTFUL=1 requires KONRAD_REMOTE_GID}"
    ws_relabel=""
    userns_flags=(
      --security-opt label=disable
      --uidmap 0:100000:999 --uidmap 999:0:1
      --uidmap "1000:${ruid}:1" --uidmap 1001:101001:64535
      --gidmap 0:100000:999 --gidmap 999:0:1
      --gidmap "1000:${rgid}:1" --gidmap 1001:101001:64535
    )
  fi

  # Egress firewall: stand up the sidecar + isolated network, then put the agent
  # on that network ONLY and point it at the proxy. The proxy reuses the agent's
  # userns map + config mounts (exported as globals for fw_setup, since bash 3.2
  # has no array passing). With the firewall off, the agent keeps Podman's default
  # networking and unrestricted egress — the pre-firewall behaviour.
  local -a net_flags=() proxy_env=()
  if firewall_on; then
    KR_USERNS_FLAGS=("${userns_flags[@]}")   # KR_CFG_MOUNTS already set by _build_cfg_mounts above
    fw_setup
    local proxy_url="http://${FW_PROXY_NAME}:${KONRAD_PROXY_PORT}"
    net_flags=(--network "$FW_NET_INTERNAL")
    # Bun's fetch (opencode) honours these; lower- and upper-case both, since
    # different tools read different spellings. localhost stays direct.
    proxy_env=(
      -e "HTTP_PROXY=${proxy_url}"  -e "HTTPS_PROXY=${proxy_url}"
      -e "http_proxy=${proxy_url}"  -e "https_proxy=${proxy_url}"
      -e "NO_PROXY=localhost,127.0.0.1"  -e "no_proxy=localhost,127.0.0.1"
    )
  fi

  # ${home_mounts[@]+"${home_mounts[@]}"} is the empty-safe array splice —
  # under `set -u`, a bare ${arr[@]} on an empty array would error.
  # --init: podman runs a tiny init (catatonit) as PID 1 inside the container
  # so signals (SIGINT, SIGTERM) reach opencode cleanly and any orphaned
  # children get reaped. Per Node Docker best-practices §5.
  # KONRAD_HOST_WORKSPACE is read by the entrypoint to write the
  # workspace path into the session sidecar (opencode itself only
  # sees /workspace and can't record the host path).
  local -a run_cmd=(
    podman run
    --rm ${tty_flags[@]+"${tty_flags[@]}"} --init
    "${userns_flags[@]}"
    ${net_flags[@]+"${net_flags[@]}"}
    ${proxy_env[@]+"${proxy_env[@]}"}
    -e "KONRAD_DEBUG=${KONRAD_DEBUG}"
    -e "KONRAD_TRACE_FETCH=${KONRAD_TRACE_FETCH:-0}"
    -e "KONRAD_HOST_WORKSPACE=${ws_src}"
    -e "KONRAD_HOST_LOG_DIR=${KONRAD_LOG_DIR}"
    -v "${ws_src}:/workspace${ws_relabel}"
    -v "${SECRETS_VOLUME}:/home/node/.opencode-secrets:U"
    -v "${cache_vol}:/home/node/.cache/opencode:U"
    -v "${state_vol}:/home/node/.local/state/opencode:U"
    ${home_mounts[@]+"${home_mounts[@]}"}
    -w /workspace
    "$IMAGE_NAME" "$@"
  )

  # No firewall → exec, replacing this shell so signals/exit code pass straight
  # through (the pre-firewall behaviour). With the firewall we must stay alive to
  # tear down the proxy + networks, so run in the foreground and exit with the
  # agent's code; the EXIT trap (set in fw_setup) does the cleanup either way.
  if firewall_on; then
    local rc=0
    "${run_cmd[@]}" || rc=$?
    exit "$rc"
  fi
  exec "${run_cmd[@]}"
}

# --- Actions ---

do_run() {
  local mode="$1"  # "agent" or "shell"
  dbg "do_run start (mode=$mode)"
  info "preflight checks…"
  require_podman; dbg "podman OK"
  require_image;  dbg "image OK"
  if [[ "$mode" == "agent" ]]; then
    check_lm_studio; dbg "lm-studio probe done"
  fi
  migrate_flat_config; dbg "flat-config migration checked"
  ensure_gitignore; dbg "gitignore ensured"
  prune_log_dir; dbg "log dir pruned"
  if [[ "$mode" == "shell" ]]; then
    info "launching container…"
    dbg "about to exec podman run (bash)"
    podman_run bash
  else
    info "launching container (this can take a few seconds on first run)…"
    dbg "about to exec podman run (opencode)"
    podman_run opencode
  fi
}

# Non-interactive one-shot: exec `opencode run <args…>` instead of the TUI.
# Same preflight + workspace side-effects as the agent path (it's still the
# agent against this workspace, just one prompt with the answer on stdout).
# Everything in "$@" is forwarded verbatim to `opencode run` — konrad doesn't
# enumerate opencode's flags, so --model / --agent / --session and anything
# opencode adds later ride straight through. Pair with --profile to keep a
# self-test off the user's real state. opencode's exit code propagates via exec.
do_run_oneshot() {
  dbg "do_run_oneshot start"
  info "preflight checks…"
  require_podman; dbg "podman OK"
  require_image;  dbg "image OK"
  check_lm_studio; dbg "lm-studio probe done"
  migrate_flat_config; dbg "flat-config migration checked"
  ensure_gitignore; dbg "gitignore ensured"
  prune_log_dir; dbg "log dir pruned"
  KONRAD_NONINTERACTIVE=1   # read by podman_run to drop the pseudo-tty
  info "running opencode (non-interactive)…"
  dbg "about to exec podman run (opencode run)"
  podman_run opencode run "$@"
}

# Compose the immutable dated tag (0.X.YYYY-MM-DD) from an image's version
# and created labels. The dated tag is the registry's rollback handle; we
# reconstruct it from labels so it's readable without a container run.
# SOURCE_DATE_EPOCH=0 reproducible builds used to stamp 1970 into the
# created label — guard against that (and against images predating the
# label) by falling back to the bare version.
image_dated_tag() {
  local ver="$1" date="${2%%T*}"
  if [[ "$ver" != "unknown" && "$date" == ????-??-?? && "$date" != "1970-01-01" ]]; then
    printf '%s-%s' "$ver" "$date"
  else
    printf '%s' "$ver"
  fi
}

do_version() {
  printf 'konrad %s\n' "$KONRAD_VERSION"
  printf '  CLI:    %s\n' "$KONRAD_VERSION"

  if ! command -v podman >/dev/null 2>&1 || ! podman info >/dev/null 2>&1; then
    printf '  image:  %s (cannot inspect — podman unavailable)\n' "$IMAGE_NAME"
    return 0
  fi
  if ! podman image exists "$IMAGE_NAME"; then
    local hint
    if [[ "$(basename -- "$0")" == "konrad-dev" ]]; then
      hint="not built — run: konrad-dev --rebuild"
    else
      hint="not pulled — run: konrad --update"
    fi
    printf '  image:  %s (%s)\n' "$IMAGE_NAME" "$hint"
    return 0
  fi

  local digest image_ver image_rev image_created image_tag
  digest="$(podman image inspect "$IMAGE_NAME" --format '{{.Id}}' 2>/dev/null \
            || printf 'unknown')"
  image_ver="$(podman image inspect "$IMAGE_NAME" \
               --format '{{index .Labels "org.opencontainers.image.version"}}' 2>/dev/null)"
  [[ -z "$image_ver" ]] && image_ver="unknown"
  image_rev="$(podman image inspect "$IMAGE_NAME" \
               --format '{{index .Labels "org.opencontainers.image.revision"}}' 2>/dev/null)"
  [[ -z "$image_rev" ]] && image_rev="unknown"
  image_created="$(podman image inspect "$IMAGE_NAME" \
                   --format '{{index .Labels "org.opencontainers.image.created"}}' 2>/dev/null)"
  image_tag="$(image_dated_tag "$image_ver" "$image_created")"

  local override_note=""
  [[ -n "${KONRAD_IMAGE:-}" ]] && override_note="  (KONRAD_IMAGE override)"
  printf '  image:  %s   (%s)%s\n' "$image_tag" "$IMAGE_NAME" "$override_note"
  printf '          %s · rev %s\n' "${digest:0:19}" "$image_rev"
  # No CLI-vs-image skew warning by design. CLI-only patches don't trigger
  # an image rebuild (the workflow's paths: filter excludes VERSION), so a
  # patch-line drift between CLI and image labels is normal and harmless —
  # the contract between them is thin (env vars + mount paths + `opencode`
  # entrypoint). For "is there anything new in the registry?", that's what
  # `konrad --check-updates` answers.
}

# Probe the registry (CLI source + image label) and report whether an update
# is available. Two network calls (gitlab raw + ghcr manifest+config), both
# capped at 5s via curl --max-time. Offline doesn't break the command — the
# verdict degrades to "couldn't reach …" and exit stays 0.
do_check_updates() {
  printf 'konrad — checking for updates…\n'
  printf '\n'

  local cli_remote=""
  if command -v curl >/dev/null 2>&1; then
    cli_remote="$(curl -fsS --max-time 5 \
                    'https://gitlab.git.nrw/jbauss2/konrad/-/raw/main/VERSION' 2>/dev/null \
                  | head -1 | tr -d '[:space:]')"
  fi

  local image_local_ver="" image_remote_ver=""
  if command -v podman >/dev/null 2>&1 \
     && podman info >/dev/null 2>&1 \
     && podman image exists "$IMAGE_NAME" 2>/dev/null; then
    image_local_ver="$(podman image inspect "$IMAGE_NAME" \
                         --format '{{index .Labels "org.opencontainers.image.version"}}' 2>/dev/null)"
  fi
  image_remote_ver="$(registry_image_version "$REGISTRY_IMAGE" 2>/dev/null || true)"

  printf '  CLI:    %s (local) → %s (registry)\n' \
    "$KONRAD_VERSION" "${cli_remote:-unreachable}"
  printf '  image:  %s (local) → %s (registry)\n' \
    "${image_local_ver:-not pulled}" "${image_remote_ver:-unreachable}"
  printf '\n'

  # "Drift" only counts as actionable when *both* sides of a comparison are
  # known (i.e. not "dev", not "unreachable", not "not pulled"). Anything
  # ambiguous → "partial check" verdict.
  local cli_drift=0 image_drift=0 cli_known=0 image_known=0
  if [[ -n "$cli_remote" && "$KONRAD_VERSION" != "dev" ]]; then
    cli_known=1
    [[ "$KONRAD_VERSION" != "$cli_remote" ]] && cli_drift=1
  fi
  if [[ -n "$image_remote_ver" && -n "$image_local_ver" ]]; then
    image_known=1
    [[ "$image_local_ver" != "$image_remote_ver" ]] && image_drift=1
  fi

  if (( cli_drift || image_drift )); then
    printf 'Update available — run: konrad --update\n'
    return 0
  fi
  if (( cli_known && image_known )); then
    printf 'Up to date.\n'
    # If CLI and image labels differ but both match the registry, the user
    # is current — just sitting on the by-design drift from CLI-only
    # patches. One line of context so it doesn't read as a problem.
    if [[ -n "$image_local_ver" && "$KONRAD_VERSION" != "dev" \
          && "$KONRAD_VERSION" != "$image_local_ver" ]]; then
      printf '  (CLI patches alone do not trigger an image rebuild — drift is by design.)\n'
    fi
    return 0
  fi
  printf "Couldn't reach all sources — partial check. Try again when online.\n"
}

do_pull_image() {
  # Internal verb: pull REGISTRY_IMAGE through the layer-counter wrapper and
  # tag it as IMAGE_DEFAULT. Owned here so the POSIX install-remote.sh and
  # bash do_update share one implementation of the bash-only pipeline
  # (jq + curl manifest preflight + awk counter). Not in --help — internal.
  if [[ "$(basename -- "$0")" == "konrad-dev" ]]; then
    die "konrad-dev doesn't pull from the registry. To rebuild the dev image: konrad-dev --rebuild."
  fi
  require_podman
  info "pulling ${REGISTRY_IMAGE}…"
  if ! pull_with_progress "$REGISTRY_IMAGE"; then
    die "registry pull failed (offline? registry unreachable?)"
  fi
  podman tag "$REGISTRY_IMAGE" "$IMAGE_DEFAULT"
}

# Re-read the KONRAD_VERSION_BAKED placeholder off disk after install-remote.sh
# has rewritten $0. The in-memory $KONRAD_VERSION is whatever this process
# started with (pre-refresh); on disk is the new value. Used by do_update's
# tail so the final --version block reflects what the user just installed.
reread_baked_version() {
  local v
  v="$(sed -n 's/^KONRAD_VERSION_BAKED="\(.*\)".*/\1/p' "$0" 2>/dev/null | head -1)"
  [[ -n "$v" ]] && KONRAD_VERSION="$v"
}

do_update() {
  # Hard gate: --update refreshes the published image and the stable CLI
  # itself. konrad-dev's image (konrad:local) comes from --rebuild, and
  # its CLI source comes from `git pull` in the checkout — neither path
  # touches what --update would touch.
  if [[ "$(basename -- "$0")" == "konrad-dev" ]]; then
    die "konrad-dev doesn't update. To rebuild the dev image: konrad-dev --rebuild. To refresh the stable konrad CLI next to it on PATH: konrad --update. To update this script: git pull inside the checkout the symlink points at."
  fi

  # 1. Pull the image (with the layer counter).
  do_pull_image

  # 2. Self-update the CLI. Skip for symlink installs — those track a
  #    checkout and update via `git pull` in the user's clone, not from
  #    the remote raw URL. The symlink check distinguishes:
  #      - regular file  → curl|sh install        → refresh via installer
  #      - symlink       → clone-symlink install  → leave alone
  if [[ -L "$0" ]]; then
    info "CLI is a symlink — update with 'git pull' inside the checkout it points at."
    printf '\n'
    do_check_updates
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    warn "neither curl nor wget available; CLI was not refreshed."
    printf '\n'
    do_check_updates
    return 0
  fi
  info "refreshing CLI…"
  local install_dir
  install_dir="$(dirname "$0")"
  # Env-var prefix on the *right* side of the pipe — `VAR=x curl … | sh` only
  # sets the var for curl, not for the `sh` consuming the pipe (env-prefix
  # applies to one command, not to the whole pipeline). The installer needs
  # KONRAD_NO_PULL (skip the second image pull) and KONRAD_INSTALL_DIR (land
  # at the same path) and KONRAD_QUIET_INSTALL (we already said "refreshing
  # CLI" — its play-by-play would be redundant on this path).
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$INSTALL_REMOTE_URL" \
      | KONRAD_NO_PULL=1 KONRAD_INSTALL_DIR="$install_dir" KONRAD_QUIET_INSTALL=1 sh
  else
    wget -qO- "$INSTALL_REMOTE_URL" \
      | KONRAD_NO_PULL=1 KONRAD_INSTALL_DIR="$install_dir" KONRAD_QUIET_INSTALL=1 sh
  fi

  # 3. Registry comparison from the freshly baked CLI. Re-reads the
  # KONRAD_VERSION_BAKED placeholder off disk so the CLI: line reflects
  # what install-remote.sh just wrote, then do_check_updates does the
  # local-vs-registry probe. We replace what used to be do_version here:
  # right after --update, the comparison view + "Up to date." verdict is
  # more useful than the standalone digest/rev forensics (still available
  # via `konrad --version`), and it directly answers the "why is image
  # older than CLI?" question that the version block alone leaves open.
  reread_baked_version
  printf '\n'
  do_check_updates
}

do_rebuild() {
  # Hard gate: --rebuild is konrad-dev's verb. A curl|sh-installed konrad
  # has no source to build from, and we want the dev image and stable
  # image to stay in separate worlds.
  if [[ "$(basename -- "$0")" != "konrad-dev" ]]; then
    cat >&2 <<'EOF'
konrad: --rebuild is only available from konrad-dev.

konrad-dev is the contributor binary — a symlink to bin/konrad from a
checkout of the konrad repo. To set it up:

  git clone https://gitlab.git.nrw/jbauss2/konrad.git
  cd konrad
  mkdir -p ~/.local/bin && ln -sfn "$(pwd)/bin/konrad" ~/.local/bin/konrad-dev
  konrad-dev --rebuild

Full contributor setup: CONTRIBUTING.md.

To just refresh the published image: konrad --update
EOF
    exit 1
  fi
  require_podman
  # konrad-dev should always have the source next to it (the symlink points
  # at a checkout's bin/konrad), but guard anyway — a sparse checkout or a
  # stale symlink would otherwise fail downstream with a confusing error.
  if [[ ! -f "$IMAGE_CONTEXT/Dockerfile" ]]; then
    die "konrad-dev: expected $IMAGE_CONTEXT/Dockerfile (is the symlink pointing at a complete checkout?)"
  fi
  # Delegate the three-stage build to scripts/build-image.sh — the single
  # source of truth for the local build (lock reading, git-sha/build-date
  # metadata, the cache-tagged intermediate stages, the build-args). It writes
  # $IMAGE_LOCAL_TAG (konrad:local), so the pulled image at $IMAGE_DEFAULT is
  # never clobbered. Safe to assume present: --rebuild only runs from a full
  # checkout (the Dockerfile guard above already proved that).
  info "building $IMAGE_LOCAL_TAG from $IMAGE_CONTEXT (konrad=$KONRAD_VERSION)"
  "$REPO_ROOT/scripts/build-image.sh" || die "image build failed"
  info "built $IMAGE_LOCAL_TAG — run with: konrad-dev"
}

# --- Persistent firewall verb (plumbing for the scaffolded dev container) -----
# `konrad fw up <id>` / `konrad fw down <id>`. Stands up (or tears down) a named,
# PERSISTENT egress firewall — the same isolated-network + filtering-proxy
# topology fw_setup builds per-run, but with stable names and no EXIT-trap
# teardown so it can outlive a single process. The scaffolded dev container's
# initializeCommand calls `up`; the container joins the internal network and
# points HTTP(S)_PROXY at the proxy (see do_init_devcontainer). Idempotent: a
# VS Code reopen re-runs `up` against the live resources without disrupting them.
do_fw() {
  local sub="${1:-}" id="${2:-}"
  case "$sub" in up|down) ;; *) die "usage: $(basename -- "$0") fw <up|down> <id>" ;; esac
  [[ "$id" =~ ^[A-Za-z0-9_-]+$ ]] || die "fw: id must be non-empty [A-Za-z0-9_-]+ (got '${id}')"
  require_podman
  local net_internal net_egress proxy
  read -r net_internal net_egress proxy <<<"$(_fw_dc_names "$id")"

  if [[ "$sub" == "down" ]]; then
    podman rm -f "$proxy" >/dev/null 2>&1 || true
    podman network rm "$net_internal" "$net_egress" >/dev/null 2>&1 || true
    info "firewall down ($id): removed proxy + networks"
    return 0
  fi

  # up: the proxy runs THIS image (so its config-merge / allow-list logic matches
  # the agent's image). For a pinned dev-container tag the image may not be local
  # yet — pull it through the same progress wrapper a normal pull uses.
  if ! podman image exists "$IMAGE_NAME" 2>/dev/null; then
    info "fw: image $IMAGE_NAME not present — pulling…"
    pull_with_progress "$IMAGE_NAME" || die "fw: could not pull $IMAGE_NAME (offline? wrong tag?)"
  fi

  # Same userns map + org/user config mounts the agent gets, via the shared
  # builders — so the proxy composes the identical baked<org<user config to
  # derive the allow-list. Consumer dev containers drive a local daemon;
  # _build_cfg_mounts also covers the remote-daemon case (konrad-dev self-test).
  KR_USERNS_FLAGS=("$KONRAD_KEEPID_USERNS")
  _build_cfg_mounts

  _fw_create_networks "$net_internal" "$net_egress"
  info "egress firewall: starting filtering proxy ($proxy)…"
  _fw_start_proxy "$proxy" "$net_internal" "$net_egress" "$KONRAD_ALLOW_HOST"
  fw_wait_ready "$proxy"
  info "firewall up ($id): agent network=$net_internal proxy=$proxy"
}

# --- Scaffold a Dev Container into the user's project -------------------------
# `konrad init-devcontainer` writes ./.devcontainer/devcontainer.json so the user
# can drive konrad from VS Code's UI instead of the terminal. The container IS the
# published konrad image, sealed on an isolated network with the same egress
# firewall the CLI uses (stood up host-side by `konrad fw up` in initializeCommand).
# Used exactly like the CLI — open a terminal in the container and run `opencode`.
# The template is generated from THIS script's own constants (volume names, mount
# paths, the keep-id flag, proxy port, fw-net naming) so there is a single source
# of truth; re-run after upgrading konrad to regenerate.
do_init_devcontainer() {
  local force=0 image_override=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force)     force=1; shift ;;
      --image-tag) [[ $# -ge 2 ]] || die "--image-tag requires a value (e.g. --image-tag ghcr.io/jlbauss/konrad:0.8.0)"
                   image_override="$2"; shift 2 ;;
      *)           die "init-devcontainer: unexpected argument '$1' (flags: --force, --image-tag <ref>)" ;;
    esac
  done

  local dc_dir dc_json
  dc_dir="$(pwd -P)/.devcontainer"
  dc_json="$dc_dir/devcontainer.json"
  if [[ -e "$dc_json" && "$force" != "1" ]]; then
    die "$dc_json already exists. Re-run with --force to overwrite."
  fi
  require_podman

  # Resolve the image ref to pin. We stamp the IMAGE's published version — NOT the
  # CLI's $KONRAD_VERSION — because CLI-only patches bump VERSION without firing an
  # image rebuild, so the CLI version can run ahead of any tag that exists in the
  # registry (e.g. CLI 0.9.0 while the newest image is :0.8.0). Prefer the local
  # image's label (what the user runs today), fall back to the registry's label,
  # then the CLI version. konrad-dev pins its local build; --image-tag overrides.
  local image_ref
  if [[ -n "$image_override" ]]; then
    image_ref="$image_override"
  elif [[ "$(basename -- "$0")" == "konrad-dev" ]]; then
    image_ref="$IMAGE_LOCAL_TAG"
  else
    local ver=""
    if podman image exists "$IMAGE_NAME" 2>/dev/null; then
      ver="$(podman image inspect "$IMAGE_NAME" \
              --format '{{index .Labels "org.opencontainers.image.version"}}' 2>/dev/null)"
    fi
    [[ -z "$ver" || "$ver" == "unknown" ]] && ver="$(registry_image_version "$REGISTRY_IMAGE" 2>/dev/null || true)"
    [[ -z "$ver" || "$ver" == "dev" ]] && ver="$KONRAD_VERSION"
    [[ -z "$ver" || "$ver" == "dev" ]] && \
      die "init-devcontainer: can't determine a published image tag to pin (no local image, registry unreachable, CLI version is 'dev'). Pull the image first with 'konrad --update', or pass --image-tag <ref>."
    image_ref="${REGISTRY_IMAGE%:*}:${ver}"
  fi

  # Stable per-project id → firewall resource names (deterministic from the abs
  # path so the same project always reuses the same names). cksum is POSIX and
  # everywhere; we only need stable + unique-ish, not cryptographic.
  local cwd dc_id net_internal net_egress proxy
  cwd="$(pwd -P)"
  dc_id="$(printf '%s' "$cwd" | cksum | cut -d' ' -f1)"   # stable digits; names get the konrad-fw-*-dc- prefix
  read -r net_internal net_egress proxy <<<"$(_fw_dc_names "$dc_id")"

  mkdir -p "$dc_dir"
  # Unquoted heredoc: $-vars from THIS script interpolate; VS Code's own
  # \${localWorkspaceFolder} / \${localEnv:HOME} / \$HOME are backslash-escaped so
  # they reach the file literally and expand per-machine. The file is committable
  # and machine-independent — so it calls bare `konrad` (PATH lookup on each host),
  # never this generator's absolute path.
  cat > "$dc_json" <<EOF
{
  // Generated by \`konrad init-devcontainer\`. Re-run to regenerate after an upgrade.
  //
  // Opens THIS project inside the konrad image and runs the agent exactly like the
  // host CLI: same sandbox, same default-on egress firewall. The firewall (an
  // isolated network + a filtering proxy sidecar) is stood up host-side by
  // 'konrad fw up' below, so the host needs konrad installed and on PATH.
  // Open a terminal in the container and run:  opencode
  "name": "konrad",
  "image": "${image_ref}",
  "remoteUser": "node",
  "containerUser": "node",
  "updateRemoteUserUID": false,
  "overrideCommand": true,
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=\${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  // Host-side, before the container starts: ensure the config dir exists (bind
  // source below), then stand up this project's firewall. KONRAD_IMAGE pins the
  // proxy to the same image as the container; 'fw up' pulls it if missing.
  "initializeCommand": "mkdir -p \$HOME/.config/konrad && KONRAD_IMAGE=${image_ref} konrad fw up ${dc_id}",
  // Compose baked<org<user config on every start by reusing konrad's own
  // entrypoint with a no-op command (it composes, links auth.json, then execs true).
  "postStartCommand": "konrad-entrypoint true",
  "runArgs": [
    "${KONRAD_KEEPID_USERNS}",
    "--network", "${net_internal}",
    "-v", "${SECRETS_VOLUME}:/home/node/.opencode-secrets:U",
    "-v", "${CACHE_VOLUME}:/home/node/.cache/opencode:U",
    "-v", "${STATE_VOLUME}:/home/node/.local/state/opencode:U"
  ],
  "mounts": [
    "source=\${localEnv:HOME}/.config/konrad,target=/home/node/.config/konrad,type=bind,readonly"
  ],
  "containerEnv": {
    "HTTP_PROXY": "http://${proxy}:${KONRAD_PROXY_PORT}",
    "HTTPS_PROXY": "http://${proxy}:${KONRAD_PROXY_PORT}",
    "http_proxy": "http://${proxy}:${KONRAD_PROXY_PORT}",
    "https_proxy": "http://${proxy}:${KONRAD_PROXY_PORT}",
    "NO_PROXY": "localhost,127.0.0.1",
    "no_proxy": "localhost,127.0.0.1"
  }
}
EOF

  info "wrote $dc_json"
  info "pinned image: $image_ref"
  cat >&2 <<EOF

Next steps:
  1. Ensure konrad is installed on this host and on PATH — the dev container's
     firewall is started by 'konrad fw up' before the container launches.
  2. In VS Code: "Dev Containers: Reopen in Container".
  3. Open a terminal in the container and run:  opencode

Provider credentials + model selection are shared with your host konrad (same
named volumes). Tear down this project's firewall manually with:
  konrad fw down ${dc_id}
EOF
}

do_reset() {
  # Two shapes. Without --profile: wipe the shared default state — log dir +
  # all three base volumes (the original, ALL-workspaces reset). With
  # --profile <name>: wipe only that profile's throwaway state + cache volumes,
  # and leave the shared secrets and the central log dir untouched (the secrets
  # volume is shared on purpose — see KONRAD_PROFILE — so a profile reset must
  # never delete the user's real credentials).
  if [[ -n "$KONRAD_PROFILE" ]]; then
    local p_state="${STATE_VOLUME}-${KONRAD_PROFILE}" p_cache="${CACHE_VOLUME}-${KONRAD_PROFILE}"
    cat >&2 <<EOF

==============================================================================
WARNING — --reset --profile $KONRAD_PROFILE will permanently delete:

  - the profile's throwaway volumes:
      • $p_state  (this profile's opencode session/model state)
      • $p_cache  (this profile's opencode cache)

Leaves alone: the shared $SECRETS_VOLUME (credentials), the central log dir,
and the default (profile-less) volumes. There is no undo.
==============================================================================

EOF
    printf 'konrad: proceed with profile reset? [y/N]: ' >&2
    local confirmation=""
    read -r confirmation || true
    case "$confirmation" in
      y|Y|yes|YES) ;;
      *) info "aborted; nothing was deleted."; exit 0 ;;
    esac
    if command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1; then
      for vol in "$p_state" "$p_cache"; do
        if podman volume exists "$vol" 2>/dev/null; then
          podman volume rm "$vol" >/dev/null
          info "removed profile volume $vol"
        fi
      done
    else
      warn "podman not reachable; profile volumes were NOT removed."
    fi
    info "profile '$KONRAD_PROFILE' reset complete."
    return 0
  fi

  cat >&2 <<EOF

==============================================================================
WARNING — --reset will permanently delete:

  - the central log dir:
      $KONRAD_LOG_DIR
  - the shared volumes:
      • $SECRETS_VOLUME  (your provider credentials — you'll need to /connect again)
      • $CACHE_VOLUME    (opencode's cache)
      • $STATE_VOLUME    (opencode's UI state and model selection)

This affects ALL workspaces, not just the current one. There is no undo.
==============================================================================

EOF
  printf 'konrad: proceed with reset? [y/N]: ' >&2
  local confirmation=""
  read -r confirmation || true
  case "$confirmation" in
    y|Y|yes|YES) ;;
    *) info "aborted; nothing was deleted."; exit 0 ;;
  esac

  if [[ -d "$KONRAD_LOG_DIR" ]]; then
    rm -rf "$KONRAD_LOG_DIR"
    info "removed $KONRAD_LOG_DIR"
  fi
  if command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1; then
    for vol in "$SECRETS_VOLUME" "$CACHE_VOLUME" "$STATE_VOLUME"; do
      if podman volume exists "$vol" 2>/dev/null; then
        podman volume rm "$vol" >/dev/null
        info "removed shared volume $vol"
      fi
    done
  else
    warn "podman not reachable; shared volumes were NOT removed."
  fi
  _fw_sweep   # remove any orphaned konrad-fw-* proxies/networks (dev-container leftovers)
  info "reset complete. Next run will need a fresh /connect, repopulate caches, and re-pick a model."
}

do_uninstall() {
  # Removes this binary's installation (the CLI on PATH + its dedicated
  # image, plus build-cache images for konrad-dev). Shared state — user
  # config, volumes, log dir — is intentionally left alone; that's
  # --reset's job. Composes: --reset first to wipe shared state, then
  # --uninstall on each binary you've installed.
  local self other_name other_path target_image cache_note
  self="$(basename -- "$0")"
  if [[ "$self" == "konrad-dev" ]]; then
    other_name="konrad"
    target_image="$IMAGE_LOCAL_TAG"
    cache_note="
  - intermediate build-cache images:
      • konrad-python-base:cache
      • konrad-python-models:cache"
  else
    other_name="konrad-dev"
    target_image="konrad:latest"
    cache_note=""
  fi
  other_path="$(command -v "$other_name" 2>/dev/null || true)"

  cat >&2 <<EOF

==============================================================================
WARNING — $self --uninstall will remove:

  - the CLI binary at: $0
  - the image:         $target_image$cache_note

This does NOT remove (your call):
  - your config:    $KONRAD_CFG_DIR/   (org/ + user/ layers)
  - shared volumes: $SECRETS_VOLUME, $CACHE_VOLUME, $STATE_VOLUME
  - log dir:        $KONRAD_LOG_DIR/

(Use --reset first to wipe the shared state; rm -rf the config dir
if you want that gone too.)
==============================================================================

EOF
  printf 'konrad: proceed with uninstall? [y/N]: ' >&2
  local confirmation=""
  read -r confirmation || true
  case "$confirmation" in
    y|Y|yes|YES) ;;
    *) info "aborted; nothing was removed."; exit 0 ;;
  esac

  # Remove images first (podman). Quiet if missing.
  if command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1; then
    if podman image exists "$target_image" 2>/dev/null; then
      podman image rm "$target_image" >/dev/null
      info "removed image $target_image"
    fi
    if [[ "$self" == "konrad-dev" ]]; then
      local img
      for img in konrad-python-base:cache konrad-python-models:cache; do
        if podman image exists "$img" 2>/dev/null; then
          podman image rm "$img" >/dev/null
          info "removed image $img"
        fi
      done
    fi
  else
    warn "podman not reachable; image(s) were NOT removed. Delete manually with: podman image rm $target_image"
  fi
  _fw_sweep   # remove any orphaned konrad-fw-* proxies/networks (dev-container leftovers)

  # Delete the binary last. Bash has already mmap'd this script, so the
  # remainder of execution is safe. For konrad-dev, $0 is a symlink — rm
  # removes the symlink only, not the checkout it points at.
  if rm -f "$0" 2>/dev/null; then
    info "removed $0"
  else
    warn "failed to remove $0 (permissions?); delete manually."
  fi

  if [[ -n "$other_path" ]]; then
    info "$other_name is still installed at $other_path — uninstall separately with: $other_name --uninstall"
  fi
  info "$self uninstalled."
}

do_help() {
  # Help branches on basename so each binary only lists the flags that make
  # sense for its world. konrad has --update; konrad-dev has --rebuild.
  local self refresh_flag variant_blurb cross_pointer
  self="$(basename -- "$0")"
  if [[ "$self" == "konrad-dev" ]]; then
    refresh_flag="  --rebuild             Rebuild the local dev image from image/ (writes konrad:local)."
    variant_blurb="konrad-dev — contributor variant. Defaults to konrad:local (your local build),
so anything you're testing stays out of the way of the stable konrad next to it on PATH."
    cross_pointer="Your stable user CLI 'konrad' is unaffected by anything here. It lives next to
this binary on PATH and pulls konrad:latest from ghcr.io ('konrad --update' to refresh)."
  else
    refresh_flag="  --update              Pull the latest image AND refresh the CLI itself.
  --check-updates       Compare local vs registry; print 'up to date' or 'update available'."
    variant_blurb="konrad — sandboxed opencode in a Podman container."
    cross_pointer="Working on konrad itself? Install the contributor variant 'konrad-dev'
alongside this stable CLI — see CONTRIBUTING.md."
  fi

  cat <<EOF
$variant_blurb

Default ($self, no args): launch the interactive opencode TUI against the
current directory. Pass a flag, or the 'run' subcommand, to do something else.

Subcommands:
  $self run <args…>    Non-interactive: exec 'opencode run <args…>' instead of
                        the TUI — one prompt, answer on stdout (pipeable). Args
                        after 'run' pass straight to opencode, so:
                          $self run "summarize this repo"
                          $self run --model <slug> "fix the failing test"
                        Put konrad's own flags (below) BEFORE 'run'.
  $self init-devcontainer   Scaffold ./.devcontainer/ into the current project so
                        you can run konrad from VS Code's UI with the same sandbox
                        + egress firewall as the CLI. --force overwrites; pin a
                        specific image with --image-tag <ref>. Then "Reopen in
                        Container" and run 'opencode' in the terminal.

Flags:
  -s, --shell           Open a bash shell in the container instead.
  --profile <name>      Use throwaway state + cache volumes suffixed with <name>
                        (konrad-state-<name> / konrad-cache-<name>) instead of
                        the shared ones; credentials stay shared. Isolates a
                        self-test / experiment from your real session + model.
  --no-firewall         Disable the egress firewall for this run (default ON).
                        Normally the agent reaches only the allow-list (your
                        providers + a small trusted set) via a sidecar proxy;
                        this restores unrestricted network access.
  --allow-host <host>   Add a host to the egress allow-list for this run
                        (repeatable, or comma-separated). For a permanent entry,
                        list it in ~/.config/konrad/user/allowed_hosts.
  -v, --verbose         Per-phase timestamps + opencode log-file pointer.
                        (Raw HTTP trace is separate: KONRAD_TRACE_FETCH=1 …)
  --version             Print CLI + image versions (dated tag, digest, revision).
$refresh_flag
  --reset               Wipe shared volumes + log dir. Prompts [y/N].
                        With --profile <name>: wipe only that profile's
                        state + cache volumes (leaves credentials + log dir).
  --uninstall           Remove this binary's CLI + image. Prompts [y/N].
                        Leaves shared state alone — use --reset for that.
  -h, --help            Show this message.

$cross_pointer

Override which image runs:
  KONRAD_IMAGE=konrad:pr-42 $self    Test a published PR image.
  KONRAD_IMAGE=konrad:my-tag $self   Run a custom-tagged image you built or pulled.

Files in the workspace (.agent/ belongs to the agent end-to-end):
  .agent/task.md        Current task's plan + outcome (committable).
  .agent/artifacts/     Durable mid-task outputs (committable).
  .agent/scratch/       Agent-written scripts / exploration (auto-pruned >7d).
  .agent/quality-assurance/<stamp>/    Quality-assurance evidence on a fail (auto-pruned >7d).

Files on the host (outside the workspace):
  $KONRAD_LOG_DIR
                        opencode logs + per-session sidecars.
                        Pruned >7d on every launch. \`tail -f\` to read.

Files in ~/.config/konrad/user/ (all optional — your personal layer):
  opencode.jsonc        Deep-merged with konrad's baked defaults at start.
  agents/               Your own opencode primary agents, layered in.
  skills/               Your own opencode skills, layered in.
  AGENTS.md             Personal instructions, loaded on top of base.
  fonts/                .ttf / .otf / .ttc dropped here are loaded into
                        fontconfig on top of konrad's baked palette.
An organization can ship the same five things in ~/.config/konrad/org/;
they merge under your user layer (precedence: baked < org < user). See
README → Configuration → "For organizations".

Occasional maintenance (one-liners, not built into the CLI):
  Edit your override:   \$EDITOR ~/.config/konrad/user/opencode.jsonc
  Build-manifest dump:  podman run --rm --entrypoint cat $IMAGE_DEFAULT \\
                          /etc/konrad/build-manifest.json | jq .
EOF
}

# --- Flag parser + dispatch ---

# Test seam: when this file is *sourced* with KONRAD_SOURCE_ONLY=1 (the smoke
# test does this to exercise migrate_flat_config in isolation), stop before the
# flag parser + dispatch so nothing runs. `return` is valid only in a sourced
# context; in normal execution the condition is false, so it's never reached.
[[ "${KONRAD_SOURCE_ONLY:-0}" == "1" ]] && return 0

SHELL_MODE=0
ACTION="run"
RUN_ARGS=()
INIT_ARGS=()
FW_ARGS=()

# Each flag is its own token. Short flags bundle (-sv == -s -v). Long flags
# stand alone. The action flags (--version / --update / --rebuild / --reset
# / --help) are mutually exclusive; last one wins if multiple are passed.
# konrad's own flags come BEFORE the optional `run` verb; once `run` is seen,
# the rest of the line is captured verbatim for `opencode run` and parsing stops.
while [[ $# -gt 0 ]]; do
  case "$1" in
    run)          ACTION="run-oneshot"; shift; RUN_ARGS=("$@"); break ;;
    init-devcontainer) ACTION="init-devcontainer"; shift; INIT_ARGS=("$@"); break ;;
    fw)           ACTION="fw"; shift; FW_ARGS=("$@"); break ;;
    --shell)      SHELL_MODE=1;     shift ;;
    --profile)
      [[ $# -ge 2 ]] || die "--profile requires a name (e.g. --profile selftest)"
      [[ "$2" =~ ^[A-Za-z0-9_-]+$ ]] \
        || die "invalid profile name '$2' (allowed: letters, digits, '-', '_')"
      KONRAD_PROFILE="$2"; shift 2 ;;
    --no-firewall) KONRAD_FIREWALL=0; shift ;;
    --allow-host)
      [[ $# -ge 2 ]] || die "--allow-host requires a host (e.g. --allow-host github.com)"
      KONRAD_ALLOW_HOST="${KONRAD_ALLOW_HOST:+$KONRAD_ALLOW_HOST,}$2"; shift 2 ;;
    --verbose)    KONRAD_DEBUG=1;   shift ;;
    --version)    ACTION="version"; shift ;;
    --update)     ACTION="update";  shift ;;
    --check-updates) ACTION="check-updates"; shift ;;
    --pull-image) ACTION="pull-image"; shift ;;
    --rebuild)    ACTION="rebuild"; shift ;;
    --reset)      ACTION="reset";   shift ;;
    --uninstall)  ACTION="uninstall"; shift ;;
    --help)       ACTION="help";    shift ;;
    --)           shift; break ;;
    --*)          die "unknown flag: $1 (try: $(basename -- "$0") --help)" ;;
    -*)
      # Short-flag bundle: explode -sv into -s -v.
      flags="${1#-}"
      shift
      for (( i=0; i<${#flags}; i++ )); do
        char="${flags:$i:1}"
        case "$char" in
          s) SHELL_MODE=1   ;;
          v) KONRAD_DEBUG=1 ;;
          h) ACTION="help"  ;;
          *) die "unknown short flag: -$char (try: $(basename -- "$0") --help)" ;;
        esac
      done
      ;;
    *)            die "unexpected argument: $1 (try: $(basename -- "$0") --help)" ;;
  esac
done

case "$ACTION" in
  run)
    if [[ "$SHELL_MODE" == "1" ]]; then
      do_run shell
    else
      do_run agent
    fi
    ;;
  run-oneshot)   do_run_oneshot ${RUN_ARGS[@]+"${RUN_ARGS[@]}"} ;;
  init-devcontainer) do_init_devcontainer ${INIT_ARGS[@]+"${INIT_ARGS[@]}"} ;;
  fw)            do_fw ${FW_ARGS[@]+"${FW_ARGS[@]}"} ;;
  version)       do_version       ;;
  update)        do_update        ;;
  check-updates) do_check_updates ;;
  pull-image)    do_pull_image    ;;
  rebuild)    do_rebuild    ;;
  reset)     do_reset     ;;
  uninstall) do_uninstall ;;
  help)      do_help      ;;
esac
