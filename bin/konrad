#!/usr/bin/env bash
# konrad — sandboxed opencode in a Podman container.
#
# Usage:
#   konrad             Run opencode against the current directory.
#   konrad shell       Open a bash shell inside the container.
#   konrad rebuild     Rebuild the konrad image from the repo's Dockerfile.
#   konrad clean       Remove this project's .agent/opencode/ state.
#   konrad clean --all Also remove the shared volumes (auth, cache, npm).
#   konrad help        Show this message.
set -euo pipefail

IMAGE_NAME="konrad:latest"
LM_STUDIO_HOST_URL="http://localhost:1234/v1/models"

# Shared (cross-project) named volumes.
SECRETS_VOLUME="konrad-secrets"
CACHE_VOLUME="konrad-cache"
NPM_GLOBAL_VOLUME="konrad-npm-global"

# --- Resolve the script's source directory, even when symlinked ---
# Lets `konrad rebuild` find image/Dockerfile no matter where bin/konrad
# is symlinked from.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SRC_DIR_TMP="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SRC_DIR_TMP/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
IMAGE_CONTEXT="$REPO_ROOT/image"

# --- Helpers ---

die()  { echo "konrad: $*" >&2; exit 1; }
info() { echo "konrad: $*" >&2; }

require_podman() {
  command -v podman >/dev/null 2>&1 \
    || die "podman is not installed."
  if ! podman info >/dev/null 2>&1; then
    cat >&2 <<'EOF'
konrad: cannot reach Podman.

On macOS this usually means the Podman VM isn't running. Start it with:

  podman machine init     # first time only
  podman machine start

Then re-run your command.
EOF
    exit 1
  fi
}

require_image() {
  if ! podman image exists "$IMAGE_NAME"; then
    info "image '$IMAGE_NAME' not found locally — building it now (one-time, ~5 min)."
    cmd_rebuild
  fi
}

check_lm_studio() {
  if ! curl --max-time 2 -sf "$LM_STUDIO_HOST_URL" >/dev/null 2>&1; then
    info "warning: LM Studio not reachable at $LM_STUDIO_HOST_URL"
    info "         Start LM Studio and load qwen/qwen3.6-35b-a3b before giving the agent work."
  fi
}

# If the cwd is inside a git repo, make sure .agent/opencode/ is
# gitignored. Idempotent — appends only if not already present.
ensure_gitignore() {
  git -C "$(pwd -P)" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
  local gi="$(pwd -P)/.gitignore"
  if [[ -f "$gi" ]] && grep -qE '^\.agent/opencode/?$' "$gi"; then
    return 0
  fi
  {
    [[ -s "$gi" ]] && [[ -n "$(tail -c1 "$gi" 2>/dev/null)" ]] && echo
    echo "# konrad operational state (sessions, sqlite) — keep out of git"
    echo ".agent/opencode/"
  } >> "$gi"
  info "added '.agent/opencode/' to $gi"
}

# Run a command inside the konrad container with the standard mount set.
# All variables are quoted, so paths containing spaces are safe.
podman_run() {
  local cwd agent_dir
  cwd="$(pwd -P)"
  agent_dir="$cwd/.agent/opencode"
  mkdir -p "$agent_dir"
  exec podman run \
    --rm -it \
    --userns=keep-id:uid=1000,gid=1000 \
    -v "${cwd}:/workspace" \
    -v "${agent_dir}:/home/node/.local/share/opencode" \
    -v "${SECRETS_VOLUME}:/home/node/.opencode-secrets:U" \
    -v "${CACHE_VOLUME}:/home/node/.cache/opencode:U" \
    -v "${NPM_GLOBAL_VOLUME}:/home/node/.npm-global:U" \
    -w /workspace \
    "$IMAGE_NAME" "$@"
}

# --- Subcommands ---

cmd_run() {
  require_podman
  require_image
  check_lm_studio
  ensure_gitignore
  podman_run opencode
}

cmd_shell() {
  require_podman
  require_image
  ensure_gitignore
  podman_run bash
}

cmd_rebuild() {
  require_podman
  [[ -f "$IMAGE_CONTEXT/Dockerfile" ]] \
    || die "expected Dockerfile at $IMAGE_CONTEXT/Dockerfile (is the konrad repo intact?)"
  info "building $IMAGE_NAME from $IMAGE_CONTEXT"
  podman build -t "$IMAGE_NAME" "$IMAGE_CONTEXT"
}

cmd_clean() {
  require_podman
  local agent_dir="$(pwd -P)/.agent/opencode"

  if [[ -d "$agent_dir" ]]; then
    rm -rf "$agent_dir"
    info "removed $agent_dir"
  else
    info "no project state at $agent_dir"
  fi

  if [[ "${1:-}" == "--all" ]]; then
    for vol in "$SECRETS_VOLUME" "$CACHE_VOLUME" "$NPM_GLOBAL_VOLUME"; do
      if podman volume exists "$vol" 2>/dev/null; then
        podman volume rm "$vol" >/dev/null
        info "removed shared volume $vol"
      fi
    done
    info "next run will need a fresh /connect and will repopulate caches"
  fi
}

cmd_help() {
  sed -n '2,10p' "$0" | sed 's/^# \{0,1\}//'
}

# --- Dispatch ---

case "${1:-run}" in
  run|"")              cmd_run ;;
  shell)               cmd_shell ;;
  rebuild)             cmd_rebuild ;;
  clean)               shift; cmd_clean "$@" ;;
  help|-h|--help)      cmd_help ;;
  *)                   die "unknown command: $1 (try: konrad help)" ;;
esac
