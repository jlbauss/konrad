#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 Jan-Luca Bauß
# SPDX-License-Identifier: AGPL-3.0-or-later
# konrad — sandboxed opencode in a Podman container. See `konrad --help`.
set -euo pipefail

# Image tags. Two distinct surfaces:
#   konrad:latest  — what `konrad update` writes (= the published image
#                    from ghcr.io). The default when this script is
#                    invoked as `konrad`.
#   konrad:local   — what `konrad-dev rebuild` writes (= your local
#                    build, for working ON konrad itself). The default
#                    when this script is invoked as `konrad-dev` (the
#                    contributor symlink — see CONTRIBUTING.md).
#
# Same script, two binaries on PATH. The invocation name decides which
# image tag is the default — `konrad` runs the published image,
# `konrad-dev` runs your dev build. Neither touches the other, so a
# contributor can keep both side by side. KONRAD_IMAGE still overrides
# either path for ad-hoc tags (`KONRAD_IMAGE=konrad:pr-42 konrad`).
#
# KONRAD_IMAGE does NOT redirect what update/rebuild produce; those
# always write to their fixed tags.
# Invocation name, resolved once. `konrad` vs `konrad-dev` (the contributor
# symlink) decides the default image tag and gates the dev-only verbs; is_dev()
# is the single predicate every such check goes through.
SELF="$(basename -- "$0")"
is_dev() { [[ "$SELF" == "konrad-dev" ]]; }

IMAGE_LOCAL_TAG="konrad:local"
if is_dev; then IMAGE_DEFAULT="$IMAGE_LOCAL_TAG"; else IMAGE_DEFAULT="konrad:latest"; fi
IMAGE_NAME="${KONRAD_IMAGE:-$IMAGE_DEFAULT}"

# Registry coordinates — where CI publishes the prebuilt image and where
# `konrad update` pulls from. `:latest` always points at the newest
# build that passed the smoke gate (see .github/workflows/build-image.yml).
# CI runs on a GitHub mirror of this repo even though the primary repo
# lives on gitlab.git.nrw — see the README's "Pinning strategy" section.
REGISTRY_IMAGE="ghcr.io/jlbauss/konrad:latest"

# URL of the curl|sh installer. `konrad update` re-runs it after the
# image pull so the CLI itself stays fresh; standalone installs don't
# otherwise auto-update.
INSTALL_URL="https://gitlab.git.nrw/jbauss2/konrad/-/raw/main/scripts/install.sh"

# Shared (cross-project) named volumes.
SECRETS_VOLUME="konrad-secrets"
CACHE_VOLUME="konrad-cache"
STATE_VOLUME="konrad-state"

# Where the three stores above live when the engine is apple/container. Podman
# uses real named volumes (chowned to the runtime user via the :U mount option);
# apple/container can't chown a named volume and has no :U, and a fresh named
# volume there is root-owned — so node (uid 1000) can't write it. A host-dir
# bind sidesteps that: VirtioFS remaps the owner to the container user (the same
# reason the /workspace bind is writable). So on that engine each store is a
# subdir here, bind-mounted; Podman ignores this entirely. See eng_volume_*.
KONRAD_STORE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}/konrad/store"

# Volume profile (--profile <name>). When set, the state + cache volumes are
# suffixed (konrad-state → konrad-state-<name>, konrad-cache → konrad-cache-<name>)
# so a named profile gets throwaway opencode state — its own session DB, model
# selection, and caches — without touching the user's real ones. The canonical
# use is `--profile selftest` for end-to-end self-test runs: a live run against
# the real konrad-state otherwise triggers opencode's one-time DB migration on
# it and persists a model/session the user didn't pick (hit 2026-06-03 during
# dev-container self-testing). SECRETS is deliberately NOT suffixed — it stays
# shared so a profile reuses the user's real provider credentials (auth.json);
# an isolated secrets volume would start empty and have no API key to resolve a
# model. Empty (no --profile) → the unsuffixed volumes above, unchanged.
KONRAD_PROFILE=""

# Where konrad keeps host-side config. Two symmetric sublayers live under it:
#   org/   — an organization's shipped defaults (dropped in by a provisioning
#            package; see docs/examples/org-package/). Merged ABOVE the baked
#            image defaults but BELOW the user's own layer.
#   user/  — the individual user's overrides.
# Merge precedence is baked < org < user (last writer wins). Pre-org-layer
# konrad kept the user layer flat at $KONRAD_CFG_DIR/*; migrate_flat_config()
# relocates it into user/ on first run of this version.
KONRAD_CFG_DIR="${HOME}/.config/konrad"
ORG_CFG_DIR="$KONRAD_CFG_DIR/org"
USER_CFG_DIR="$KONRAD_CFG_DIR/user"
# Read-only reference material — NOT a config layer (no opencode merge). A
# sibling of org/user holding named subdirs the agent greps at /context/<name>;
# see the context mount below and ARCHITECTURE → State, secrets & isolation.
CONTEXT_CFG_DIR="$KONRAD_CFG_DIR/context"

# Central log directory on the host (XDG state). Holds opencode's
# structured log files plus a per-session sidecar that records the host
# workspace path. Shared across all projects so logs live in one
# discoverable place; pruned (>7d) before every launch.
KONRAD_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/konrad/log"

# --- Resolve the script's source directory, even when symlinked ---
# Lets `konrad-dev rebuild` find image/Dockerfile no matter where
# bin/konrad is symlinked from.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SRC_DIR_TMP="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SRC_DIR_TMP/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
IMAGE_CONTEXT="$REPO_ROOT/image"

# CLI version. Three sources, in priority order:
#   1. $REPO_ROOT/VERSION       — present when installed from a clone
#                                  (the konrad-dev symlink path documented
#                                  in CONTRIBUTING.md).
#   2. $KONRAD_VERSION_BAKED    — rewritten by scripts/install.sh
#                                  at install time (curl|sh path), so
#                                  standalone installs still report the
#                                  real version instead of "dev".
#   3. "dev"                     — last-ditch fallback.
KONRAD_VERSION_BAKED=""  # rewritten by scripts/install.sh
if [[ -f "$REPO_ROOT/VERSION" ]]; then
  KONRAD_VERSION="$(cat "$REPO_ROOT/VERSION")"
elif [[ -n "$KONRAD_VERSION_BAKED" ]]; then
  KONRAD_VERSION="$KONRAD_VERSION_BAKED"
else
  KONRAD_VERSION="dev"
fi

# --- Output helpers (all go to stderr; stdout is reserved for tool output) ---
# Color + icons are gated on an interactive stderr (a TTY) with NO_COLOR unset,
# so piped / CI / `konrad run` output stays plain. The UTF-8 glyphs are safe —
# host and image both run a UTF-8 locale. The container entrypoint mirrors this
# block (it's a separate process in a separate file; not worth a shared lib for
# six lines), so a konrad launch reads as one continuous styled sequence.
if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then
  _C_BRAND=$'\033[1;36m'; _C_OK=$'\033[32m'; _C_GO=$'\033[36m'
  _C_WARN=$'\033[33m';    _C_ERR=$'\033[31m'; _C_DIM=$'\033[2m'; _C_OFF=$'\033[0m'
else
  _C_BRAND=''; _C_OK=''; _C_GO=''; _C_WARN=''; _C_ERR=''; _C_DIM=''; _C_OFF=''
fi

# Launch sequence: a "starting konrad" header carrying the CLI + image versions
# (so every run shows what it's actually running — the image version is the OCI
# label, read once), then indented phase lines — ✓ for a completed setup phase,
# → for the handoff to opencode/shell.
brand() {
  local img_ver
  img_ver="$(eng_image_label "$IMAGE_NAME" "org.opencontainers.image.version")"
  [[ -n "$img_ver" ]] || img_ver="?"
  printf '%sstarting konrad%s  %scli %s · image %s%s\n' \
    "$_C_BRAND" "$_C_OFF" "$_C_DIM" "$KONRAD_VERSION" "$img_ver" "$_C_OFF" >&2
}
step()  { printf '  %s✓%s  %s\n' "$_C_OK"  "$_C_OFF" "$*" >&2; }
go()    { printf '  %s→%s  %s\n' "$_C_GO"  "$_C_OFF" "$*" >&2; }

# General messages (non-launch): a dim "konrad" prefix, with a colored tag on
# warnings/errors.
info() { printf '%skonrad%s %s\n'        "$_C_DIM" "$_C_OFF" "$*" >&2; }
warn() { printf '%skonrad%s %swarning:%s %s\n' "$_C_DIM" "$_C_OFF" "$_C_WARN" "$_C_OFF" "$*" >&2; }
die()  { printf '%skonrad%s %serror:%s %s\n'   "$_C_DIM" "$_C_OFF" "$_C_ERR" "$_C_OFF" "$*" >&2; exit 1; }

# Debug mode: KONRAD_DEBUG=1 turns on per-phase timestamps (host + container)
# and points at opencode's structured file log. Off by default — flip with
# -v/--verbose or by exporting KONRAD_DEBUG=1 in the environment.
KONRAD_DEBUG="${KONRAD_DEBUG:-0}"
# Raw HTTP trace: a separate, noisier opt-in than -v. KONRAD_TRACE_FETCH=1
# makes the container dump every Bun fetch (full headers) to stderr — for
# hunting network stalls the file log can't surface. Deliberately NOT bundled
# into -v (it buries everything else; see image/entrypoint.sh). Passed through
# to the container via -e; off by default.
KONRAD_TRACE_FETCH="${KONRAD_TRACE_FETCH:-0}"

# Egress firewall (ON by default). The agent container runs on an isolated
# Podman network with NO route to the internet; a sidecar — the same konrad
# image launched as `konrad-proxy` — is the only member with egress and forwards
# only the allow-listed hosts (derived providers + a baked infra floor + the
# user's allowed_hosts). Shrinks the blast radius of a prompt-injected agent
# exfiltrating secrets/workspace data. See image/konrad-proxy-entrypoint.sh and
# fw_setup() below. Disable per-run with --no-firewall (or KONRAD_FIREWALL=0).
# Add one-off allowed hosts with --allow-host h1,h2 (or KONRAD_ALLOW_HOST=…).
KONRAD_FIREWALL="${KONRAD_FIREWALL:-1}"
KONRAD_PROXY_PORT="${KONRAD_PROXY_PORT:-8888}"
KONRAD_ALLOW_HOST="${KONRAD_ALLOW_HOST:-}"

# Resource limits for the agent container (RAM + CPU). Left empty here on purpose:
# when unset, podman_run derives a proportional default from the host's own totals
# (half the RAM, clamped to [2G, 32G]; all cores but two reserved for the host, min
# 2 — see default_memory / default_cpus), so a small laptop and a big workstation
# each get a ceiling that fits. The cap does double duty across both engines: Apple's `container` defaults
# to a tiny 1G VM — too small for the bundled docling models, which OOM-kill
# mid-run — so the default lifts that floor, while on otherwise-uncapped Podman it
# bounds runaway/fork-bomb usage. Both CLIs accept --memory/--cpus with the same
# spelling, so one computation serves both — no eng_* wrapper needed. Override per
# run by setting the env vars to an explicit value (e.g. KONRAD_MEMORY=8G for heavy
# OCR), or to 0 to drop that cap entirely (restores Podman's unbounded behaviour).
# The CPU cap also becomes the container's OMP_NUM_THREADS (see podman_run), so
# docling/torch actually use the granted cores instead of self-throttling to 4.
KONRAD_MEMORY="${KONRAD_MEMORY:-}"
KONRAD_CPUS="${KONRAD_CPUS:-}"

# Container engine. Konrad runs on Podman everywhere, with one exception: on
# Apple-Silicon macOS where Apple's `container` CLI (apple/container, macOS 26+)
# is installed, that native engine is preferred — it drops the `podman machine`
# VM entirely. Empty here → detect_engine() picks one at startup. Pin explicitly
# with KONRAD_ENGINE=podman (stay on Podman on a Mac) or =container (force it).
# The dev container is Linux, so it always resolves to podman — working ON konrad
# stays on Podman. Every engine call below routes through an eng_* wrapper, since
# the two CLIs are NOT subcommand-compatible (`container image pull` vs
# `podman pull`, `container delete` vs `podman rm`, JSON-only inspect, no
# `--userns`, no `:z`/`:U`/`:ro` mount suffixes).
KONRAD_ENGINE="${KONRAD_ENGINE:-}"
# opencode's loopback port for the remote-MCP OAuth callback. `konrad mcp-auth`
# publishes it to the host so the post-approval redirect reaches the sandbox.
# ponytail: opencode uses a fixed port today; env-overridable if that changes.
KONRAD_MCP_AUTH_PORT="${KONRAD_MCP_AUTH_PORT:-19876}"

# $SECONDS is bash's built-in script-elapsed counter (portable to bash 3.2
# on macOS). The container side uses GNU `date +%N` for sub-second precision
# since Linux has that. Both are good enough to spot what's slow.
dbg() {
  [[ "$KONRAD_DEBUG" != "1" ]] && return 0
  printf 'konrad [debug +%ss]: %s\n' "$SECONDS" "$*" >&2
}

# --- Registry probes (manifest preflight for update --check) ----------------
#
# `update --check` reads the registry's image-version label without pulling:
# anon token → platform-specific manifest → config blob →
# `org.opencontainers.image.version`, compared against the locally-installed
# image to tell the user whether a pull would change anything. Registry-agnostic
# in shape, but the token endpoint is ghcr.io-specific today (the only registry
# konrad pulls from). jq + curl are soft-deps — missing either → silent skip.
#
# Pulls themselves no longer wrap a custom progress counter: each engine renders
# its own native pull progress (Podman's per-layer bars on Linux, Apple's
# `container` UX on macOS), which beats piping podman through an aggregator that
# suppressed those bars. The pull goes straight through eng_pull().

# Split `<registry>/<repo>:<tag>` into three space-separated tokens on stdout.
# Defaults `tag` to `latest`. Repo may contain slashes; tokens won't.
_parse_image_ref() {
  local image_ref="$1" tag repo_part
  case "$image_ref" in
    *:*) tag="${image_ref##*:}"; repo_part="${image_ref%:*}" ;;
    *)   tag="latest";            repo_part="$image_ref"      ;;
  esac
  printf '%s %s %s' "${repo_part%%/*}" "${repo_part#*/}" "$tag"
}

# Detect the target arch for podman pull. Podman's VM matches host arch on
# both macOS and Linux, so `uname -m` on the host is the right answer.
_pull_arch() {
  case "$(uname -m)" in
    x86_64|amd64)  printf 'amd64' ;;
    aarch64|arm64) printf 'arm64' ;;
    *)             printf 'amd64' ;;
  esac
}

# Fetch an anonymous pull-scoped bearer token for the given registry/repo.
# Echoes the token or returns silently empty. ghcr.io only today.
_registry_anon_token() {
  local registry="$1" repo="$2" url
  case "$registry" in
    ghcr.io) url="https://ghcr.io/token?service=ghcr.io&scope=repository:${repo}:pull" ;;
    *)       return 0 ;;
  esac
  curl -fsS --max-time 5 "$url" 2>/dev/null \
    | jq -r '.token // .access_token // empty' 2>/dev/null
}

# Fetch the platform-specific image manifest JSON for ${registry}/${repo}:${tag}.
# Echoes the JSON on stdout, or nothing on failure. Handles both single-
# manifest and multi-arch manifest-list / OCI-index shapes.
_registry_platform_manifest() {
  local registry="$1" repo="$2" tag="$3" token="$4"
  local arch accept manifest media_type platform_digest
  arch="$(_pull_arch)"
  accept='application/vnd.docker.distribution.manifest.list.v2+json,application/vnd.oci.image.index.v1+json,application/vnd.docker.distribution.manifest.v2+json,application/vnd.oci.image.manifest.v1+json'
  manifest="$(curl -fsS --max-time 5 \
                -H "Authorization: Bearer $token" \
                -H "Accept: $accept" \
                "https://${registry}/v2/${repo}/manifests/${tag}" 2>/dev/null)"
  [[ -z "$manifest" ]] && return 0
  media_type="$(printf '%s' "$manifest" | jq -r '.mediaType // empty' 2>/dev/null)"
  case "$media_type" in
    *manifest.list*|*image.index*)
      platform_digest="$(printf '%s' "$manifest" \
        | jq -r --arg a "$arch" '
            .manifests[]
            | select(.platform.architecture == $a
                     and (.platform.os == "linux" or .platform.os == null))
            | .digest' 2>/dev/null | head -1)"
      [[ -z "$platform_digest" ]] && return 0
      curl -fsS --max-time 5 \
        -H "Authorization: Bearer $token" \
        -H "Accept: $accept" \
        "https://${registry}/v2/${repo}/manifests/${platform_digest}" 2>/dev/null
      ;;
    *)
      printf '%s' "$manifest"
      ;;
  esac
}

# Fetch the `org.opencontainers.image.version` label from the registry's
# platform-specific image config blob. Three HTTP calls (token, manifest,
# config blob). Prints the label on stdout, or nothing on failure.
# Always returns 0.
registry_image_version() {
  command -v jq   >/dev/null 2>&1 || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local registry repo tag token pm config_digest
  read -r registry repo tag <<<"$(_parse_image_ref "$1")"
  token="$(_registry_anon_token "$registry" "$repo")"
  [[ -z "$token" ]] && return 0
  pm="$(_registry_platform_manifest "$registry" "$repo" "$tag" "$token")"
  [[ -z "$pm" ]] && return 0
  config_digest="$(printf '%s' "$pm" | jq -r '.config.digest // empty' 2>/dev/null)"
  [[ -z "$config_digest" || "$config_digest" == "null" ]] && return 0
  # -L follows redirects: GHCR (and most OCI registries) serve blobs by
  # returning a 307 redirect to a CDN-signed URL. Manifest endpoints don't
  # redirect, but `-L` is harmless there.
  curl -fsSL --max-time 5 \
    -H "Authorization: Bearer $token" \
    "https://${registry}/v2/${repo}/blobs/${config_digest}" 2>/dev/null \
    | jq -r '.config.Labels["org.opencontainers.image.version"] // empty' 2>/dev/null
  return 0
}

# --- Container engine abstraction -------------------------------------------
# One selector ($KONRAD_ENGINE) and a set of eng_* wrappers. detect_engine()
# fixes the choice once at startup; every host-side engine call goes through a
# wrapper so the Podman ⇄ apple/container CLI differences live in exactly one
# place. The run/network/volume verbs map cleanly; the cosmetic bits that don't
# (image-label introspection on apple/container, which is JSON-only and not
# contract-stable) degrade gracefully rather than failing the command.

# Pick the engine. Podman unless we're on Apple Silicon macOS with the
# `container` CLI present, where the native engine wins (no podman-machine VM).
# An explicit KONRAD_ENGINE always overrides. Idempotent.
detect_engine() {
  if [[ -n "$KONRAD_ENGINE" ]]; then
    case "$KONRAD_ENGINE" in
      podman|container) return 0 ;;
      *) die "KONRAD_ENGINE must be 'podman' or 'container' (got '$KONRAD_ENGINE')." ;;
    esac
  fi
  if [[ "$(uname -s)" == "Darwin" && "$(uname -m)" == "arm64" ]] \
     && command -v container >/dev/null 2>&1; then
    KONRAD_ENGINE="container"
  else
    KONRAD_ENGINE="podman"
  fi
}

# True when the selected engine's service is reachable.
eng_running() {
  case "$KONRAD_ENGINE" in
    podman)    podman info >/dev/null 2>&1 ;;
    container) container system status >/dev/null 2>&1 ;;
  esac
}

# Does an image exist locally? (exit status only)
eng_image_exists() {
  case "$KONRAD_ENGINE" in
    podman)    podman image exists "$1" ;;
    container) container image inspect "$1" >/dev/null 2>&1 ;;
  esac
}

# Pull / retag / remove an image.
eng_pull() {
  case "$KONRAD_ENGINE" in
    # podman resolves a multi-arch index to the host platform on its own
    # (its VM is host-arch), so no --platform needed. Apple's `container`
    # does NOT: an unqualified pull unpacks *every* platform in the index
    # (you'd watch it unpack amd64 then arm64 on Apple Silicon — wasted
    # bandwidth + disk for layers that never run). Pin it to the host arch.
    podman)    podman pull "$1" ;;
    container) container image pull --platform "linux/$(_pull_arch)" "$1" ;;
  esac
}
eng_tag() {
  case "$KONRAD_ENGINE" in
    podman)    podman tag "$1" "$2" ;;
    container) container image tag "$1" "$2" ;;
  esac
}
eng_image_rm() {
  case "$KONRAD_ENGINE" in
    podman)    podman image rm "$1" >/dev/null ;;
    container) container image delete "$1" >/dev/null ;;
  esac
}

# Read an OCI image label. Podman has a Go-template formatter; apple/container
# emits JSON only, so we dig the label out with jq — best-effort, since the
# exact inspect JSON path isn't version-stable. A miss returns empty, which
# callers already render as "unknown". Always exits 0 so callers can capture.
eng_image_label() {
  local ref="$1" key="$2"
  case "$KONRAD_ENGINE" in
    podman)
      podman image inspect "$ref" \
        --format "{{index .Labels \"$key\"}}" 2>/dev/null
      ;;
    container)
      command -v jq >/dev/null 2>&1 || return 0
      container image inspect "$ref" 2>/dev/null \
        | jq -r --arg k "$key" '
            [ .. | objects | (.labels? // .Labels? // empty)
              | objects | .[$k]? ]
            | map(select(. != null and . != "")) | first // empty' 2>/dev/null
      ;;
  esac
  return 0
}

# Container lifecycle: force-remove, logs, existence. Force-remove and rm are
# best-effort (teardown must never mask the agent's exit code).
eng_rm_container() {
  case "$KONRAD_ENGINE" in
    podman)    podman rm -f "$1" >/dev/null 2>&1 || true ;;
    container) container delete --force "$1" >/dev/null 2>&1 || true ;;
  esac
}
eng_logs() {  # stdout+stderr of the container, merged
  case "$KONRAD_ENGINE" in
    podman)    podman logs "$1" 2>&1 ;;
    container) container logs "$1" 2>&1 ;;
  esac
}
eng_container_exists() {
  case "$KONRAD_ENGINE" in
    podman)    podman container exists "$1" ;;
    container) container inspect "$1" >/dev/null 2>&1 ;;
  esac
}

# Networks. The internal (no-egress) net carries --internal on both engines.
eng_network_create_internal() {
  case "$KONRAD_ENGINE" in
    podman)    podman network create --internal "$1" >/dev/null ;;
    container) container network create --internal "$1" >/dev/null ;;
  esac
}
eng_network_create() {
  case "$KONRAD_ENGINE" in
    podman)    podman network create "$1" >/dev/null ;;
    container) container network create "$1" >/dev/null ;;
  esac
}
eng_network_rm() {  # variadic, best-effort
  case "$KONRAD_ENGINE" in
    podman)    podman network rm "$@" >/dev/null 2>&1 || true ;;
    container) container network delete "$@" >/dev/null 2>&1 || true ;;
  esac
}

# Named-store backing. On Podman these are real named volumes; on apple/container
# they're host directories under KONRAD_STORE_HOME (see there for why). The three
# wrappers below all branch on that — keep them in lockstep.

# Print the `-v` SOURCE for store $1 and, on apple/container, ensure its host dir
# exists. Deterministic by name, so the agent and the proxy resolve the shared
# secrets store to the identical path.
eng_volume_source() {
  if [[ "$KONRAD_ENGINE" == "podman" ]]; then
    printf '%s' "$1"
    return 0
  fi
  mkdir -p "${KONRAD_STORE_HOME}/$1"
  printf '%s' "${KONRAD_STORE_HOME}/$1"
}
eng_volume_exists() {
  if [[ "$KONRAD_ENGINE" == "podman" ]]; then
    podman volume exists "$1"
  else
    [[ -d "${KONRAD_STORE_HOME}/$1" ]]
  fi
}
eng_volume_rm() {
  if [[ "$KONRAD_ENGINE" == "podman" ]]; then
    podman volume rm "$1" >/dev/null
  else
    rm -rf "${KONRAD_STORE_HOME:?}/$1"
  fi
}

# Set the global RO_BIND array to the engine-correct argv for a READ-ONLY bind
# of host $1 → guest $2. Podman takes the :ro suffix on -v; apple/container's -v
# has no :ro suffix, so it needs the --mount form with the readonly option (a
# global array because bash 3.2 has no namerefs). Callers splice
# "${RO_BIND[@]}" into their run argv. (A literal comma in a source path would
# break the --mount key=value syntax — none of konrad's mount sources have one.)
RO_BIND=()
ro_bind() {
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    RO_BIND=(--mount "type=bind,source=$1,target=$2,readonly")
  else
    RO_BIND=(-v "$1:$2:ro")
  fi
}

# Print container $1's IPv4 address on network $2 (empty on failure). Podman
# resolves a sidecar by hostname over its internal DNS even on an --internal
# net, so callers never need this for Podman; on apple/container DNS is dead on
# --internal, so the agent must be handed the proxy's literal IP. The two
# documented JSON shapes disagree (`container inspect` → .networks[].address as
# CIDR; `container ls --format json` → .status.networks[].ipv4Address), so we
# recurse for any object whose .network/.name matches $2 and take whichever
# address field is present, stripping a /prefix. Robust to either shape.
eng_container_ip() {
  local name="$1" net="$2"
  command -v jq >/dev/null 2>&1 || return 1
  container inspect "$name" 2>/dev/null \
    | jq -r --arg net "$net" '
        [ .. | objects
          | select((.network? // .name?) == $net)
          | (.ipv4Address? // .address? // empty) ]
        | map(select(. != null and . != "")) | first // empty' 2>/dev/null \
    | sed 's#/.*##'
}

# Print network $1's IPv4 gateway, /prefix stripped (empty on failure). This is
# apple/container's vmnet gateway for the net — and on a "host-only" (--internal)
# or the egress `default` net that gateway IS the Mac host. Two consumers, both
# apple/container-only: the agent's host-gateway SEAL (the internal net's gateway,
# blackholed in the entrypoint) and the proxy's local-model route (the egress
# net's gateway, mapped to host.containers.internal in the proxy's /etc/hosts).
# Podman needs neither — its --internal net exposes no host route, and it injects
# host.containers.internal into the proxy itself. Defensive jq like
# eng_container_ip(): the inspect JSON path isn't contract-stable, so we recurse
# for any object carrying a gateway field rather than hard-coding a path.
eng_network_gateway() {
  local net="$1"
  command -v jq >/dev/null 2>&1 || return 1
  # Observed shape (apple/container 0.x): .status.ipv4Gateway = "192.168.133.1".
  # We recurse for any of the plausible field spellings rather than pinning the
  # path, so a future inspect-schema tweak degrades gracefully (empty → callers
  # fail closed / warn) instead of silently reading the wrong field.
  container network inspect "$net" 2>/dev/null \
    | jq -r '
        [ .. | objects | (.ipv4Gateway? // .gateway? // .Gateway? // empty) ]
        | map(select(type == "string" and . != "")) | first // empty' 2>/dev/null \
    | sed 's#/.*##'
}

# --- Preflight checks ---

# Print the install hint for a missing engine and exit. Mirrors the wording the
# installer prints (scripts/install.sh) so the runtime and install paths
# stay consistent; the README's Requirements section is the canonical home.
engine_missing() {
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    cat >&2 <<'EOF'
konrad: Apple's 'container' CLI is not installed.

Install it from https://github.com/apple/container/releases, then:
  container system start

Or set KONRAD_ENGINE=podman to use Podman instead.
EOF
  else
    cat >&2 <<'EOF'
konrad: Podman is not installed.

  macOS:  brew install podman && podman machine init && podman machine start
  Linux:  https://podman.io/docs/installation

See the README's Requirements section.
EOF
  fi
  exit 1
}

# Best-effort: bring a stopped engine up ourselves, so a not-running engine is a
# self-healing pause instead of a wall. Returns 0 if the engine is reachable
# afterwards, 1 if we couldn't start it (caller then prints manual guidance).
# Only does what's safe + fast + idempotent: it never `machine init`s (that
# downloads a multi-hundred-MB VM image — an opt-in the user should make), so a
# never-initialized Podman, and native-Linux Podman (no machine to start), both
# fall through to the guidance.
eng_try_start() {
  case "$KONRAD_ENGINE" in
    container)
      info "starting Apple's container service…"
      container system start >/dev/null 2>&1 || return 1
      ;;
    podman)
      [[ "$(uname -s)" == "Darwin" ]] || return 1   # no machine on Linux
      podman machine inspect >/dev/null 2>&1 || return 1   # not initialized → can't start
      info "starting the Podman machine…"
      podman machine start >/dev/null 2>&1 || return 1
      ;;
  esac
  eng_running
}

# Engine-aware reachability check, used by both the runtime verbs and the build
# (do_rebuild). The image now builds on whichever engine is selected — Podman via
# buildah, apple/container via its BuildKit `container build` — so the same check
# covers both; there's no longer a Podman-only build path needing its own guard.
require_engine() {
  command -v "$KONRAD_ENGINE" >/dev/null 2>&1 || engine_missing
  eng_running && return 0
  # Not reachable — try to bring it up ourselves before asking the user to.
  if eng_try_start; then
    dbg "engine $KONRAD_ENGINE started automatically"
    return 0
  fi
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    cat >&2 <<'EOF'
konrad: couldn't start Apple's container service automatically.

Try starting it by hand:

  container system start

(First time: install it from https://github.com/apple/container/releases.)
Or set KONRAD_ENGINE=podman to use Podman instead. Then re-run your command.
EOF
  else
    cat >&2 <<'EOF'
konrad: couldn't reach Podman (and couldn't start it automatically).

On macOS the Podman VM may not be initialized yet. Set it up with:

  podman machine init     # first time only (downloads a VM image)
  podman machine start

On Linux, check the Podman service. Then re-run your command.
EOF
  fi
  exit 1
}

require_image() {
  if eng_image_exists "$IMAGE_NAME"; then
    return 0
  fi
  # Non-default tags don't auto-resolve — user must build/pull explicitly.
  # The only tag we know how to fetch is the registry's :latest.
  if [[ "$IMAGE_NAME" != "$IMAGE_DEFAULT" ]]; then
    if is_dev; then
      die "image '$IMAGE_NAME' not found locally. Build the local dev image with 'konrad-dev rebuild' or pull the published one with 'konrad update'."
    else
      die "image '$IMAGE_NAME' not found locally. Pull the published image with 'konrad update', or build/pull '$IMAGE_NAME' manually first."
    fi
  fi
  # konrad-dev shouldn't auto-pull the published image when its own
  # default (konrad:local) is missing — that would silently undo what
  # the dev was about to do with rebuild.
  if is_dev; then
    die "image '$IMAGE_NAME' not built yet. Run: konrad-dev rebuild"
  fi
  # Default tag missing — try registry, fall back to local build.
  # Pull fetches a known-good image; local build recompiles every layer
  # and re-downloads model weights, so it's substantially slower. The
  # registry path is the default user experience.
  info "image '$IMAGE_NAME' not found locally — pulling ${REGISTRY_IMAGE}…"
  if eng_pull "$REGISTRY_IMAGE"; then
    eng_tag "$REGISTRY_IMAGE" "$IMAGE_NAME"
    info "pulled and tagged as $IMAGE_NAME"
    return 0
  fi
  die "registry pull failed (offline? registry unreachable?). Once connectivity is back: konrad update"
}

# Prune the central log dir of files older than 7 days. Runs host-side
# before every launch so disk doesn't grow without bound. Silent (the count
# goes to -v only) — it's housekeeping in konrad's own state dir, not the
# user's workspace.
prune_log_dir() {
  [[ -d "$KONRAD_LOG_DIR" ]] || return 0
  local pruned
  pruned=$(find "$KONRAD_LOG_DIR" -maxdepth 1 -type f \
             \( -name '*.log' -o -name '*-session.txt' \) \
             -mtime +7 -print -delete 2>/dev/null | wc -l | tr -d ' ')
  [[ "$pruned" -gt 0 ]] && dbg "pruned $pruned old log file(s) from $KONRAD_LOG_DIR"
  return 0
}

# --- Remote-daemon path translation (dev-container self-testing) ---
# Normally konrad's podman talks to a LOCAL daemon, so bind-mount SOURCE
# paths are read off the same filesystem as this script. The .devcontainer
# self-testing path (see CLAUDE.md) instead points podman at the HOST's
# rootless socket via CONTAINER_HOST, so the agent working ON konrad can
# exercise the runtime image. With a remote daemon, every `-v src:…` source
# is resolved against the HOST fs, not this container's — so the workspace
# the agent sees under /workspace has to be rewritten to its real host path.
# The dev container supplies the mapping in two env vars:
#   KONRAD_REMOTE_HOST_ROOT   host-fs path the guest workspace root maps to
#                             (its presence is what flips on remote mode)
#   KONRAD_REMOTE_GUEST_ROOT  the in-container prefix that maps to it (/workspace)
# Unset on every normal host install → no rewrite, paths used verbatim.
remote_host_path() {
  local p="$1"
  local host="${KONRAD_REMOTE_HOST_ROOT:-}" guest="${KONRAD_REMOTE_GUEST_ROOT:-/workspace}"
  if [[ -n "$host" && "$p" == "$guest"* ]]; then
    printf '%s%s' "$host" "${p#"$guest"}"
  else
    printf '%s' "$p"
  fi
}

# --- Egress firewall (sidecar filtering proxy) -------------------------------
# Topology (validated on Podman AND apple/container): two networks per run —
#   <net-internal>  --internal (no route out): the agent's ONLY network.
#   <net-egress>    normal bridge: carries the proxy's outbound traffic.
# The proxy container joins BOTH; the agent joins only <net-internal> and is
# pointed at the proxy via HTTP(S)_PROXY. So the agent has no direct path to the
# internet — every request is filtered against the allow-list or refused. The
# boundary lives in engine-managed networking the agent (uid 1000) can't alter.
# Engine deltas (proven 2026-06: live test on macOS 26 / Apple Silicon):
#   - the agent reaches the proxy by IP, not hostname (DNS is dead on an
#     --internal net under apple/container) — see fw_proxy_url();
#   - the proxy attaches to both nets via repeated --network (multi-attach),
#     which Podman accepts too, so one code path serves both engines.
#
# Why a forward proxy (HTTP_PROXY) and not something fancier: opencode runs on
# Bun, which honours HTTP_PROXY/HTTPS_PROXY for fetch — verified end-to-end that
# its model-catalog (HTTPS CONNECT) and local-model (HTTP) calls both route
# through tinyproxy. Keeps the agent capability-less and needs no nftables.

firewall_on() { [[ "$KONRAD_FIREWALL" == "1" ]]; }

# Names are per-run ($$) so concurrent konrad invocations don't collide; the
# konrad-fw- prefix makes orphans (after a kill -9) greppable for cleanup.
FW_ACTIVE=0
FW_NET_INTERNAL=""
FW_NET_EGRESS=""
FW_PROXY_NAME=""
# apple/container only: the internal net's gateway (the Mac host). Read once the
# proxy is up (fw_setup) and handed to the agent's entrypoint, which blackholes
# the route to it so the agent can't reach host services directly, bypassing the
# proxy. Empty on Podman (no host route to seal). See the seal prelude in
# image/entrypoint.sh and the host-gateway note in ARCHITECTURE → Egress firewall.
FW_SEAL_GATEWAY=""
# Whether WE created the egress net and must tear it down. 1 on Podman (a
# dedicated konrad-fw-out-$$); 0 on apple/container, where the egress leg is the
# engine-managed built-in `default` net (see fw_setup for why) — never ours to rm.
FW_EGRESS_MANAGED=1

# Remove this run's proxy + networks. Idempotent (EXIT trap may double-fire);
# every step is best-effort so teardown never masks the agent's exit code.
fw_teardown() {
  [[ "$FW_ACTIVE" == "1" ]] || return 0
  FW_ACTIVE=0
  dbg "firewall: tearing down proxy + networks"
  [[ -n "$FW_PROXY_NAME"  ]] && eng_rm_container "$FW_PROXY_NAME"
  [[ -n "$FW_NET_INTERNAL" ]] && eng_network_rm "$FW_NET_INTERNAL"
  [[ "$FW_EGRESS_MANAGED" == "1" && -n "$FW_NET_EGRESS" ]] && eng_network_rm "$FW_NET_EGRESS"
}

# Block until tinyproxy is accepting connections (it logs the line on start);
# bail fast with the proxy's own logs if it died (bad config, image mismatch).
fw_wait_ready() {
  local i
  for i in $(seq 1 100); do
    if eng_logs "$FW_PROXY_NAME" | grep -q "Accepting connections"; then
      dbg "firewall: proxy ready"
      return 0
    fi
    if ! eng_container_exists "$FW_PROXY_NAME"; then
      eng_logs "$FW_PROXY_NAME" | tail -20 >&2 || true
      die "egress firewall: proxy exited during startup (see logs above; --no-firewall to bypass)"
    fi
    sleep 0.1
  done
  eng_logs "$FW_PROXY_NAME" | tail -20 >&2 || true
  die "egress firewall: proxy did not become ready (--no-firewall to bypass)"
}

# The URL the agent points HTTP(S)_PROXY at. On Podman the proxy is reachable by
# its container hostname over the engine's internal DNS (works even on an
# --internal net). On apple/container DNS is dead on --internal, so we hand the
# agent the proxy's literal IPv4 on the internal net (re-read every run — it
# changes on each recreate). Must be called AFTER fw_wait_ready (the IP only
# exists once the container is up).
fw_proxy_url() {
  if [[ "$KONRAD_ENGINE" == "podman" ]]; then
    printf 'http://%s:%s' "$FW_PROXY_NAME" "$KONRAD_PROXY_PORT"
    return 0
  fi
  local ip
  ip="$(eng_container_ip "$FW_PROXY_NAME" "$FW_NET_INTERNAL")" \
    || die "egress firewall: could not read proxy IP (jq missing? --no-firewall to bypass)"
  [[ -n "$ip" ]] \
    || die "egress firewall: proxy has no IP on $FW_NET_INTERNAL yet (--no-firewall to bypass)"
  printf 'http://%s:%s' "$ip" "$KONRAD_PROXY_PORT"
}

# Create the networks and start the proxy sidecar. Reads globals the caller
# (podman_run) exports — KR_USERNS_FLAGS and KR_CFG_MOUNTS — because the proxy
# needs the same userns mapping and the same org/user config mounts as the agent
# (it derives the provider allow-list from the merged config). The proxy's own
# read-only secrets mount it builds here via ro_bind. Sets the FW_* globals and
# the EXIT trap so a partial setup is always cleaned up.
fw_setup() {
  FW_NET_INTERNAL="konrad-fw-net-$$"
  FW_PROXY_NAME="konrad-fw-proxy-$$"
  # The proxy's egress leg differs by engine. On Podman every created network
  # resolves (aardvark) and NATs, so we use a dedicated, torn-down egress net.
  # On apple/container that doesn't hold: a `container network create` net has NO
  # DNS resolver (only the built-in `default` net resolves + provides egress), and
  # a container takes its resolver from the FIRST attached network — so the egress
  # leg must be `default`, attached BEFORE the internal net, or the proxy can't
  # resolve any allow-listed host (verified on macOS 26: a custom egress net, or
  # `default` listed second, both yield "could not resolve host"). `default` is
  # engine-managed — we neither create nor tear it down.
  local -a fw_net_args
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    FW_NET_EGRESS="default"
    FW_EGRESS_MANAGED=0
    fw_net_args=(--network "$FW_NET_EGRESS" --network "$FW_NET_INTERNAL")  # egress (resolver) FIRST
  else
    FW_NET_EGRESS="konrad-fw-out-$$"
    FW_EGRESS_MANAGED=1
    fw_net_args=(--network "$FW_NET_INTERNAL" --network "$FW_NET_EGRESS")  # Podman's proven order
  fi
  trap fw_teardown EXIT
  trap 'exit 143' TERM   # TERM → exit → EXIT trap → teardown (don't leak nets);
                          # SIGINT is left untrapped so the interactive TUI's
                          # Ctrl-C reaches podman, which exits cleanly and lets
                          # this function's caller fall through to teardown.

  # Defensive: clear any same-named leftovers (PID reuse after a hard kill).
  eng_rm_container "$FW_PROXY_NAME"
  eng_network_rm "$FW_NET_INTERNAL"
  [[ "$FW_EGRESS_MANAGED" == "1" ]] && eng_network_rm "$FW_NET_EGRESS"

  dbg "firewall: creating internal network $FW_NET_INTERNAL (egress via $FW_NET_EGRESS)"
  eng_network_create_internal "$FW_NET_INTERNAL" \
    || die "egress firewall: could not create internal network (--no-firewall to bypass)"
  if [[ "$FW_EGRESS_MANAGED" == "1" ]]; then
    eng_network_create "$FW_NET_EGRESS" \
      || die "egress firewall: could not create egress network (--no-firewall to bypass)"
  fi
  FW_ACTIVE=1

  dbg "egress firewall: starting filtering proxy…"
  # Mount the shared secrets store READ-ONLY (ro_bind → :ro on Podman,
  # --mount …,readonly on apple/container) so the proxy can read auth.json's
  # provider *ids* (never the keys) — that's how it allow-lists the built-in
  # providers the user has connected, live-reloading when that changes. The proxy
  # never writes secrets, so RO holds on both engines. fw_net_args attaches the
  # sidecar to both nets (egress-first on apple/container — see above).
  local -a fw_secrets_mount
  ro_bind "$(eng_volume_source "$SECRETS_VOLUME")" /home/node/.opencode-secrets
  fw_secrets_mount=("${RO_BIND[@]}")

  # Local-model route (apple/container only). On Podman the engine injects
  # host.containers.internal into every container's /etc/hosts, so the proxy
  # resolves it (→ the host) for free and local models work through the proxy
  # like any other allow-listed host. apple/container injects no such alias and
  # has no --add-host, so we hand the proxy the egress (`default`) net's gateway —
  # which IS the Mac host — and its root prelude maps host.containers.internal to
  # it in /etc/hosts before dropping to node (see image/entrypoint.sh). That name
  # is in the baked allow-list floor, so a model request the agent sends through
  # the proxy to that name is forwarded to the host; any OTHER name/IP is still
  # default-denied. The agent never resolves it (it hands the name to the proxy
  # over HTTP(S)_PROXY). Best-effort: if the gateway can't be read we warn and
  # carry on — egress filtering is unaffected, only local-model name resolution.
  local -a fw_alias_flags=()
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    local egress_gw
    egress_gw="$(eng_network_gateway "$FW_NET_EGRESS")"
    if [[ -n "$egress_gw" ]]; then
      fw_alias_flags=(--user 0 -e "KONRAD_HOST_ALIAS_IP=$egress_gw")
      dbg "firewall: proxy host alias host.containers.internal -> $egress_gw (via $FW_NET_EGRESS)"
    else
      warn "could not read the $FW_NET_EGRESS gateway; a local model addressed as host.containers.internal may not resolve in the proxy (egress filtering is unaffected)"
    fi
  fi

  "$KONRAD_ENGINE" run -d --rm --name "$FW_PROXY_NAME" --init \
    "${fw_net_args[@]}" \
    ${fw_alias_flags[@]+"${fw_alias_flags[@]}"} \
    ${KR_USERNS_FLAGS[@]+"${KR_USERNS_FLAGS[@]}"} \
    ${KR_CFG_MOUNTS[@]+"${KR_CFG_MOUNTS[@]}"} \
    "${fw_secrets_mount[@]}" \
    -e "KONRAD_DEBUG=${KONRAD_DEBUG}" \
    -e "KONRAD_PROXY_PORT=${KONRAD_PROXY_PORT}" \
    -e "KONRAD_ALLOWED_HOSTS=${KONRAD_ALLOW_HOST}" \
    "$IMAGE_NAME" konrad-proxy >/dev/null \
    || die "egress firewall: could not start proxy container (--no-firewall to bypass)"

  fw_wait_ready
  step "firewall"

  # Host-gateway seal (apple/container only). Read the internal net's gateway —
  # the Mac host, directly reachable from the agent on this "host-only" net —
  # now that the net exists and the proxy has attached (so it's populated). The
  # agent's entrypoint blackholes the route to it (see KONRAD_SEAL_GATEWAY wiring
  # in podman_run and the seal prelude in image/entrypoint.sh). Podman needs no
  # seal: its --internal net exposes no route to the host at all.
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    FW_SEAL_GATEWAY="$(eng_network_gateway "$FW_NET_INTERNAL")"
    dbg "firewall: internal-net gateway to seal: ${FW_SEAL_GATEWAY:-<unresolved>}"
  fi
}

# --- Resource-limit defaults -------------------------------------------------
# Proportional caps derived from the host's own totals, so the ceiling fits the
# machine. Detection is best-effort (Linux /proc, macOS sysctl); any miss falls
# back to the fixed 4G / 4. Both engines take the same --memory/--cpus spelling,
# so one computation serves both. Users override via KONRAD_MEMORY / KONRAD_CPUS.

# Total physical RAM in MiB, or empty if it can't be read. Always exits 0.
host_mem_mib() {
  local raw=""
  if [[ "$(uname -s)" == "Darwin" ]]; then
    raw="$(sysctl -n hw.memsize 2>/dev/null || true)"
    if [[ "$raw" =~ ^[0-9]+$ ]]; then printf '%s' "$(( raw / 1048576 ))"; fi
  else
    raw="$(awk '/^MemTotal:/{print $2; exit}' /proc/meminfo 2>/dev/null || true)"
    if [[ "$raw" =~ ^[0-9]+$ ]]; then printf '%s' "$(( raw / 1024 ))"; fi
  fi
  return 0
}

# Logical CPU count, or empty if it can't be read. Always exits 0.
host_cpu_count() {
  local raw=""
  if [[ "$(uname -s)" == "Darwin" ]]; then
    raw="$(sysctl -n hw.ncpu 2>/dev/null || true)"
  else
    raw="$(nproc 2>/dev/null || true)"
  fi
  if [[ "$raw" =~ ^[0-9]+$ ]]; then printf '%s' "$raw"; fi
  return 0
}

# Default memory cap: half the host RAM, clamped to [2G, 32G] and never above the
# host total. Emitted as <n>G when a whole GiB, else <n>M. Falls back to 4G.
default_memory() {
  local total half
  total="$(host_mem_mib)"
  if [[ ! "$total" =~ ^[0-9]+$ ]] || (( total <= 0 )); then printf '4G'; return 0; fi
  half=$(( total / 2 ))
  if (( half < 2048 ));  then half=2048;  fi
  if (( half > 32768 )); then half=32768; fi
  if (( half > total )); then half="$total"; fi
  if (( half % 1024 == 0 )); then printf '%sG' "$(( half / 1024 ))"; else printf '%sM' "$half"; fi
  return 0
}

# Default CPU cap: all cores but two reserved for the host, min 2, never above the
# host count. Falls back to 4.
default_cpus() {
  local total cap
  total="$(host_cpu_count)"
  if [[ ! "$total" =~ ^[0-9]+$ ]] || (( total <= 0 )); then printf '4'; return 0; fi
  cap=$(( total - 2 ))
  if (( cap < 2 ));     then cap=2;        fi
  if (( cap > total )); then cap="$total"; fi
  printf '%s' "$cap"
  return 0
}

# Run a command inside the konrad container with the standard mount set.
# All variables are quoted, so paths containing spaces are safe.
podman_run() {
  local cwd ws_src
  cwd="$(pwd -P)"

  # Guard: refuse $HOME as the workspace. konrad bind-mounts the current dir into
  # the sandbox as /workspace; from your home folder that hands the agent your
  # entire home, and the mount fails outright on some hosts (SELinux won't relabel
  # $HOME; the macOS Podman VM can't traverse ~/.Trash). Name the fix, don't emit
  # a raw mount error. (Skipped in remote/self-test mode, where cwd is /workspace.)
  if [[ -z "${KONRAD_REMOTE_HOST_ROOT:-}" ]]; then
    local home_real
    home_real="$(cd "$HOME" 2>/dev/null && pwd -P || printf '%s' "$HOME")"
    if [[ "$cwd" == "$home_real" ]]; then
      cat >&2 <<EOF
konrad: refusing to run with your home directory as the workspace.

konrad mounts the current directory into the sandbox as /workspace; from \$HOME
that hands the agent your entire home folder, and the mount is refused outright
on some hosts (SELinux, macOS Podman). cd into a project directory and re-run.
EOF
      exit 1
    fi
  fi

  ws_src="$(remote_host_path "$cwd")"   # rewritten only in remote mode

  # Profile-suffixed state + cache volumes (secrets stays shared — see
  # KONRAD_PROFILE above). No profile → the base names, unchanged.
  local state_vol="$STATE_VOLUME" cache_vol="$CACHE_VOLUME"
  if [[ -n "$KONRAD_PROFILE" ]]; then
    state_vol="${STATE_VOLUME}-${KONRAD_PROFILE}"
    cache_vol="${CACHE_VOLUME}-${KONRAD_PROFILE}"
  fi

  # Mount-option suffixes for READ-WRITE binds. Podman uses :z (SELinux relabel)
  # and :U (chown the volume to the mapped user); apple/container supports neither
  # (VirtioFS maps UIDs, no SELinux, and its -v rejects suffixes), so they're
  # empty there. vol_relabel may be cleared again below for the rootful-remote
  # Podman path (chcon fails on virtiofs). Read-ONLY binds don't use these — they
  # go through ro_bind(), which picks :ro vs --mount …,readonly per engine.
  local vol_relabel=":z" vol_chown=":U"
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    vol_relabel=""; vol_chown=""
  fi

  # TTY / stdin allocation. The interactive TUI and the shell path want a
  # real terminal (-it). The non-interactive `konrad run` path never wants a
  # pseudo-tty (its answer should stream to stdout clean and capturable), and
  # it must be careful with stdin: `opencode run` treats a non-tty stdin as
  # PIPED input and reads it, so forwarding a live interactive terminal as a
  # non-tty fd (-i without -t) makes opencode block forever on a read that
  # never sees EOF. So in run mode we attach stdin ONLY when it's genuinely
  # piped/redirected (echo … | konrad run); from a terminal we pass neither
  # flag, podman leaves the container stdin closed, and opencode uses the
  # prompt arg. KONRAD_NONINTERACTIVE is set by do_run_oneshot before it
  # calls here.
  local -a tty_flags=(-it)
  if [[ "${KONRAD_NONINTERACTIVE:-0}" == "1" ]]; then
    if [[ -t 0 ]]; then tty_flags=(); else tty_flags=(-i); fi
  fi

  # Host-home bind mounts. The central log dir and the org/user config layers
  # live under $HOME. Against a LOCAL daemon they bind straight off this
  # filesystem. Against a REMOTE daemon (dev-container self-testing) the daemon
  # resolves every -v SOURCE on its OWN filesystem, so:
  #   - the log dir is skipped — no daemon-visible path for it; giving up
  #     host-side log capture is the one concession self-testing makes;
  #   - the config layers ARE mounted, from the host path the dev container
  #     exposes as KONRAD_REMOTE_HOST_CONFIG (the user's real ~/.config/konrad,
  #     which .devcontainer also binds into THIS container at $KONRAD_CFG_DIR so
  #     the -d guards below can see which layers exist). Net effect: self-testing
  #     composes baked < org < user exactly like an ordinary run — same model,
  #     AGENTS.md, skills, and providers — instead of running bare baked config.
  # The named volumes further down are daemon-side and work either way (so the
  # dev-container konrad still shares the host konrad's secrets/state).
  # cfg_mounts holds ONLY the org/user config layers — the firewall proxy needs
  # the identical set (it composes the same baked<org<user config to derive the
  # provider allow-list), so it's kept separate and merged into home_mounts for
  # the agent. home_mounts adds the agent-only central log dir on top.
  local -a cfg_mounts=()
  local -a home_mounts=()
  if [[ -z "${KONRAD_REMOTE_HOST_ROOT:-}" ]]; then
    # LOCAL daemon: log dir + config layers off this filesystem.
    # Central log dir on the host (XDG state). Created lazily so the bind
    # works on the very first launch. The entrypoint writes a per-session
    # sidecar here and opencode writes its structured log alongside.
    mkdir -p "$KONRAD_LOG_DIR"
    home_mounts+=(-v "${KONRAD_LOG_DIR}:/home/node/.local/share/opencode/log${vol_relabel}")
    # Config-layer mounts. The org layer (~/.config/konrad/org/) and the
    # per-user layer (~/.config/konrad/user/) are each surfaced WHOLE into
    # the container at /home/node/.config/konrad/{org,user}; the entrypoint
    # composes them over the baked defaults (precedence: baked < org < user).
    # Read-only — the container never writes back. Gated on existence so a
    # user with no org package (the common case) just gets the user mount.
    [[ -d "$ORG_CFG_DIR" ]]  && { ro_bind "$ORG_CFG_DIR"  /home/node/.config/konrad/org;  cfg_mounts+=("${RO_BIND[@]}"); }
    [[ -d "$USER_CFG_DIR" ]] && { ro_bind "$USER_CFG_DIR" /home/node/.config/konrad/user; cfg_mounts+=("${RO_BIND[@]}"); }
    # Reference-material mount (org/user-supplied wiki, docs, …) at /context.
    # AGENT-ONLY, so it lands in home_mounts, NOT cfg_mounts: it is not config,
    # and the firewall proxy (which consumes cfg_mounts to derive the allow-list)
    # has no business seeing it. One bind of the whole dir; consumers namespace
    # by subdir (/context/<name>). Reads fall under the default external_directory
    # allow, so no permission change. See ARCHITECTURE's mount table.
    [[ -d "$CONTEXT_CFG_DIR" ]] && { ro_bind "$CONTEXT_CFG_DIR" /context; home_mounts+=("${RO_BIND[@]}"); }
  else
    # REMOTE daemon: mount the SAME config layers, but from the daemon-visible
    # host path (KONRAD_REMOTE_HOST_CONFIG); the -d guards stat the copy the dev
    # container sees at $KONRAD_CFG_DIR. Unset (Linux host without the wire-up,
    # or an older dev container) → no config mount, baked-only, as before.
    local host_cfg="${KONRAD_REMOTE_HOST_CONFIG:-}"
    if [[ -n "$host_cfg" ]]; then
      [[ -d "$ORG_CFG_DIR" ]]  && { ro_bind "$host_cfg/org"  /home/node/.config/konrad/org;  cfg_mounts+=("${RO_BIND[@]}"); }
      [[ -d "$USER_CFG_DIR" ]] && { ro_bind "$host_cfg/user" /home/node/.config/konrad/user; cfg_mounts+=("${RO_BIND[@]}"); }
      # /context too (agent-only → home_mounts), for self-test parity. See the
      # local branch above for the full rationale.
      [[ -d "$CONTEXT_CFG_DIR" ]] && { ro_bind "$host_cfg/context" /context; home_mounts+=("${RO_BIND[@]}"); }
    fi
    # In remote-socket mode (dev-container self-test) the daemon resolves the
    # workspace bind against the HOST fs, which only knows paths under the guest
    # root. Outside it the bind can't resolve — podman dies with a raw
    # `statfs <cwd>: no such file or directory`. Refuse upfront with the fix
    # instead (the remote-mode analog of the $HOME guard above).
    local guest_root="${KONRAD_REMOTE_GUEST_ROOT:-/workspace}"
    if [[ "$cwd" != "$guest_root" && "$cwd" != "$guest_root/"* ]]; then
      die "in the dev container, run konrad from under $guest_root (got $cwd) — the workspace mount can't resolve a path outside it. cd into your checkout (e.g. $guest_root) and re-run."
    fi
  fi
  home_mounts+=(${cfg_mounts[@]+"${cfg_mounts[@]}"})

  # User-namespace mapping. The normal case (local rootless daemon, and the
  # Linux remote-socket path) is keep-id: container node(1000) shares the
  # invoking user's uid, so workspace files have sane ownership. A ROOTFUL
  # remote daemon — the macOS dev-container self-testing path, flagged by
  # KONRAD_DAEMON_ROOTFUL from .devcontainer/podman-vscode.sh — needs the
  # explicit equivalent instead: rootful keep-id degrades to an identity map
  # while virtiofs presents the workspace with raw Mac ids, so node must be
  # mapped to the Mac user's uid/gid (KONRAD_REMOTE_UID/GID, injected by the
  # same shim). SELinux labeling is disabled there (Enforcing in the machine
  # VM) and the workspace `:z` relabel skipped (chcon fails on virtiofs).
  # apple/container takes neither path: VirtioFS maps guest UIDs → the host user
  # automatically, so it gets no userns flag at all (and no relabel — vol_relabel
  # was already emptied for it above).
  local -a userns_flags=("--userns=keep-id:uid=1000,gid=1000")
  if [[ "$KONRAD_ENGINE" == "container" ]]; then
    userns_flags=()
  elif [[ "${KONRAD_DAEMON_ROOTFUL:-0}" == "1" ]]; then
    local ruid="${KONRAD_REMOTE_UID:?KONRAD_DAEMON_ROOTFUL=1 requires KONRAD_REMOTE_UID}"
    local rgid="${KONRAD_REMOTE_GID:?KONRAD_DAEMON_ROOTFUL=1 requires KONRAD_REMOTE_GID}"
    vol_relabel=""
    userns_flags=(
      --security-opt label=disable
      --uidmap 0:100000:999 --uidmap 999:0:1
      --uidmap "1000:${ruid}:1" --uidmap 1001:101001:64535
      --gidmap 0:100000:999 --gidmap 999:0:1
      --gidmap "1000:${rgid}:1" --gidmap 1001:101001:64535
    )
  fi

  # Egress firewall: stand up the sidecar + isolated network, then put the agent
  # on that network ONLY and point it at the proxy. The proxy reuses the agent's
  # userns map + config mounts (exported as globals for fw_setup, since bash 3.2
  # has no array passing). With the firewall off, the agent keeps Podman's default
  # networking and unrestricted egress — the pre-firewall behaviour.
  # seal_flags: apple/container-only host-gateway seal (see fw_setup + the seal
  # prelude in image/entrypoint.sh). The agent starts as root with CAP_NET_ADMIN
  # so its entrypoint can blackhole the route to the host, then drops to node
  # with the capability stripped. Empty on Podman (no host route to seal) and on
  # the firewall-off path (no internal net, no proxy — egress is unrestricted by
  # design there, so there is nothing to bypass).
  local -a net_flags=() proxy_env=() seal_flags=()
  if firewall_on; then
    KR_USERNS_FLAGS=(${userns_flags[@]+"${userns_flags[@]}"})
    KR_CFG_MOUNTS=(${cfg_mounts[@]+"${cfg_mounts[@]}"})
    fw_setup
    local proxy_url
    proxy_url="$(fw_proxy_url)"   # hostname on Podman, IP on apple/container
    net_flags=(--network "$FW_NET_INTERNAL")
    # Fail CLOSED: if we couldn't determine the host gateway to seal, refuse to
    # run rather than expose the agent to host services directly. The user keeps
    # two explicit escape hatches (both surrender the seal knowingly).
    if [[ "$KONRAD_ENGINE" == "container" ]]; then
      [[ -n "$FW_SEAL_GATEWAY" ]] \
        || die "egress firewall: could not determine the host-gateway IP to seal (apple/container). Refusing to run with the host reachable directly. Re-run with --no-firewall, or KONRAD_ENGINE=podman, to bypass."
      seal_flags=(--user 0 --cap-add NET_ADMIN -e "KONRAD_SEAL_GATEWAY=${FW_SEAL_GATEWAY}")
    fi
    # Bun's fetch (opencode) honours these; lower- and upper-case both, since
    # different tools read different spellings. localhost stays direct.
    proxy_env=(
      -e "HTTP_PROXY=${proxy_url}"  -e "HTTPS_PROXY=${proxy_url}"
      -e "http_proxy=${proxy_url}"  -e "https_proxy=${proxy_url}"
      -e "NO_PROXY=localhost,127.0.0.1"  -e "no_proxy=localhost,127.0.0.1"
    )
  fi

  # ${home_mounts[@]+"${home_mounts[@]}"} is the empty-safe array splice —
  # under `set -u`, a bare ${arr[@]} on an empty array would error.
  # --init: podman runs a tiny init (catatonit) as PID 1 inside the container
  # so signals (SIGINT, SIGTERM) reach opencode cleanly and any orphaned
  # children get reaped. Per Node Docker best-practices §5.
  # KONRAD_HOST_WORKSPACE is read by the entrypoint to write the
  # workspace path into the session sidecar (opencode itself only
  # sees /workspace and can't record the host path).
  # Optional host port publish, set by callers that need an inbound callback
  # reachable from the host (konrad mcp-auth's OAuth loopback redirect). Bound to
  # 127.0.0.1 so it never listens on a routable interface. Only used on the
  # firewall-off path, where the container is on the default network.
  local -a publish_flags=()
  [[ -n "${KONRAD_PUBLISH_PORT:-}" ]] \
    && publish_flags=(-p "127.0.0.1:${KONRAD_PUBLISH_PORT}:${KONRAD_PUBLISH_PORT}")

  # Resource caps (RAM + CPU; see KONRAD_MEMORY / KONRAD_CPUS up top). Unset env →
  # a proportional default from host totals; explicit value used as-is; 0 → no cap.
  # Same flag spelling on both engines.
  local mem_cap cpu_cap
  mem_cap="${KONRAD_MEMORY:-$(default_memory)}"
  cpu_cap="${KONRAD_CPUS:-$(default_cpus)}"
  local -a res_flags=()
  [[ "$mem_cap" != 0 ]] && res_flags+=(--memory "$mem_cap")
  [[ "$cpu_cap" != 0 ]] && res_flags+=(--cpus   "$cpu_cap")

  # Let CPU-bound libraries use the cores we just granted. docling/torch (and any
  # OpenMP/numpy work) otherwise self-throttle to 4 threads regardless of --cpus,
  # so on a big host the extra cores sit idle on the heaviest tool in the image.
  # Track the CPU cap as an integer (floor a fractional --cpus; min 1); when the
  # cap is off, fall back to the host core count. Best-effort — skip if unknown.
  local omp_threads=""
  if [[ "$cpu_cap" != 0 ]]; then omp_threads="${cpu_cap%%.*}"; else omp_threads="$(host_cpu_count)"; fi
  if [[ "$omp_threads" =~ ^[0-9]+$ ]]; then
    if (( omp_threads < 1 )); then omp_threads=1; fi
  else
    omp_threads=""
  fi
  local -a omp_flags=()
  [[ -n "$omp_threads" ]] && omp_flags+=(-e "OMP_NUM_THREADS=$omp_threads")

  local -a run_cmd=(
    "$KONRAD_ENGINE" run
    --rm ${tty_flags[@]+"${tty_flags[@]}"} --init
    ${userns_flags[@]+"${userns_flags[@]}"}
    ${seal_flags[@]+"${seal_flags[@]}"}
    ${net_flags[@]+"${net_flags[@]}"}
    ${publish_flags[@]+"${publish_flags[@]}"}
    ${res_flags[@]+"${res_flags[@]}"}
    ${omp_flags[@]+"${omp_flags[@]}"}
    ${proxy_env[@]+"${proxy_env[@]}"}
    -e "KONRAD_DEBUG=${KONRAD_DEBUG}"
    -e "KONRAD_TRACE_FETCH=${KONRAD_TRACE_FETCH:-0}"
    -e "KONRAD_HOST_WORKSPACE=${ws_src}"
    -e "KONRAD_HOST_LOG_DIR=${KONRAD_LOG_DIR}"
    -e "KONRAD_ALLOWED_HOSTS=${KONRAD_ALLOW_HOST}"
    -v "${ws_src}:/workspace${vol_relabel}"
    -v "$(eng_volume_source "$SECRETS_VOLUME"):/home/node/.opencode-secrets${vol_chown}"
    -v "$(eng_volume_source "$cache_vol"):/home/node/.cache/opencode${vol_chown}"
    -v "$(eng_volume_source "$state_vol"):/home/node/.local/state/opencode${vol_chown}"
    ${home_mounts[@]+"${home_mounts[@]}"}
    -w /workspace
    "$IMAGE_NAME" "$@"
  )

  step "container"

  # No firewall → exec, replacing this shell so signals/exit code pass straight
  # through (the pre-firewall behaviour). With the firewall we must stay alive to
  # tear down the proxy + networks, so run in the foreground and exit with the
  # agent's code; the EXIT trap (set in fw_setup) does the cleanup either way.
  if firewall_on; then
    local rc=0
    "${run_cmd[@]}" || rc=$?
    exit "$rc"
  fi
  exec "${run_cmd[@]}"
}

# --- Actions ---

# Shared preflight for every container-launching verb (run / shell / connect /
# mcp-auth / opencode): engine reachable, image present, logs pruned. brand() is
# left to the caller — its placement varies (connect/mcp-auth print context
# first), and connect/mcp-auth flip the firewall off before it.
launch_preflight() {
  require_engine; dbg "engine OK"
  require_image;  dbg "image OK"
  prune_log_dir
}

do_run() {
  local mode="$1"  # "agent" or "shell"
  dbg "do_run start (mode=$mode)"
  launch_preflight
  brand
  if [[ "$mode" == "shell" ]]; then
    dbg "about to exec podman run (bash)"
    podman_run bash
  else
    dbg "about to exec podman run (opencode)"
    podman_run opencode
  fi
}

# Non-interactive one-shot: exec `opencode run <args…>` instead of the TUI.
# Same preflight + workspace side-effects as the agent path (it's still the
# agent against this workspace, just one prompt with the answer on stdout).
# Everything in "$@" is forwarded verbatim to `opencode run` — konrad doesn't
# enumerate opencode's flags, so --model / --agent / --session and anything
# opencode adds later ride straight through. Pair with --profile to keep a
# self-test off the user's real state. opencode's exit code propagates via exec.
do_run_oneshot() {
  dbg "do_run_oneshot start"
  launch_preflight
  KONRAD_NONINTERACTIVE=1   # read by podman_run to drop the pseudo-tty
  brand
  dbg "about to exec podman run (opencode run)"
  podman_run opencode run "$@"
}

# Generic opencode pass-through: exec `opencode <args…>` in the sandbox. The
# escape hatch for opencode subcommands konrad doesn't wrap (models, agent list,
# session list, auth list, …) — firewall stays ON and output goes to stdout, like
# `run`. Provider auth has its own verb (`connect`, firewall off); a single prompt
# is `run`. Args forward verbatim, so anything opencode adds later rides through.
do_opencode() {
  dbg "do_opencode start"
  [[ $# -ge 1 ]] || die "usage: $SELF opencode <args…>  (e.g. $SELF opencode models)"
  launch_preflight
  KONRAD_NONINTERACTIVE=1   # clean, pipeable stdout — same as run
  brand
  dbg "about to exec podman run (opencode $*)"
  podman_run opencode "$@"
}

# Authenticate a provider: `opencode auth login`, with NO LLM agent in the loop.
# Args after `connect` pass straight through (konrad doesn't re-enumerate
# opencode's flags), so `konrad connect` opens the picker and
# `konrad connect -p openrouter` skips it — same as do_run_oneshot forwards to
# `opencode run`. The credential lands on the konrad-secrets volume (auth.json),
# exactly like an in-TUI /connect.
#
# The firewall is FORCED OFF for this verb. It's safe because authentication runs
# no agent — there's no prompt-injection surface to contain — and it's the clean
# fix for the one rough edge of the default-on firewall: an OAuth first-connect
# (Claude Pro/Max, Copilot) does its handshake BEFORE auth.json exists, so the
# proxy can't auto-allow the host and the user would otherwise need a one-time
# --allow-host. With no filter in the loop, OAuth and API-key logins alike just
# work, no flags. (API-key logins need no egress at all; OAuth needs its host.)
do_connect() {
  dbg "do_connect start"
  # `--custom [id]` runs the guided self-hosted-provider flow (declare + key);
  # everything else passes straight to `opencode auth login` (integrated + OAuth).
  if [[ "${1:-}" == "--custom" ]]; then
    shift
    do_connect_custom "${1:-}"
    return
  fi
  launch_preflight
  # The one wrong-door case: a self-hosted endpoint connected via opencode's bare
  # "Other" gets a credential but no config declaration. Point those users at the
  # guided flow. Integrated providers are fine here — this IS `opencode auth login`,
  # the same backend as the TUI's /connect.
  if [[ $# -eq 0 ]]; then
    info "tip: a custom / self-hosted endpoint? use 'konrad connect --custom' to declare it too."
  fi
  KONRAD_FIREWALL=0   # pure auth, no agent → no injection surface → safe unfiltered
  brand
  dbg "about to exec podman run (opencode auth login)"
  podman_run opencode auth login "$@"
}

# Guided custom / self-hosted provider flow. Two halves: the DECLARATION
# (baseURL + models) goes into the user config layer — Konrad owns that — and the
# CREDENTIAL goes to opencode's auth.json via `opencode auth login`, which Konrad
# never touches (the "keys never leak into konrad" invariant). opencode's auth
# login only accepts custom ids through its interactive "Other" path (it rejects
# `-p <non-catalog-id>`), so the key step is a guided hand-off, not a drive.
#
# Whether the provider is already declared (e.g. shipped by an org layer) is read
# straight from the host-side org/user config — baked carries no custom providers,
# so those two layers are the whole story. jq can't parse JSONC, so a layer that
# carries comments is treated as "unknown" and we fall back to one y/N — never an
# unsafe // strip (that would maul a https:// URL). In practice the layers are
# plain JSON (Konrad writes them that way), so the question simply doesn't appear.
do_connect_custom() {
  local id="$1" baseurl model block userfile merged ans declared="" unknown=0 f

  command -v jq >/dev/null 2>&1 \
    || die "konrad connect --custom needs 'jq' on the host (e.g. 'brew install jq' / 'apt install jq')."
  require_engine; require_image

  [[ -n "$id" ]] || read -r -p "Provider id (e.g. acme): " id
  [[ -n "$id" ]] || die "a provider id is required."
  [[ "$id" =~ ^[A-Za-z0-9_-]+$ ]] \
    || die "invalid provider id '$id' (allowed: letters, digits, '-', '_')."

  # Auto-detect: is $id declared in a config layer we can read?
  for f in "$ORG_CFG_DIR/opencode.jsonc" "$USER_CFG_DIR/opencode.jsonc"; do
    [[ -f "$f" ]] || continue
    if jq -e --arg id "$id" '(.provider // {}) | has($id)' "$f" >/dev/null 2>&1; then
      declared=yes; break
    elif ! jq empty "$f" >/dev/null 2>&1; then
      unknown=1   # JSONC/unparseable — can't tell from this layer
    fi
  done
  if [[ -z "$declared" && "$unknown" == 1 ]]; then
    read -r -p "Couldn't fully read your config. Is '$id' already declared (e.g. by your org)? [y/N] " ans
    [[ "$ans" =~ ^[Yy] ]] && declared=yes
  fi

  if [[ "$declared" == yes ]]; then
    info "'$id' is already declared in your config — skipping to the key step."
  else
    # Scenario 1 — declare it: endpoint + at least one served model.
    read -r -p "Base URL (OpenAI-compatible, e.g. https://llm.acme.example/v1): " baseurl
    [[ -n "$baseurl" ]] || die "a base URL is required for a new custom provider."
    read -r -p "One model id served there (e.g. acme-large): " model
    [[ -n "$model" ]] || die "at least one model id is required."

    block="$(jq -n --arg id "$id" --arg url "$baseurl" --arg m "$model" \
      '{provider: {($id): {npm: "@ai-sdk/openai-compatible", name: $id,
                           options: {baseURL: $url},
                           models: {($m): {name: $m}}}}}')"

    userfile="$USER_CFG_DIR/opencode.jsonc"
    printf '\nkonrad: this provider declaration belongs in %s:\n%s\n\n' "$userfile" "$block" >&2

    if [[ ! -f "$userfile" ]]; then
      read -r -p "Create $userfile with it? [y/N] " ans
      if [[ "$ans" =~ ^[Yy] ]]; then
        mkdir -p "$USER_CFG_DIR"
        printf '%s\n' "$block" > "$userfile"
        info "wrote $userfile"
      else
        info "skipped — add the block above to $userfile yourself before your next run."
      fi
    elif jq empty "$userfile" >/dev/null 2>&1; then
      # Plain JSON → safe to deep-merge (objects recurse under jq's '*').
      read -r -p "Merge it into $userfile? [y/N] " ans
      if [[ "$ans" =~ ^[Yy] ]]; then
        merged="$(jq -s '.[0] * .[1]' "$userfile" <(printf '%s' "$block"))" \
          && printf '%s\n' "$merged" > "$userfile" \
          && info "updated $userfile"
      else
        info "skipped — add the block above to $userfile yourself before your next run."
      fi
    else
      # Has comments (JSONC) → don't risk clobbering them with a jq round-trip.
      info "$userfile has comments — add the block above into its \"provider\" object by hand, then continue."
    fi
  fi

  # Guided key hand-off. opencode owns the credential; konrad never reads the key.
  cat >&2 <<EOF

konrad: opening 'opencode auth login' (firewall off — safe, no agent runs).
  When it opens:
    • choose "Other"
    • enter provider id:  $id
    • paste your API key
EOF
  KONRAD_FIREWALL=0
  podman_run opencode auth login
}

# Authenticate a remote MCP server's OAuth: `opencode mcp auth <server>`, with NO
# agent in the loop. Two sandbox-specific moves on top of a bare auth, both the
# reason this can't just live in the agent's normal run:
#   • Firewall OFF — same rationale as do_connect: pure auth has no injection
#     surface, and the OAuth handshake needs to reach the MCP host before any
#     allow-list applies.
#   • Publish opencode's loopback callback port to the host. opencode runs a
#     local redirect server inside the sandbox; the browser approval redirects to
#     http://127.0.0.1:PORT/…, which from the host would hit a dead port. Publish
#     it and the redirect lands back inside, so the flow completes on its own —
#     no manual code-paste dance. The token persists on the konrad-secrets volume
#     (mcp-auth.json, symlinked in the entrypoint) and is reused on every run.
do_mcp_auth() {
  dbg "do_mcp_auth start"
  [[ $# -ge 1 ]] \
    || die "usage: $SELF mcp-auth <server>  (the MCP server's name in your opencode config)"
  launch_preflight
  info "authenticating MCP server '$1' (firewall off — safe, no agent runs)."
  cat >&2 <<'EOF'
  A URL prints below — open it in your browser and approve. You'll be redirected
  to localhost; Konrad forwards that callback into the sandbox, so it completes
  on its own. The token is saved and reused automatically on later runs.
EOF
  KONRAD_FIREWALL=0
  KONRAD_PUBLISH_PORT="$KONRAD_MCP_AUTH_PORT"
  brand
  dbg "about to exec podman run (opencode mcp auth)"
  podman_run opencode mcp auth "$@"
}

do_version() {
  # Compact, mirroring the startup banner (brand()): a `cli X · image Y`
  # headline — CLI and image are DISTINCT versions (a CLI-only patch ships
  # without an image rebuild, so they legitimately differ), not one overarching
  # "konrad" number — then one dim detail line carrying the immutable pin
  # (registry repo : <short-sha> — the handle to pin/rollback), the local tag,
  # the build date, and the engine. Prints to stdout (the version is
  # conventionally parseable there, unlike konrad's stderr chatter), so color
  # gates on a stdout TTY — NOT the global _C_*, which gate on stderr and would
  # bleed ANSI into `konrad --version | …`.
  local c_brand='' c_dim='' c_off=''
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    c_brand=$'\033[1;36m'; c_dim=$'\033[2m'; c_off=$'\033[0m'
  fi

  # Resolve the image field (headline) + the dim detail line up front, then
  # print both in the shared brand-mirror layout once. Labels go through
  # eng_image_label (best-effort on apple/container — a miss reads "unknown").
  local img_field detail
  if ! command -v "$KONRAD_ENGINE" >/dev/null 2>&1 || ! eng_running; then
    img_field="?"
    detail="cannot inspect image — $KONRAD_ENGINE unavailable"
  elif ! eng_image_exists "$IMAGE_NAME"; then
    local hint
    if is_dev; then hint="konrad-dev rebuild"; else hint="konrad update"; fi
    img_field="not present"
    detail="$IMAGE_NAME · run: $hint"
  else
    local image_ver image_rev image_created pin
    image_ver="$(eng_image_label "$IMAGE_NAME" org.opencontainers.image.version)"
    [[ -z "$image_ver" ]] && image_ver="unknown"
    image_rev="$(eng_image_label "$IMAGE_NAME" org.opencontainers.image.revision)"
    [[ -z "$image_rev" ]] && image_rev="unknown"
    image_created="$(eng_image_label "$IMAGE_NAME" org.opencontainers.image.created)"
    img_field="$image_ver"
    # The immutable pin: the revision (git short-sha) hung off the registry repo
    # (REGISTRY_IMAGE minus its tag). A miss (dev/old image, no revision label)
    # degrades to the local tag. The local tag is shown in parens only when it
    # differs from the pin, so the common case stays one clean token.
    if [[ "$image_rev" != "unknown" ]]; then pin="${REGISTRY_IMAGE%:*}:$image_rev"; else pin="$IMAGE_NAME"; fi
    detail="$pin"
    [[ "$pin" != "$IMAGE_NAME" ]] && detail="$detail ($IMAGE_NAME)"
    [[ -n "${KONRAD_IMAGE:-}" ]] && detail="$detail · KONRAD_IMAGE override"
    [[ "${image_created%%T*}" == ????-??-?? && "${image_created%%T*}" != "1970-01-01" ]] \
      && detail="$detail · built ${image_created%%T*}"
    detail="$detail · engine: $KONRAD_ENGINE"
  fi

  printf '%skonrad%s  %scli %s · image %s%s\n' \
    "$c_brand" "$c_off" "$c_dim" "$KONRAD_VERSION" "$img_field" "$c_off"
  printf '  %s%s%s\n' "$c_dim" "$detail" "$c_off"
  # No CLI-vs-image skew warning by design. CLI-only patches don't trigger an
  # image rebuild (the workflow's paths: filter excludes VERSION), so a
  # patch-line drift between CLI and image labels is normal — the contract
  # between them is thin (env vars + mount paths + `opencode` entrypoint).
  # "Is there anything new in the registry?" is what `konrad update --check`
  # answers.
}

# Probe the registry (CLI source + image label) and report whether an update
# is available. Two network calls (gitlab raw + ghcr manifest+config), both
# capped at 5s via curl --max-time. Offline doesn't break the command — the
# verdict degrades to "couldn't reach …" and exit stays 0.
do_check_updates() {
  printf 'konrad — checking for updates…\n'
  printf '\n'

  local cli_remote=""
  if command -v curl >/dev/null 2>&1; then
    cli_remote="$(curl -fsS --max-time 5 \
                    'https://gitlab.git.nrw/jbauss2/konrad/-/raw/main/VERSION' 2>/dev/null \
                  | head -1 | tr -d '[:space:]')"
  fi

  local image_local_ver="" image_remote_ver=""
  if command -v "$KONRAD_ENGINE" >/dev/null 2>&1 \
     && eng_running \
     && eng_image_exists "$IMAGE_NAME"; then
    image_local_ver="$(eng_image_label "$IMAGE_NAME" org.opencontainers.image.version)"
  fi
  image_remote_ver="$(registry_image_version "$REGISTRY_IMAGE" 2>/dev/null || true)"

  printf '  CLI:    %s (local) → %s (registry)\n' \
    "$KONRAD_VERSION" "${cli_remote:-unreachable}"
  printf '  image:  %s (local) → %s (registry)\n' \
    "${image_local_ver:-not pulled}" "${image_remote_ver:-unreachable}"
  printf '\n'

  # "Drift" only counts as actionable when *both* sides of a comparison are
  # known (i.e. not "dev", not "unreachable", not "not pulled"). Anything
  # ambiguous → "partial check" verdict.
  local cli_drift=0 image_drift=0 cli_known=0 image_known=0
  if [[ -n "$cli_remote" && "$KONRAD_VERSION" != "dev" ]]; then
    cli_known=1
    [[ "$KONRAD_VERSION" != "$cli_remote" ]] && cli_drift=1
  fi
  if [[ -n "$image_remote_ver" && -n "$image_local_ver" ]]; then
    image_known=1
    [[ "$image_local_ver" != "$image_remote_ver" ]] && image_drift=1
  fi

  if (( cli_drift || image_drift )); then
    printf 'Update available — run: konrad update\n'
    return 0
  fi
  if (( cli_known && image_known )); then
    printf 'Up to date.\n'
    # If CLI and image labels differ but both match the registry, the user
    # is current — just sitting on the by-design drift from CLI-only
    # patches. One line of context so it doesn't read as a problem.
    if [[ -n "$image_local_ver" && "$KONRAD_VERSION" != "dev" \
          && "$KONRAD_VERSION" != "$image_local_ver" ]]; then
      printf '  (CLI patches alone do not trigger an image rebuild — drift is by design.)\n'
    fi
    return 0
  fi
  printf "Couldn't reach all sources — partial check. Try again when online.\n"
}

do_pull_image() {
  # Internal verb: pull REGISTRY_IMAGE through the layer-counter wrapper and
  # tag it as IMAGE_DEFAULT. Owned here so the POSIX install.sh and
  # bash do_update share one implementation of the bash-only pipeline
  # (jq + curl manifest preflight + awk counter). Not in --help — internal.
  if is_dev; then
    die "konrad-dev doesn't pull from the registry. To rebuild the dev image: konrad-dev rebuild."
  fi
  require_engine
  info "pulling ${REGISTRY_IMAGE}…"
  if ! eng_pull "$REGISTRY_IMAGE"; then
    die "registry pull failed (offline? registry unreachable?)"
  fi
  eng_tag "$REGISTRY_IMAGE" "$IMAGE_DEFAULT"
}

# Re-read the KONRAD_VERSION_BAKED placeholder off disk after install.sh
# has rewritten $0. The in-memory $KONRAD_VERSION is whatever this process
# started with (pre-refresh); on disk is the new value. Used by do_update's
# tail so the final --version block reflects what the user just installed.
reread_baked_version() {
  local v
  v="$(sed -n 's/^KONRAD_VERSION_BAKED="\(.*\)".*/\1/p' "$0" 2>/dev/null | head -1)"
  [[ -n "$v" ]] && KONRAD_VERSION="$v"
}

do_update() {
  # Hard gate: update refreshes the published image and the stable CLI
  # itself. konrad-dev's image (konrad:local) comes from rebuild, and
  # its CLI source comes from `git pull` in the checkout — neither path
  # touches what update would touch.
  if is_dev; then
    die "konrad-dev doesn't update. To rebuild the dev image: konrad-dev rebuild. To refresh the stable konrad CLI next to it on PATH: konrad update. To update this script: git pull inside the checkout the symlink points at."
  fi

  # A symlink install tracks a checkout — refresh the CLI with `git pull` in that
  # clone, NOT the remote installer (which would clobber the symlink with a
  # regular file). Pull the image directly and report.
  if [[ -L "$0" ]]; then
    info "CLI is a symlink — update it with 'git pull' inside the checkout it points at."
    do_pull_image
    printf '\n'
    return 0
  fi

  # Regular curl|sh install: hand the whole job to the installer. It refreshes
  # the CLI FIRST, then pulls the image (via `konrad pull-image`) — one source of
  # truth for both halves of an update, and CLI-before-image ordering for free.
  # No fetcher on PATH → fall back to refreshing just the image.
  if ! command -v curl >/dev/null 2>&1 && ! command -v wget >/dev/null 2>&1; then
    warn "neither curl nor wget available; refreshing the image only (CLI left as-is)."
    do_pull_image
    printf '\n'
    do_check_updates
    return 0
  fi
  info "updating konrad…"
  local install_dir
  install_dir="$(dirname "$0")"
  # Env-var prefix on the *right* side of the pipe — `VAR=x curl … | sh` only
  # sets the var for curl, not for the `sh` consuming the pipe. The installer
  # lands at the same path (KONRAD_INSTALL_DIR) and stays quiet (we already
  # announced the update); it does the image pull itself, so no KONRAD_NO_PULL.
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$INSTALL_URL" \
      | KONRAD_INSTALL_DIR="$install_dir" KONRAD_QUIET_INSTALL=1 sh
  else
    wget -qO- "$INSTALL_URL" \
      | KONRAD_INSTALL_DIR="$install_dir" KONRAD_QUIET_INSTALL=1 sh
  fi

  # Registry comparison from the freshly baked CLI. reread_baked_version picks up
  # the version install.sh just wrote so the CLI: line is current; do_check_updates
  # then does the local-vs-registry probe — more useful right after an update than
  # the standalone digest/rev block (still at `konrad --version`).
  reread_baked_version
}

do_rebuild() {
  # Hard gate: rebuild is konrad-dev's verb. A curl|sh-installed konrad
  # has no source to build from, and we want the dev image and stable
  # image to stay in separate worlds.
  if ! is_dev; then
    cat >&2 <<'EOF'
konrad: 'rebuild' is only available from konrad-dev.

konrad-dev is the contributor binary — a symlink to bin/konrad from a
checkout of the konrad repo. To set it up:

  git clone https://gitlab.git.nrw/jbauss2/konrad.git
  cd konrad
  mkdir -p ~/.local/bin && ln -sfn "$(pwd)/bin/konrad" ~/.local/bin/konrad-dev
  konrad-dev rebuild

Full contributor setup: CONTRIBUTING.md.

To just refresh the published image: konrad update
EOF
    exit 1
  fi
  require_engine
  # konrad-dev should always have the source next to it (the symlink points
  # at a checkout's bin/konrad), but guard anyway — a sparse checkout or a
  # stale symlink would otherwise fail downstream with a confusing error.
  if [[ ! -f "$IMAGE_CONTEXT/Dockerfile" ]]; then
    die "konrad-dev: expected $IMAGE_CONTEXT/Dockerfile (is the symlink pointing at a complete checkout?)"
  fi
  # Delegate to scripts/build-image.sh — the single source of truth for the
  # local build (lock reading, git-sha/build-date metadata, build-args). It
  # builds on the selected engine: Podman via buildah (the cache-tagged
  # three-stage path), apple/container via `container build` straight into
  # container's own store (no podman, no machine VM). KONRAD_ENGINE is exported
  # so the script picks the matching path. It writes $IMAGE_LOCAL_TAG
  # (konrad:local), never clobbering the pulled $IMAGE_DEFAULT. Safe to assume
  # present: rebuild only runs from a full checkout (guarded just above).
  info "building $IMAGE_LOCAL_TAG from $IMAGE_CONTEXT (konrad=$KONRAD_VERSION, engine=$KONRAD_ENGINE)"
  KONRAD_ENGINE="$KONRAD_ENGINE" "$REPO_ROOT/scripts/build-image.sh" || die "image build failed"
  info "built $IMAGE_LOCAL_TAG — run with: konrad-dev"
}

do_reset() {
  # Two shapes. Without --profile: wipe the shared default state — log dir +
  # all three base volumes (the original, ALL-workspaces reset). With
  # --profile <name>: wipe only that profile's throwaway state + cache volumes,
  # and leave the shared secrets and the central log dir untouched (the secrets
  # volume is shared on purpose — see KONRAD_PROFILE — so a profile reset must
  # never delete the user's real credentials).
  if [[ -n "$KONRAD_PROFILE" ]]; then
    local p_state="${STATE_VOLUME}-${KONRAD_PROFILE}" p_cache="${CACHE_VOLUME}-${KONRAD_PROFILE}"
    cat >&2 <<EOF

==============================================================================
WARNING — reset --profile $KONRAD_PROFILE will permanently delete:

  - the profile's throwaway volumes:
      • $p_state  (this profile's opencode session/model state)
      • $p_cache  (this profile's opencode cache)

Leaves alone: the shared $SECRETS_VOLUME (credentials), the central log dir,
and the default (profile-less) volumes. There is no undo.
==============================================================================

EOF
    printf 'konrad: proceed with profile reset? [y/N]: ' >&2
    local confirmation=""
    read -r confirmation || true
    case "$confirmation" in
      y|Y|yes|YES) ;;
      *) info "aborted; nothing was deleted."; exit 0 ;;
    esac
    if command -v "$KONRAD_ENGINE" >/dev/null 2>&1 && eng_running; then
      for vol in "$p_state" "$p_cache"; do
        if eng_volume_exists "$vol"; then
          eng_volume_rm "$vol"
          info "removed profile volume $vol"
        fi
      done
    else
      warn "$KONRAD_ENGINE not reachable; profile volumes were NOT removed."
    fi
    info "profile '$KONRAD_PROFILE' reset complete."
    return 0
  fi

  cat >&2 <<EOF

==============================================================================
WARNING — reset will permanently delete:

  - the central log dir:
      $KONRAD_LOG_DIR
  - the shared volumes:
      • $SECRETS_VOLUME  (your provider credentials — you'll need to /connect again)
      • $CACHE_VOLUME    (opencode's cache)
      • $STATE_VOLUME    (opencode's UI state and model selection)

This affects ALL workspaces, not just the current one. There is no undo.
==============================================================================

EOF
  printf 'konrad: proceed with reset? [y/N]: ' >&2
  local confirmation=""
  read -r confirmation || true
  case "$confirmation" in
    y|Y|yes|YES) ;;
    *) info "aborted; nothing was deleted."; exit 0 ;;
  esac

  if [[ -d "$KONRAD_LOG_DIR" ]]; then
    rm -rf "$KONRAD_LOG_DIR"
    info "removed $KONRAD_LOG_DIR"
  fi
  if command -v "$KONRAD_ENGINE" >/dev/null 2>&1 && eng_running; then
    for vol in "$SECRETS_VOLUME" "$CACHE_VOLUME" "$STATE_VOLUME"; do
      if eng_volume_exists "$vol"; then
        eng_volume_rm "$vol"
        info "removed shared volume $vol"
      fi
    done
  else
    warn "$KONRAD_ENGINE not reachable; shared volumes were NOT removed."
  fi
  info "reset complete. Next run will need a fresh /connect, repopulate caches, and re-pick a model."
}

do_uninstall() {
  # Removes this binary's installation (the CLI on PATH + its dedicated
  # image, plus build-cache images for konrad-dev). Shared state — user
  # config, volumes, log dir — is intentionally left alone; that's
  # reset's job. Composes: reset first to wipe shared state, then
  # uninstall on each binary you've installed.
  local self other_name other_path target_image cache_note
  self="$SELF"
  if is_dev; then
    other_name="konrad"
    target_image="$IMAGE_LOCAL_TAG"
    cache_note="
  - intermediate build-cache images:
      • konrad-python-base:cache
      • konrad-python-models:cache"
  else
    other_name="konrad-dev"
    target_image="konrad:latest"
    cache_note=""
  fi
  other_path="$(command -v "$other_name" 2>/dev/null || true)"

  cat >&2 <<EOF

==============================================================================
WARNING — $self uninstall will remove:

  - the CLI binary at: $0
  - the image:         $target_image$cache_note

This does NOT remove (your call):
  - your config:    $KONRAD_CFG_DIR/   (org/ + user/ layers, context/ material)
  - shared volumes: $SECRETS_VOLUME, $CACHE_VOLUME, $STATE_VOLUME
  - log dir:        $KONRAD_LOG_DIR/

(Use '$self reset' first to wipe the shared state; rm -rf the config dir
if you want that gone too.)
==============================================================================

EOF
  printf 'konrad: proceed with uninstall? [y/N]: ' >&2
  local confirmation=""
  read -r confirmation || true
  case "$confirmation" in
    y|Y|yes|YES) ;;
    *) info "aborted; nothing was removed."; exit 0 ;;
  esac

  # Remove this binary's image from the runtime engine. Quiet if missing.
  if command -v "$KONRAD_ENGINE" >/dev/null 2>&1 && eng_running; then
    if eng_image_exists "$target_image"; then
      eng_image_rm "$target_image"
      info "removed image $target_image"
    fi
  else
    warn "$KONRAD_ENGINE not reachable; image $target_image was NOT removed. Delete it manually."
  fi
  # konrad-dev's intermediate build-cache images are podman build artifacts
  # regardless of the runtime engine — sweep them via podman whenever it's around.
  if is_dev && command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1; then
    local img
    for img in konrad-python-base:cache konrad-python-models:cache; do
      if podman image exists "$img" 2>/dev/null; then
        podman image rm "$img" >/dev/null
        info "removed image $img"
      fi
    done
  fi

  # Delete the binary last. Bash has already mmap'd this script, so the
  # remainder of execution is safe. For konrad-dev, $0 is a symlink — rm
  # removes the symlink only, not the checkout it points at.
  if rm -f "$0" 2>/dev/null; then
    info "removed $0"
  else
    warn "failed to remove $0 (permissions?); delete manually."
  fi

  if [[ -n "$other_path" ]]; then
    info "$other_name is still installed at $other_path — uninstall separately with: $other_name uninstall"
  fi
  info "$self uninstalled."
}

do_help() {
  # Help branches on basename so each binary only lists the verbs that make
  # sense for its world. konrad has 'update'; konrad-dev has 'rebuild'.
  local self refresh_cmd variant_blurb cross_pointer
  self="$SELF"
  if is_dev; then
    refresh_cmd="  $self rebuild        Rebuild the local dev image from image/ (writes konrad:local)."
    variant_blurb="konrad-dev — contributor variant. Defaults to konrad:local (your local build),
so anything you're testing stays out of the way of the stable konrad next to it on PATH."
    cross_pointer="Your stable user CLI 'konrad' is unaffected by anything here. It lives next to
this binary on PATH and pulls konrad:latest from ghcr.io ('konrad update' to refresh)."
  else
    refresh_cmd="  $self update         Pull the latest image AND refresh the CLI itself.
  $self update --check Compare local vs registry; print 'up to date' or 'update available'."
    variant_blurb="konrad — sandboxed opencode in a Podman container."
    cross_pointer="Working on konrad itself? Install the contributor variant 'konrad-dev'
alongside this stable CLI — see CONTRIBUTING.md."
  fi

  cat <<EOF
$variant_blurb

Default ($self, no args): launch the interactive opencode TUI against the
current directory. Pass a subcommand or flag to do something else.

Subcommands:
  $self run <args…>    Non-interactive: exec 'opencode run <args…>' instead of
                        the TUI — one prompt, answer on stdout (pipeable). Args
                        after 'run' pass straight to opencode, so:
                          $self run "summarize this repo"
                          $self run --model <slug> "fix the failing test"
                        Put konrad's own flags (below) BEFORE 'run'.
  $self opencode <a…>  Pass-through: exec 'opencode <args…>' in the sandbox — the
                        escape hatch for opencode subcommands konrad doesn't wrap:
                          $self opencode models        # list available models
                          $self opencode agent list    # list configured agents
                          $self opencode session list  # past sessions
                        Firewall ON, output on stdout. (Provider auth is
                        'connect'; a single prompt is 'run'.)
  $self shell          Open a bash shell in the container instead of the TUI.
  $self connect [a…]   Authenticate a provider ('opencode auth login') with no
                        agent in the loop — the firewall is off for this step, so
                        an OAuth login (Claude Pro/Max, …) needs no --allow-host.
                        Args pass straight to opencode:
                          $self connect                 # pick a provider
                          $self connect -p openrouter   # skip the picker
                        The credential is stored on the konrad-secrets volume.
                        Same auth backend as the TUI's /connect, just agent-free.
  $self connect --custom [id]
                        Guided self-hosted / custom-endpoint flow: declares the
                        provider (baseURL + a model) in your user config layer,
                        then walks you through the key step. Prompts for whatever
                        you don't pass. (Already declared by your org? It just
                        does the key step.)
  $self mcp-auth <server>
                        Authenticate a remote MCP server's OAuth (e.g. a wiki or
                        issue tracker declared in your config). Agent-free,
                        firewall off, and the browser callback is forwarded into
                        the sandbox so the approval completes on its own. The
                        token is stored on the konrad-secrets volume and reused
                        on every run:
                          $self mcp-auth wiki

Maintenance subcommands:
$refresh_cmd
  $self reset          Wipe shared volumes + log dir. Prompts [y/N].
                        With --profile <name>: wipe only that profile's
                        state + cache volumes (leaves credentials + log dir).
  $self uninstall      Remove this binary's CLI + image. Prompts [y/N].
                        Leaves shared state alone — use '$self reset' for that.

Flags (modifiers — put them BEFORE the subcommand):
  --profile <name>      Use throwaway state + cache volumes suffixed with <name>
                        (konrad-state-<name> / konrad-cache-<name>) instead of
                        the shared ones; credentials stay shared. Isolates a
                        self-test / experiment from your real session + model.
  --no-firewall         Disable the egress firewall for this run (default ON).
                        Normally the agent reaches only the allow-list (your
                        providers + a small trusted set) via a sidecar proxy;
                        this restores unrestricted network access.
  --allow-host <host>   Add a host to the egress allow-list for this run
                        (repeatable, or comma-separated). For a permanent entry,
                        list it in ~/.config/konrad/user/allowed_hosts.
  -v, --verbose         Per-phase timestamps + opencode log-file pointer.
                        (Raw HTTP trace is separate: KONRAD_TRACE_FETCH=1 …)
  --version             Print CLI + image versions, then the immutable pin
                        (registry repo : short-sha), local tag, and build date.
  -h, --help            Show this message.

$cross_pointer

Override which image runs:
  KONRAD_IMAGE=konrad:pr-42 $self    Test a published PR image.
  KONRAD_IMAGE=konrad:my-tag $self   Run a custom-tagged image you built or pulled.

Resource caps (auto-scaled to this host: $(default_memory) RAM / $(default_cpus) CPUs;
bounds runaway use and lifts Apple container's tight 1G default that OOM-kills docling):
  KONRAD_MEMORY=8G $self             Pin the RAM cap (heavy docling / OCR).
  KONRAD_MEMORY=0 $self              Drop the RAM cap (Podman's old unbounded run).
  KONRAD_CPUS=8 $self                Pin the CPU-core cap (also docling/torch's thread budget).

Files the agent may write in your workspace (konrad does NOT create or
gitignore these — they appear only if the agent actually uses them):
  .agent/task.md        Current task's plan + outcome (committable).
  .agent/artifacts/     Durable mid-task outputs (committable).
  .agent/scratch/       Agent-written scripts / exploration.
  .agent/quality-assurance/<stamp>/    Quality-assurance evidence on a fail.

Files on the host (outside the workspace):
  $KONRAD_LOG_DIR
                        opencode logs. Pruned >7d on every launch. \`tail -f\` to read.

Files in ~/.config/konrad/user/ (all optional — your personal layer):
  opencode.jsonc        Deep-merged with konrad's baked defaults at start.
  agents/               Your own opencode primary agents, layered in.
  skills/               Your own opencode skills, layered in.
  AGENTS.md             Personal instructions, loaded on top of base.
  fonts/                .ttf / .otf / .ttc dropped here are loaded into
                        fontconfig on top of konrad's baked palette.
An organization can ship the same five things in ~/.config/konrad/org/;
they merge under your user layer (precedence: baked < org < user). See
README → Configuration → "For organizations".

Occasional maintenance (one-liners, not built into the CLI):
  Edit your override:   \$EDITOR ~/.config/konrad/user/opencode.jsonc
  Build-manifest dump:  podman run --rm --entrypoint cat $IMAGE_DEFAULT \\
                          /etc/konrad/build-manifest.json | jq .
EOF
}

# --- Flag parser + dispatch ---

# Test seam: when this file is *sourced* with KONRAD_SOURCE_ONLY=1, stop before
# the flag parser + dispatch so the helper functions can be exercised in
# isolation without running anything. `return` is valid only in a sourced
# context; in normal execution the condition is false, so it's never reached.
[[ "${KONRAD_SOURCE_ONLY:-0}" == "1" ]] && return 0

ACTION="run"
RUN_ARGS=()

# Grammar:  konrad [modifier flags] [<subcommand> [args…]]
# The action *verbs* are subcommands, not flags: update / reset / uninstall /
# shell (and konrad-dev's rebuild). Only genuine run modifiers stay flags
# (--profile / --no-firewall / --allow-host / -v), plus the conventional meta
# flags --version and -h/--help. Modifier flags come BEFORE the subcommand;
# run / connect / mcp-auth capture the rest of the line verbatim (their args
# belong to opencode) and stop parsing. No subcommand → the interactive TUI.
while [[ $# -gt 0 ]]; do
  case "$1" in
    run)        ACTION="run-oneshot"; shift; RUN_ARGS=("$@"); break ;;
    opencode)   ACTION="opencode";    shift; RUN_ARGS=("$@"); break ;;
    connect)    ACTION="connect";     shift; RUN_ARGS=("$@"); break ;;
    mcp-auth)   ACTION="mcp-auth";    shift; RUN_ARGS=("$@"); break ;;
    shell)      ACTION="shell";       shift; break ;;
    update)
      shift
      case "${1:-}" in
        --check) ACTION="check-updates" ;;
        "")      ACTION="update" ;;
        *)       die "update: unknown argument '$1' (only --check is accepted)" ;;
      esac
      break ;;
    reset)      ACTION="reset";      shift; break ;;
    uninstall)  ACTION="uninstall";  shift; break ;;
    rebuild)    ACTION="rebuild";    shift; break ;;
    pull-image) ACTION="pull-image"; shift; break ;;
    --profile)
      [[ $# -ge 2 ]] || die "--profile requires a name (e.g. --profile selftest)"
      [[ "$2" =~ ^[A-Za-z0-9_-]+$ ]] \
        || die "invalid profile name '$2' (allowed: letters, digits, '-', '_')"
      KONRAD_PROFILE="$2"; shift 2 ;;
    --no-firewall) KONRAD_FIREWALL=0; shift ;;
    --allow-host)
      [[ $# -ge 2 ]] || die "--allow-host requires a host (e.g. --allow-host github.com)"
      KONRAD_ALLOW_HOST="${KONRAD_ALLOW_HOST:+$KONRAD_ALLOW_HOST,}$2"; shift 2 ;;
    --verbose)  KONRAD_DEBUG=1;   shift ;;
    --version)  ACTION="version"; shift; break ;;
    --help)     ACTION="help";    shift; break ;;
    --)         shift; break ;;
    --*)        die "unknown flag: $1 (try: $SELF --help)" ;;
    -*)
      # Short-flag bundle: explode -vh into -v -h.
      flags="${1#-}"
      shift
      for (( i=0; i<${#flags}; i++ )); do
        char="${flags:$i:1}"
        case "$char" in
          v) KONRAD_DEBUG=1 ;;
          h) ACTION="help"  ;;
          *) die "unknown short flag: -$char (try: $SELF --help)" ;;
        esac
      done
      ;;
    *)          die "unknown subcommand or argument: $1 (try: $SELF --help)" ;;
  esac
done

# Fix the container engine once, now that flags (and any KONRAD_ENGINE) are in.
detect_engine

case "$ACTION" in
  run)           do_run agent ;;
  shell)         do_run shell ;;
  run-oneshot)   do_run_oneshot ${RUN_ARGS[@]+"${RUN_ARGS[@]}"} ;;
  opencode)      do_opencode ${RUN_ARGS[@]+"${RUN_ARGS[@]}"} ;;
  connect)       do_connect ${RUN_ARGS[@]+"${RUN_ARGS[@]}"} ;;
  mcp-auth)      do_mcp_auth ${RUN_ARGS[@]+"${RUN_ARGS[@]}"} ;;
  version)       do_version       ;;
  update)        do_update        ;;
  check-updates) do_check_updates ;;
  pull-image)    do_pull_image    ;;
  rebuild)    do_rebuild    ;;
  reset)     do_reset     ;;
  uninstall) do_uninstall ;;
  help)      do_help      ;;
esac
